  margin-bottom: 1.25rem;
  text-shadow: 0 0 60px rgba(124,58,237,0.15);
}

.hero-sub {
  color: var(--text-muted);
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 2rem;
