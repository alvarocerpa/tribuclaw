  flex-direction: column;
  gap: 0.5rem;
  overflow: hidden;
}

.chat-bubble {
  background: #2a2a3e;
  border-radius: 16px 16px 16px 4px;
  padding: 0.65rem 0.85rem;
  max-width: 85%;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.9);
  line-height: 1.45;
  opacity: 0;
  transform: translateY(8px);
  animation: bubbleIn 0.4s ease forwards;
}

.chat-bubble.msg-2 {
  animation-delay: 3s;
}

.chat-bubble.msg-3 {
  animation-delay: 5.5s;
}

@keyframes bubbleIn {
  to { opacity: 1; transform: translateY(0); }
}

.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 0.6rem 0.85rem;
  max-width: 50px;
  opacity: 0;
}

.typing-indicator span {
  width: 6px;
  height: 6px;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  animation: typingDot 1.4s ease-in-out infinite;
}

.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingDot {
  0%, 60%, 100% { opacity: 0.3; transform: scale(0.8); }
  30% { opacity: 1; transform: scale(1.1); }
}

.typing-indicator {
  animation: typingShow 0.3s ease forwards 0.3s;
}
.typing-2 {
  animation: typingShow2 0.3s ease forwards 3.8s;
}

@keyframes typingShow {
  0% { opacity: 0; }
  30% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes typingShow2 {
  0% { opacity: 0; }
  30% { opacity: 1; }
  80% { opacity: 1; }
  100% { opacity: 0; }
}

.phone-input {
  padding: 0.75rem 1rem;
