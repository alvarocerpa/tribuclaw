<Footer />

<script type="module">
// ═══════ GSAP ANIMATIONS ═══════
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ─── Hero animations on load ───
const heroBadge = document.querySelector('.hero-badge');
const heroHeadline = document.querySelector('.hero-headline');
const heroSub = document.querySelector('.hero-sub');
const heroCta = document.querySelector('.hero-cta');

const heroTl = gsap.timeline({ delay: 0.3 });
heroTl
  .from(heroBadge, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' })
  .from(heroHeadline, { opacity: 0, y: 30, duration: 0.7, ease: 'power2.out' }, '-=0.3')
  .from(heroSub, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3')
  .from(heroCta, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3');

// ─── Section headers: fade up ───
gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach(el => {
  if (el.closest('.hero')) return;
  gsap.from(el, {
    scrollTrigger: {
      trigger: el,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.7,
    ease: 'power2.out',
  });
});

// ─── Stagger animations ───
gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach(container => {
  if (container.closest('.hero')) return;
  const children = container.children;
  gsap.from(children, {
    scrollTrigger: {
      trigger: container,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.6,
    stagger: 0.1,
    ease: 'power2.out',
  });
});
</script>

<style>
/* ═══════ HERO ═══════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 6rem 1.5rem 4rem;
  overflow: hidden;
  background: linear-gradient(180deg, #050505 0%, #0a0a0f 50%, var(--bg) 100%);
}

.hero-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.hero-glow {
  position: absolute;
  top: 10%;
  left: -10%;
  width: 60%;
  height: 60%;
  background: radial-gradient(ellipse, rgba(124,58,237,0.08) 0%, transparent 70%);
