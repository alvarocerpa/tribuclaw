---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_URL, WHOP_URL } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`${SITE_TITLE} — Monta tu agente IA que trabaje 24/7 por ti`}
    description="Mientras tú haces todo manual, otros ya tienen un agente IA trabajando 24/7. TribuClaw te enseña a montar el tuyo en un servidor de 5€/mes. Sin ser programador."
  />
  <!-- LCP preload: hero image (phone frame is decorative, h1 is text LCP — font preload is in BaseHead) -->
  <link rel="preload" href="/images/logo-icon.webp" as="image" type="image/webp" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "TribuClaw — Membresía",
    "description": "Comunidad en español que te enseña a montar tu propio agente IA con OpenClaw. Curso completo, casos de uso reales, soporte 24/7, directos semanales y TribuClaw App.",
    "url": SITE_URL,
    "brand": { "@type": "Brand", "name": "TribuClaw" },
    "offers": {
      "@type": "Offer",
      "url": WHOP_URL,
      "price": "40",
      "priceCurrency": "EUR",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "ratingCount": "98"
    },
    "author": { "@type": "Person", "name": "Alvaro Cerpa", "url": SITE_URL }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Necesito saber programar?", "acceptedAnswer": { "@type": "Answer", "text": "No. El curso está pensado para gente sin conocimientos técnicos." } },
      { "@type": "Question", "name": "¿En cuánto tiempo tengo mi agente funcionando?", "acceptedAnswer": { "@type": "Answer", "text": "La mayoría lo tienen montado en la primera semana." } },
      { "@type": "Question", "name": "¿Puedo cancelar cuando quiera?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Sin permanencia. Entras y sales cuando quieras." } },
      { "@type": "Question", "name": "¿Qué necesito para empezar?", "acceptedAnswer": { "@type": "Answer", "text": "Solo un ordenador y conexión a internet. Te guiamos con lo demás." } },
      { "@type": "Question", "name": "¿El servidor de 5€/mes es obligatorio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí, es donde vive tu agente. Te enseñamos a montarlo en el curso." } },
      { "@type": "Question", "name": "¿Esto funciona para mi negocio?", "acceptedAnswer": { "@type": "Answer", "text": "Si gestionas emails, clientes o redes sociales de forma manual, sí. Funciona." } },
      { "@type": "Question", "name": "¿OpenClaw es de pago?", "acceptedAnswer": { "@type": "Answer", "text": "No. OpenClaw es 100% gratuito y open source. TribuClaw es la comunidad que te enseña a montarlo y sacarle provecho." } },
      { "@type": "Question", "name": "¿Puedo tener más de un agente?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Te enseñamos a configurarlos y gestionarlos." } },
      { "@type": "Question", "name": "¿Mis datos están seguros?", "acceptedAnswer": { "@type": "Answer", "text": "100%. Tu servidor, tus datos. Nada pasa por terceros." } },
      { "@type": "Question", "name": "¿Qué pasa si cancelo?", "acceptedAnswer": { "@type": "Answer", "text": "Tu agente sigue funcionando. Pierdes acceso a comunidad y updates." } }
    ]
  })} />
</head>
<body>

<Header />

<main id="main-content">

<!-- ═══════ BLOQUE 1: HERO ═══════ -->
<section class="hero" id="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="hero-left">
      <div class="hero-badge" data-animate="fade-up">
        <span>✦ La comunidad #1 de OpenClaw en español</span>
      </div>
      <h1 class="hero-headline" data-animate="fade-up">
        Tu agente IA.<br/>Tu día libre.
      </h1>
      <p class="hero-sub" data-animate="fade-up">
        La comunidad donde aprendes a montar agentes IA que trabajan por ti 24/7.
      </p>
      <div class="hero-cta" data-animate="fade-up">
        <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
          <span>Entrar a TribuClaw</span>
        </a>
      </div>
    </div>
    <div class="hero-right" data-animate="fade-up">
      <div class="phone-glow"></div>
      <div class="phone-frame">
        <div class="phone-notch"></div>
        <div class="phone-status">
          <span class="phone-time">9:41</span>
          <span class="phone-icons">● ● ●</span>
        </div>
        <div class="phone-header">
          <div class="phone-avatar">🤖</div>
          <div class="phone-header-info">
            <span class="phone-header-name">TribuBot</span>
            <span class="phone-header-status">en línea</span>
          </div>
        </div>
        <div class="phone-messages">
          <div class="chat-bubble chat-incoming">
            <span>📧 3 emails importantes. El de María necesita respuesta urgente.</span>
          </div>
          <div class="typing-indicator">
            <span></span><span></span><span></span>
          </div>
          <div class="chat-bubble chat-incoming msg-2">
            <span>✅ Post de LinkedIn publicado</span>
          </div>
          <div class="typing-indicator typing-2">
            <span></span><span></span><span></span>
          </div>
          <div class="chat-bubble chat-incoming msg-3">
            <span>📊 Resumen del día listo</span>
          </div>
        </div>
        <div class="phone-input">
          <span class="phone-input-placeholder">Mensaje...</span>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 2: EL PROBLEMA ═══════ -->
<section class="section section-problem" id="problema">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <h2 class="section-title">Tu negocio depende 100% de ti. Y eso tiene techo.</h2>
    </div>
    <div class="problem-text" data-animate="fade-up">
      <p>Piensa en tu día de ayer.</p>
      <p>Abriste los emails uno por uno. Respondiste clientes por WhatsApp. Publicaste algo en redes. Buscaste info para un proyecto. Preparaste una factura. Miraste el calendario. Contestaste un mensaje más. Y otro. Y otro.</p>
      <p>Todo eso lo hiciste tú. Manualmente. A mano.</p>
      <p>El problema no es que trabajes mucho. Es que <strong>no puedes trabajar más</strong>. Tu día tiene 24 horas y ya las usas todas. Si quieres facturar el doble, necesitas el doble de tiempo. Y ese tiempo no existe.</p>
      <p>La IA está ahí fuera. Todo el mundo habla de ella. Pero cuando intentas usarla de verdad, te encuentras con lo mismo: ChatGPT te da respuestas bonitas, pero no hace nada por ti. No abre tu email. No contesta a tus clientes. No publica mientras duermes.</p>
      <p>Hay un salto entre "usar ChatGPT" y "tener un sistema que trabaja por ti". Y casi nadie te explica cómo darlo.</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 3: QUÉ ES OPENCLAW ═══════ -->
<section class="section section-openclaw" id="openclaw">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">🌐 Open Source</span>
      <h2 class="section-title">OpenClaw: el proyecto open source que está cambiando las reglas</h2>
    </div>
    <div class="openclaw-text" data-animate="fade-up">
      <p>OpenClaw es el proyecto de agentes IA más grande del mundo. Más de 247.000 estrellas en GitHub. Gratuito. Open source. Cualquiera puede usarlo.</p>
      <p class="openclaw-clarify">Pero no es ChatGPT. No es una app que abres y le preguntas cosas.</p>
      <p>OpenClaw es un sistema que instalas en tu servidor (cuesta 5€/mes, lo mismo que un café) y que se conecta con tus herramientas reales:</p>
    </div>
    <div class="openclaw-tools" data-animate="stagger">
      <div class="glass-card tool-card">
        <span class="tool-icon">📧</span>
        <h3>Emails</h3>
        <p>Los lee, los clasifica, te prioriza lo importante.</p>
      </div>
      <div class="glass-card tool-card">
        <span class="tool-icon">💬</span>
        <h3>WhatsApp</h3>
        <p>Responde a tus clientes con contexto, no con respuestas genéricas.</p>
      </div>
      <div class="glass-card tool-card">
        <span class="tool-icon">📱</span>
        <h3>Redes sociales</h3>
        <p>Publica con tu voz y tu estilo.</p>
      </div>
      <div class="glass-card tool-card">
        <span class="tool-icon">📅</span>
        <h3>Calendario</h3>
        <p>Organiza tu semana.</p>
      </div>
      <div class="glass-card tool-card">
        <span class="tool-icon">📄</span>
        <h3>Documentos</h3>
        <p>Investiga, resume, genera informes.</p>
      </div>
    </div>
    <div class="openclaw-247" data-animate="fade-up">
      <p>Y lo hace <strong>24/7</strong>. Fines de semana incluidos.</p>
      <p class="openclaw-pivot">El problema: OpenClaw es gratis y abierto, pero montarlo bien cuesta tiempo, pruebas y dolores de cabeza. <strong>Ahí es donde entra TribuClaw.</strong></p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 4: UN DÍA CON TU AGENTE ═══════ -->
<section class="section section-timeline" id="timeline">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">⏰ Timeline</span>
      <h2 class="section-title">Así se ve un día con tu agente IA funcionando</h2>
    </div>
    <div class="timeline-table" data-animate="stagger">
      <div class="timeline-row glass-card">
        <span class="timeline-time">08:00</span>
        <p class="timeline-desc">Revisa tus emails overnight. Te prepara un resumen con solo los que necesitan respuesta. El resto ya está archivado.</p>
      </div>
      <div class="timeline-row glass-card">
        <span class="timeline-time">09:00</span>
        <p class="timeline-desc">Publica en tus redes sociales con tu tono y tu estilo. No es un post genérico — suena a ti.</p>
      </div>
      <div class="timeline-row glass-card">
        <span class="timeline-time">11:00</span>
        <p class="timeline-desc">Un cliente escribe por WhatsApp. Tu agente responde con contexto: tiene acceso a tu historial, tus precios, tus servicios.</p>
      </div>
      <div class="timeline-row glass-card">
        <span class="timeline-time">14:00</span>
        <p class="timeline-desc">Investiga tendencias de tu sector y te prepara un breve con lo relevante.</p>
      </div>
      <div class="timeline-row glass-card">
        <span class="timeline-time">17:00</span>
        <p class="timeline-desc">Te envía un resumen del día: qué se hizo, qué queda pendiente, qué necesitas decidir tú.</p>
      </div>
      <div class="timeline-row glass-card">
        <span class="timeline-time">23:00</span>
        <p class="timeline-desc">Sigue trabajando. Procesa lo que ha ido llegando. Prepara el día siguiente. Tú ya duermes.</p>
      </div>
    </div>
    <p class="timeline-note" data-animate="fade-up">Esto no es ciencia ficción. Es lo que hace OpenClaw. Y en TribuClaw te enseñamos paso a paso a montarlo.</p>
  </div>
</section>

<!-- ═══════ CTA INTERMEDIO 1 (después de bloque 4) ═══════ -->
<section class="section section-cta-mid">
  <div class="container">
    <div class="cta-mid-inner" data-animate="fade-up">
      <h2 class="cta-mid-title">¿Quieres que esto sea tu día a día?</h2>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
        <span>Entrar a TribuClaw</span>
      </a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 5: QUÉ INCLUYE ═══════ -->
<section class="section section-includes" id="incluye">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">📦 Todo lo que incluye</span>
      <h2 class="section-title">TribuClaw no es un curso más. Es todo lo que necesitas para tener tu agente funcionando.</h2>
    </div>
    <div class="includes-grid" data-animate="stagger">
      <div class="glass-card include-card">
        <span class="include-icon">🧠</span>
        <h3>Curso completo en español</h3>
        <p>De cero a tener tu sistema montado y funcionando. Sin conocimientos técnicos previos. Paso a paso, en vídeo, en tu idioma.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">🎯</span>
        <h3>Casos de uso semanales</h3>
        <p>Cada semana publicamos un caso de uso real. No teoría: cosas que nuestros agentes hacen HOY. Para que lo repliques en tu negocio.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">💬</span>
        <h3>Soporte 24/7</h3>
        <p>TribuBot (nuestro bot de soporte) responde tus dudas al instante. Y si no puede, Álvaro te responde personalmente.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">📺</span>
        <h3>Directos semanales</h3>
        <p>Cada miércoles a las 19:00 (hora peninsular) hacemos un directo en comunidad. Resolvemos dudas en vivo, mostramos novedades, compartimos avances.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">👥</span>
        <h3>Comunidad de 98 personas</h3>
        <p>No estás solo. Hay 98 personas dentro haciendo exactamente lo mismo que tú. Comparten avances, se ayudan, comparan resultados.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">⚙️</span>
        <h3>TribuClaw App</h3>
        <p>Panel de control para gestionar tu agente sin tocar código. Crear, configurar y monitorizar desde una interfaz sencilla.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 6: COMPARATIVA ═══════ -->
<section class="section section-compare" id="comparativa">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">⚖️ Comparativa</span>
      <h2 class="section-title">Lo que pasa si intentas hacerlo solo</h2>
    </div>
    <div class="compare-table" data-animate="fade-up">
      <div class="compare-row compare-header">
        <span class="compare-col compare-col-solo">Por tu cuenta</span>
        <span class="compare-col compare-col-tribu">Con TribuClaw</span>
      </div>
      <div class="compare-row">
        <span class="compare-col compare-col-solo">Googlear tutoriales en inglés que no se aplican a tu caso</span>
        <span class="compare-col compare-col-tribu">Curso en español, paso a paso, pensado para tu negocio</span>
      </div>
      <div class="compare-row">
        <span class="compare-col compare-col-solo">Preguntarle a ChatGPT y recibir respuestas genéricas</span>
        <span class="compare-col compare-col-tribu">Casos de uso semanales reales y replicables</span>
      </div>
      <div class="compare-row">
        <span class="compare-col compare-col-solo">Probar y error durante semanas (o meses)</span>
        <span class="compare-col compare-col-tribu">Tu sistema funcionando desde la primera semana</span>
      </div>
      <div class="compare-row">
        <span class="compare-col compare-col-solo">Nadie a quien preguntar cuando algo falla</span>
        <span class="compare-col compare-col-tribu">Soporte 24/7 + comunidad activa</span>
      </div>
      <div class="compare-row">
        <span class="compare-col compare-col-solo">Actualizarte solo de lo que cambia en IA</span>
        <span class="compare-col compare-col-tribu">Directos semanales con las novedades</span>
      </div>
    </div>
    <div class="compare-price" data-animate="fade-up">
      <p class="compare-price-label">¿Cuánto cuesta?</p>
      <p class="compare-price-line">TribuClaw: <strong>35€/mes</strong></p>
      <p class="compare-price-line">Tu servidor: <strong>5€/mes</strong></p>
      <p class="compare-price-total">Total: <strong>40€/mes</strong></p>
      <p class="compare-price-note">Menos que Netflix + Spotify + HBO. Y esto no te entretiene. Te libera horas.</p>
    </div>
  </div>
</section>

<!-- ═══════ CTA INTERMEDIO 2 (después de bloque 6) ═══════ -->
<section class="section section-cta-mid">
  <div class="container">
    <div class="cta-mid-inner" data-animate="fade-up">
      <h2 class="cta-mid-title">Deja de hacerlo todo a mano</h2>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
        <span>Entrar a TribuClaw</span>
      </a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 7: PROOF ═══════ -->
<section class="section section-proof" id="proof">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">⭐ 4.9/5 en Whop</span>
      <h2 class="section-title">Lo que dicen los que ya están dentro</h2>
      <p class="section-sub">98 miembros. 4,9 de 5. Datos reales de Whop, verificables por cualquiera.</p>
    </div>
    <div class="proof-stats" data-animate="stagger">
      <div class="proof-stat">
        <span class="proof-stat-value">98+</span>
        <span class="proof-stat-label">Miembros activos</span>
      </div>
      <div class="proof-stat">
        <span class="proof-stat-value">247K</span>
        <span class="proof-stat-label">GitHub stars</span>
      </div>
      <div class="proof-stat">
        <span class="proof-stat-value">4.9</span>
        <span class="proof-stat-label">Valoración media</span>
      </div>
    </div>
    <div class="reviews-static" data-animate="stagger">
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"Comunidad joven pero con muchísimo potencial. Contenido fresco, de actualidad, en español..."</p>
        <div class="review-author">
          <div class="review-avatar">SC</div>
          <div>
            <span class="review-name">SergioCR</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"Espectacular. Solo puedo decir esto. Gracias por el servicio que estáis dando en TribuClaw."</p>
        <div class="review-author">
          <div class="review-avatar">AB</div>
          <div>
            <span class="review-name">Alberto Batlle</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"Perfecto!!!"</p>
        <div class="review-author">
          <div class="review-avatar">E</div>
          <div>
            <span class="review-name">Edu</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
    </div>
    <p class="proof-closing" data-animate="fade-up">Llevamos 2 meses. El proyecto crece cada semana. Y los que entraron primero ya tienen sus agentes funcionando.</p>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ BLOQUE 7.5: TRIBUCLAW APP ═══════ -->
<section class="section section-app" id="app">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">🚀 TribuClaw App</span>
      <h2 class="section-title">Tu centro de control</h2>
      <p class="section-sub">Gestiona tus agentes sin tocar código. Crea, configura y monitoriza todo desde una interfaz pensada para que cualquiera pueda usarla.</p>
    </div>
    <div class="app-mockup" data-animate="fade-up">
      <div class="app-dashboard glass-card">
        <div class="app-sidebar">
          <div class="app-sidebar-logo">⚡ TribuClaw</div>
          <nav class="app-sidebar-nav">
            <a class="app-sidebar-item active">👥 Agentes</a>
            <a class="app-sidebar-item">📋 Tareas</a>
            <a class="app-sidebar-item">💬 Mensajes</a>
            <a class="app-sidebar-item">📊 Analytics</a>
            <a class="app-sidebar-item">⚙️ Configuración</a>
            <a class="app-sidebar-item">🌐 Comunidad</a>
          </nav>
          <div class="app-sidebar-user">
            <div class="app-sidebar-avatar">ÁC</div>
            <span>Álvaro</span>
          </div>
        </div>
        <div class="app-main">
          <div class="app-main-header">
            <h3>Panel general</h3>
            <span class="app-status-dot"></span> Todo operativo
          </div>
          <div class="app-cards">
            <div class="app-card">
              <span class="app-card-icon">🤖</span>
              <span class="app-card-value">3</span>
              <span class="app-card-label">Agentes activos</span>
            </div>
            <div class="app-card">
              <span class="app-card-icon">✅</span>
              <span class="app-card-value">12</span>
              <span class="app-card-label">Tareas hoy</span>
            </div>
            <div class="app-card">
              <span class="app-card-icon">💬</span>
              <span class="app-card-value">47</span>
              <span class="app-card-label">Mensajes</span>
            </div>
            <div class="app-card">
              <span class="app-card-icon">📈</span>
              <span class="app-card-value">98%</span>
              <span class="app-card-label">Uptime</span>
            </div>
          </div>
          <div class="app-activity">
            <div class="app-activity-item">
              <span class="app-activity-dot green"></span>
              <span>Email bot procesó 23 emails</span>
              <span class="app-activity-time">hace 2m</span>
            </div>
            <div class="app-activity-item">
              <span class="app-activity-dot green"></span>
              <span>LinkedIn bot publicó post</span>
              <span class="app-activity-time">hace 15m</span>
            </div>
            <div class="app-activity-item">
              <span class="app-activity-dot blue"></span>
              <span>WhatsApp bot respondió 4 clientes</span>
              <span class="app-activity-time">hace 1h</span>
            </div>
          </div>
        </div>
      </div>
    </div>
