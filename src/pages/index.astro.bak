.pricing-card {
  max-width: 480px;
  margin: 0 auto;
  padding: 2rem;
  text-align: center;
  position: relative;
  z-index: 1;
  border: 1px solid rgba(124,58,237,0.15);
}

.pricing-items {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}
.pricing-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-size: 0.9rem;
}
.pricing-item-label {
  color: rgba(250,250,250,0.7);
  text-align: left;
}
.pricing-item-value {
  font-weight: 700;
  color: #fafafa;
  white-space: nowrap;
}

.pricing-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem;
  background: rgba(124,58,237,0.08);
  border-radius: 10px;
  margin-bottom: 1.5rem;
}
.pricing-total-label {
  font-weight: 700;
  font-size: 1rem;
}
.pricing-total-value {
  font-size: 1.4rem;
  font-weight: 900;
  color: var(--accent);
}

.pricing-note {
  color: rgba(250,250,250,0.3);
  font-size: 0.8rem;
  margin-top: 1rem;
}

/* ═══════ BLOQUE 9: FAQ ═══════ */
.section-faq {
  background: var(--bg-alt);
}

.faq-list {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.faq-item {
  padding: 0;
  border: none;
  background: transparent;
}
.faq-item summary {
  padding: 1.25rem 1.5rem;
  cursor: pointer;
  font-weight: 700;
  font-size: 0.95rem;
  color: rgba(250,250,250,0.9);
  list-style: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.faq-item summary::after {
  content: '+';
  font-size: 1.2rem;
  color: var(--accent);
  font-weight: 300;
  transition: transform 0.2s;
}
.faq-item[open] summary::after {
  content: '−';
}
.faq-item summary::-webkit-details-marker {
  display: none;
}
.faq-item p {
  padding: 0 1.5rem 1.25rem;
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.6;
  margin: 0;
}

/* ═══════ BLOQUE 10: CIERRE ═══════ */
.section-cta-final {
  background: var(--bg);
  padding: 6rem 0;
}

.cta-final-inner {
  text-align: center;
  position: relative;
  z-index: 1;
  max-width: 680px;
  margin: 0 auto;
}
.cta-final-title {
  font-size: clamp(1.8rem, 5vw, 2.8rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin-bottom: 1.25rem;
}
.cta-final-sub {
  color: var(--text-muted);
  font-size: 1.05rem;
  margin-bottom: 0.75rem;
  line-height: 1.7;
}
.cta-final-hint {
  color: rgba(250,250,250,0.4);
  font-size: 0.9rem;
  margin-top: 1.5rem;
  font-style: italic;
}

/* ═══════ TRIBUCLAW APP ═══════ */
.section-app {
  background: var(--bg);
}

.app-mockup {
  max-width: 900px;
  margin: 0 auto 2.5rem;
}

.app-dashboard {
  display: grid;
  grid-template-columns: 180px 1fr;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
  min-height: 320px;
}

.app-sidebar {
  background: rgba(255,255,255,0.02);
  border-right: 1px solid rgba(255,255,255,0.06);
  padding: 1.25rem 0;
  display: flex;
  flex-direction: column;
}

.app-sidebar-logo {
  font-weight: 900;
  font-size: 0.85rem;
  padding: 0 1rem;
  margin-bottom: 1.25rem;
  color: var(--accent);
}

.app-sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  flex: 1;
}

.app-sidebar-item {
  padding: 0.55rem 1rem;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  cursor: default;
  transition: all 0.2s;
  border-left: 2px solid transparent;
}

.app-sidebar-item.active {
  color: #fff;
  background: rgba(124,58,237,0.1);
  border-left-color: var(--accent);
  font-weight: 600;
}

.app-sidebar-user {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  border-top: 1px solid rgba(255,255,255,0.06);
  font-size: 0.78rem;
  color: rgba(255,255,255,0.6);
}

.app-sidebar-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: var(--gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.6rem;
  font-weight: 700;
  color: #fff;
}

.app-main {
  padding: 1.5rem;
}

.app-main-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 1.25rem;
}

.app-main-header h3 {
  font-size: 0.95rem;
  font-weight: 800;
  color: #fff;
  margin-right: auto;
}

.app-status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #4ade80;
  display: inline-block;
}

.app-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.app-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.app-card-icon {
  font-size: 1.2rem;
}

.app-card-value {
  font-size: 1.5rem;
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
}

.app-card-label {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.4);
}

.app-activity {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.app-activity-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.78rem;
  color: rgba(255,255,255,0.6);
}

.app-activity-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.app-activity-dot.green { background: #4ade80; }
.app-activity-dot.blue { background: #60a5fa; }

.app-activity-time {
  margin-left: auto;
  font-size: 0.68rem;
  color: rgba(255,255,255,0.25);
  flex-shrink: 0;
}

.app-cta {
  text-align: center;
}

.app-coming {
  color: rgba(255,255,255,0.4);
  font-size: 0.9rem;
  margin-bottom: 1rem;
}

/* ═══════ RESPONSIVE ═══════ */
@media (min-width: 640px) {
  .includes-grid { grid-template-columns: repeat(2, 1fr); }
  .openclaw-tools { grid-template-columns: repeat(2, 1fr); }
  .reviews-static { grid-template-columns: repeat(3, 1fr); }
  .section { padding: 6rem 0; }
}

@media (min-width: 768px) {
  .hero-inner {
    grid-template-columns: 1.1fr 0.9fr;
  }
  .openclaw-tools { grid-template-columns: repeat(3, 1fr); }
  .includes-grid { grid-template-columns: repeat(2, 1fr); }
  .app-cards { grid-template-columns: repeat(4, 1fr); }
}

@media (min-width: 1024px) {
  .section { padding: 7rem 0; }
  .hero-inner {
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
  }
}

@media (max-width: 639px) {
  .hero { padding: 5rem 1rem 3rem; min-height: auto; }
  .hero-badge span { font-size: 0.7rem; padding: 0.3rem 0.7rem; }
  .hero-sub { font-size: 0.95rem; }
  .hero-right { display: none; }
  .section { padding: 4rem 0; }
  .section-title { font-size: 1.4rem; }
  .proof-stats { gap: 1rem; }
  .reviews-static { gap: 1rem; }
  .review-card { padding: 1.25rem; }
  .pricing-card { padding: 1.5rem; }
  .pricing-item { flex-direction: column; align-items: flex-start; gap: 0.15rem; }
  .cta-final-title { font-size: 1.5rem; }
  .compare-row { grid-template-columns: 1fr; }
  .compare-col-solo { padding-bottom: 0.25rem; color: rgba(250,250,250,0.35); font-size: 0.8rem; }
  .timeline-row { flex-direction: column; gap: 0.5rem; }
  .timeline-time { min-width: auto; }
  .app-dashboard {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .app-sidebar {
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 1rem 0;
  }
  .app-sidebar-nav {
    flex-direction: row;
    overflow-x: auto;
    gap: 0;
  }
  .app-sidebar-item {
    white-space: nowrap;
    padding: 0.4rem 0.75rem;
    font-size: 0.72rem;
    border-left: none;
    border-bottom: 2px solid transparent;
  }
  .app-sidebar-item.active {
    border-left-color: transparent;
    border-bottom-color: var(--accent);
  }
  .app-sidebar-user { display: none; }
  .app-cards { grid-template-columns: repeat(2, 1fr); }
  .app-activity { display: none; }
}
</style>

</body>
</html>
