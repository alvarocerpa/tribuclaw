  border-radius: 100px;
  padding: 0.4rem 1rem 0.4rem 0.4rem;
}
.chip-avatar {
  width: 28px; height: 28px;
  background: linear-gradient(135deg, #00d4ff, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  font-weight: 700;
  flex-shrink: 0;
}
.chip-name { font-size: 0.8rem; font-weight: 600; color: #c9d1d9; }
