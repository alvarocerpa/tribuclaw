---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_URL, WHOP_URL } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`${SITE_TITLE} — Aprende a montar tu equipo de agentes IA`}
    description="TribuClaw: la comunidad #1 de OpenClaw en español. Formación completa, casos de uso reales, soporte 24/7 y directos semanales para que la IA trabaje por ti."
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "TribuClaw",
    "url": SITE_URL,
    "logo": `${SITE_URL}/images/logo-icon.png`
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "TribuClaw",
    "url": SITE_URL,
    "inLanguage": "es"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "TribuClaw — Membresía",
    "description": "Comunidad en español con curso completo de OpenClaw, casos de uso reales, soporte 24/7, directos semanales y TribuClaw App.",
    "url": SITE_URL,
    "brand": { "@type": "Brand", "name": "TribuClaw" },
    "offers": {
      "@type": "Offer",
      "url": WHOP_URL,
      "price": "35",
      "priceCurrency": "EUR",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "ratingCount": "98"
    },
    "author": { "@type": "Person", "name": "Alvaro Cerpa", "url": SITE_URL }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es OpenClaw?", "acceptedAnswer": { "@type": "Answer", "text": "Sistema de agentes IA autónomos open source. 247K stars en GitHub. No es un chatbot: es un sistema de agentes que vive en tu servidor, ejecuta tareas, gestiona emails, navega la web y trabaja 24/7 por ti." } },
      { "@type": "Question", "name": "¿Necesito experiencia técnica?", "acceptedAnswer": { "@type": "Answer", "text": "No. El curso te guía paso a paso, en español. Sin experiencia técnica necesaria." } },
      { "@type": "Question", "name": "¿Qué incluye la membresía?", "acceptedAnswer": { "@type": "Answer", "text": "Curso completo, casos de uso semanales, TribuBot 24/7, directos semanales, TribuClaw App y comunidad activa." } },
      { "@type": "Question", "name": "¿Puedo tener más de un agente?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Te enseñamos a configurarlos y gestionarlos." } },
      { "@type": "Question", "name": "¿Mis datos están seguros?", "acceptedAnswer": { "@type": "Answer", "text": "100%. Tu servidor, tus datos. Nada pasa por terceros." } },
      { "@type": "Question", "name": "¿Qué pasa si cancelo?", "acceptedAnswer": { "@type": "Answer", "text": "Tu agente sigue funcionando. Pierdes acceso a comunidad y updates." } },
      { "@type": "Question", "name": "¿Puedo ganar dinero con esto?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Compartimos casos reales de monetización." } }
    ]
  })} />
</head>
<body>

<!-- HEADER -->
<header class="site-header" id="top">
  <div class="header-inner">
    <a href="#top" class="logo-link" aria-label="TribuClaw">
      <img src="/images/logo-icon.png" width="32" height="32" alt="" fetchpriority="high" />
      <span class="logo-text">Tribu<span class="accent">Claw</span></span>
    </a>
    <nav class="header-nav" id="main-nav">
      <a href="#features" class="nav-link">Features</a>
      <a href="#openclaw" class="nav-link">OpenClaw</a>
      <a href="#incluye" class="nav-link">Qué incluye</a>
      <a href="#precio" class="nav-link">Precio</a>
      <a href="#faq" class="nav-link">FAQ</a>
    </nav>
    <div class="header-cta-wrap">
      <a href={WHOP_URL} class="header-cta-btn" target="_blank" rel="noopener">Unirme →</a>
    </div>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-nav" id="mobile-nav">
    <a href="#features" class="mobile-nav-link">Features</a>
    <a href="#openclaw" class="mobile-nav-link">OpenClaw</a>
    <a href="#incluye" class="mobile-nav-link">Qué incluye</a>
    <a href="#precio" class="mobile-nav-link">Precio</a>
    <a href="#faq" class="mobile-nav-link">FAQ</a>
    <div class="mobile-nav-cta">
      <a href={WHOP_URL} class="cta-btn" target="_blank" rel="noopener">Unirme a TribuClaw →</a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- HERO -->
<section class="hero" id="hero">
  <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>
  <div class="hero-glow hero-glow-red"></div>
  <div class="hero-glow hero-glow-purple"></div>
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-badge-wrap reveal-stagger">
        <span class="hero-badge">✦ La comunidad #1 de OpenClaw en español</span>
      </div>
      <h1 class="hero-headline reveal-stagger">
        <span class="gradient-text">Aprende a montar tu equipo de agentes IA</span>
      </h1>
      <p class="hero-sub reveal-stagger">
        Formación completa, casos de uso reales, soporte 24/7 y todas las herramientas para que la IA trabaje por ti.
      </p>
      <div class="hero-cta-row reveal-stagger">
        <a href={WHOP_URL} class="cta-btn cta-hero" target="_blank" rel="noopener">
          <span class="cta-text">Unirme a TribuClaw</span>
        </a>
        <span class="cta-hint">Desde 35€/mes · Cancela cuando quieras</span>
      </div>
    </div>
    <div class="hero-bento reveal-stagger">
      <div class="bento-kw bento-kw-lg"><span class="bento-kw-e">🎓</span><span class="bento-kw-t">Formación</span></div>
      <div class="bento-kw bento-kw-md"><span class="bento-kw-e">🦞</span><span class="bento-kw-t">OpenClaw</span></div>
      <div class="bento-kw bento-kw-sm"><span class="bento-kw-e">🤖</span><span class="bento-kw-t">Agentes IA</span></div>
      <div class="bento-kw bento-kw-md"><span class="bento-kw-e">⚡</span><span class="bento-kw-t">Automatización</span></div>
      <div class="bento-kw bento-kw-sm"><span class="bento-kw-e">🟢</span><span class="bento-kw-t">24/7</span></div>
      <div class="bento-kw bento-kw-lg"><span class="bento-kw-e">👥</span><span class="bento-kw-t">Comunidad</span></div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="section-features reveal" id="features">
  <div class="sg sg-purple"></div>
  <div class="container">
    <div class="sh">
      <span class="sb">Todo lo que necesitas</span>
      <h2 class="st">Una membresía. Todo incluido.</h2>
      <p class="ss">Formación, herramientas, soporte y comunidad. Todo lo que necesitas para que la IA trabaje por ti.</p>
    </div>
    <div class="features-grid">
      <div class="fc reveal-stagger"><span class="fc-icon">🎓</span><h3>Curso completo</h3><p>Aprende desde cero a instalar y dominar OpenClaw. Vídeos actualizados, paso a paso, en español.</p></div>
      <div class="fc reveal-stagger"><span class="fc-icon">💡</span><h3>Casos de uso</h3><p>Cada semana nuevos casos reales: automatización, soporte, contenido, gestión, análisis.</p></div>
      <div class="fc reveal-stagger"><span class="fc-icon">🤖</span><h3>Soporte 24/7</h3><p>TribuBot responde al instante. Y si no puede, Álvaro está detrás.</p></div>
      <div class="fc reveal-stagger"><span class="fc-icon">📺</span><h3>Directos semanales</h3><p>Cada miércoles a las 19:00. Sesiones en vivo con Álvaro para resolver dudas.</p></div>
      <div class="fc reveal-stagger"><span class="fc-icon">📱</span><h3>TribuClaw App</h3><p>Tu centro de mandos: gestiona agentes, memoria, skills y automatizaciones.</p></div>
      <div class="fc reveal-stagger"><span class="fc-icon">👥</span><h3>Comunidad activa</h3><p>98 miembros que comparten, ayudan y construyen juntos.</p></div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- OPENCLAW -->
<section class="section-oc reveal" id="openclaw">
  <div class="sg sg-red"></div>
  <div class="container">
    <div class="sh">
      <span class="sb">🦞 OpenClaw</span>
      <h2 class="st">El proyecto open source con 247K estrellas en GitHub</h2>
      <p class="ss">No es un chatbot. Es un sistema de agentes autónomos que vive en tu servidor.</p>
    </div>
    <div class="oc-stats reveal-stagger">
      <div class="oc-stat"><span class="gradient-text">247K</span><span>GitHub Stars</span></div>
      <div class="oc-sep"></div>
      <div class="oc-stat"><span class="gradient-text">47.7K</span><span>Forks</span></div>
      <div class="oc-sep"></div>
      <div class="oc-stat"><span class="gradient-text">167K</span><span>Builders</span></div>
    </div>
    <div class="oc-cards reveal-stagger">
      <div class="gc"><div class="gc-icon">🧠</div><h3>No chatea. Ejecuta.</h3><p>A diferencia de ChatGPT, tu agente tiene "manos": navega la web, gestiona archivos, envía emails, organiza tu calendario. Actúa, no solo responde.</p></div>
      <div class="gc"><div class="gc-icon">🏠</div><h3>Vive en tu servidor</h3><p>Tu agente corre en tu VPS. Tus datos nunca salen de ahí. Si OpenClaw desaparece mañana, tu agente sigue funcionando.</p></div>
      <div class="gc"><div class="gc-icon">👥</div><h3>Multi-agente</h3><p>Un equipo entero: ventas, soporte, personal, contenido... cada uno con su personalidad y memoria aislada.</p></div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- BENTO -->
<section class="section-bento reveal" id="incluye">
  <div class="sg sg-purple"></div>
  <div class="container">
    <div class="sh">
      <span class="sb">📦 Lo que incluye TribuClaw</span>
      <h2 class="st">Supercharge tu workflow con IA</h2>
      <p class="ss">Todo lo que necesitas para dominar OpenClaw, en un solo sitio.</p>
    </div>
    <div class="bento-grid">
      <div class="bc bc-lg reveal-stagger"><div class="bc-glow"></div><span class="bc-e">🎓</span><h3>Curso paso a paso</h3><p>De cero a tu primer agente funcionando. Sin experiencia técnica necesaria.</p><div class="bc-tags"><span class="bc-tag">Vídeos</span><span class="bc-tag">Español</span><span class="bc-tag">Paso a paso</span></div></div>
      <div class="bc reveal-stagger"><div class="bc-glow"></div><span class="bc-e">💡</span><h3>Casos de uso semanales</h3><p>Ejemplos reales para tu negocio cada semana.</p></div>
      <div class="bc reveal-stagger"><div class="bc-glow"></div><span class="bc-e">🤝</span><h3>Soporte que responde</h3><p>TribuBot + Álvaro. No te quedas solo.</p></div>
      <div class="bc bc-wide reveal-stagger"><div class="bc-glow"></div><span class="bc-e">📡</span><h3>Directos cada miércoles</h3><p>19:00 CET. Preguntas en vivo, demos, novedades.</p></div>
      <div class="bc bc-lg reveal-stagger"><div class="bc-glow"></div><span class="bc-e">🖥️</span><h3>TribuClaw App</h3><p>Gestiona todo desde un solo sitio. Tu centro de mandos para agentes IA.</p><div class="bc-tags"><span class="bc-tag">Skills</span><span class="bc-tag">Memoria</span><span class="bc-tag">Automatizaciones</span></div></div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- SOCIAL PROOF -->
<section class="section-proof reveal" id="proof">
  <div class="sg sg-red"></div>
  <div class="container">
    <div class="sh">
      <span class="sb">⭐ 4.9/5 en Whop</span>
      <h2 class="st">No te lo cuento yo. Te lo cuentan ellos.</h2>
      <p class="ss">98 miembros. Agentes activos. Tareas ejecutándose mientras lees esto.</p>
    </div>
    <div class="counters-row">
      <div class="ci"><span class="cv" data-target="98" data-suffix="+">0</span><span class="cl">Miembros activos</span></div>
      <div class="ci"><span class="cv" data-target="247" data-suffix="K">0</span><span class="cl">GitHub stars</span></div>
      <div class="ci"><span class="cv" data-target="167" data-suffix="K">0</span><span class="cl">Builders activos</span></div>
      <div class="ci"><span class="cv" data-target="4.9" data-suffix="">0</span><span class="cl">Valoración media</span></div>
    </div>
    <div class="gc review-featured">
      <div class="rv-stars">★★★★★</div>
      <p class="rv-quote">"Espectacular. Solo puedo decir esto. Gracias por el servicio que estáis dando en TribuClaw."</p>
      <div class="rv-author"><div class="rv-avatar">AB</div><div><span class="rv-name">Alberto Batlle</span><span class="rv-role">Miembro de TribuClaw</span></div></div>
    </div>
    <div class="mq-wrap">
      <div class="mq-track" id="mq-track">
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"En menos de una semana ya tenía mi primer agente funcionando. Increíble."</p><span>Alvaro R.</span></div>
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"El soporte es de otra galaxia. Responden a cualquier hora."</p><span>Maria</span></div>
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"Llevo un mes y ya no puedo vivir sin mis agentes. Serio."</p><span>Raul</span></div>
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"La mejor inversión que he hecho este año. Sin duda."</p><span>Carlos M.</span></div>
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"Los directos de los miércoles son oro puro. Aprendo algo nuevo cada semana."</p><span>Laura P.</span></div>
        <div class="mq-item gcs"><span class="mq-s">★★★★★</span><p>"El curso está genial. Todo claro, sin rollo, y en español."</p><span>Javier S.</span></div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- PRICING -->
<section class="section-pricing reveal" id="precio">
  <div class="sg sg-red-lg"></div>
  <div class="container">
    <div class="sh">
      <span class="sb">💰 Precio transparente</span>
      <h2 class="st">¿Cuánto cuesta montar tu equipo de IA?</h2>
      <p class="ss">Menos de lo que te gastas en café al mes.</p>
    </div>
    <div class="pricing-grid">
      <div class="gc pricing-card reveal-stagger">
        <h3 class="pc-title">Coste real mensual</h3>
        <div class="pricing-rows">
          <div class="pr"><span>VPS (Hetzner)</span><span>~4€/mes</span></div>
          <div class="pr"><span>IA (OpenRouter)</span><span>1-5€/mes</span></div>
          <div class="pr"><span>OpenClaw</span><span class="pf">Gratis</span></div>
          <div class="pr"><span>Telegram</span><span class="pf">Gratis</span></div>
          <div class="pr"><span>TribuClaw</span><span>35€/mes</span></div>
          <div class="pr pr-total"><span>TOTAL</span><span class="pt">desde ~40€/mes</span></div>
        </div>
      </div>
      <div class="gc pricing-card reveal-stagger">
        <h3 class="pc-title">¿A qué equivale?</h3>
        <div class="pricing-rows">
          <div class="pr"><span>VA humano</span><span class="pm">800-2.000€/mes</span></div>
          <div class="pr"><span>Empleado</span><span class="pm">3.500€+/mes</span></div>
          <div class="pr pr-hl"><span>Tu agente IA</span><span class="pd">1,30€/día</span></div>
        </div>
      </div>
    </div>
    <div class="pricing-cta">
      <a href={WHOP_URL} class="cta-btn cta-hero" target="_blank" rel="noopener"><span class="cta-text">Unirme a TribuClaw</span></a>
      <p class="ph">98 miembros · 4.9/5 en Whop · Sin permanencia</p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- FAQ -->
<section class="section-faq reveal" id="faq">
  <div class="container">
    <div class="sh">
      <span class="sb">❓ FAQ</span>
      <h2 class="st">Preguntas frecuentes</h2>
    </div>
    <div class="faq-list">
      <div class="fi"><button class="fq"><span>¿Qué es OpenClaw?</span><span class="fa">+</span></button><div class="fas"><p>Sistema de agentes IA autónomos open source. 247K stars en GitHub. No es un chatbot: es un sistema de agentes que vive en tu servidor, ejecuta tareas, gestiona emails, navega la web y trabaja 24/7 por ti.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Necesito experiencia técnica?</span><span class="fa">+</span></button><div class="fas"><p>No. El curso te guía paso a paso, en español. Sin experiencia técnica necesaria.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Qué incluye la membresía?</span><span class="fa">+</span></button><div class="fas"><p>Curso completo, casos de uso semanales, TribuBot 24/7, directos semanales, TribuClaw App y comunidad activa de 98 miembros.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Puedo tener más de un agente?</span><span class="fa">+</span></button><div class="fas"><p>Sí. Te enseñamos a configurarlos y gestionarlos.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Mis datos están seguros?</span><span class="fa">+</span></button><div class="fas"><p>100%. Tu servidor, tus datos. Nada pasa por terceros.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Qué pasa si cancelo?</span><span class="fa">+</span></button><div class="fas"><p>Tu agente sigue funcionando. Pierdes acceso a comunidad y updates.</p></div></div>
      <div class="fi"><button class="fq"><span>¿Puedo ganar dinero con esto?</span><span class="fa">+</span></button><div class="fas"><p>Sí. Compartimos casos reales de monetización dentro de la comunidad.</p></div></div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- CTA FINAL -->
<section class="section-cta-final">
  <div class="sg sg-purple-lg"></div>
  <div class="container">
    <div class="cta-final-inner reveal">
      <h2 class="cfh"><span class="gradient-text">En 6 meses, tener un agente va a ser lo normal.</span></h2>
      <p class="cfs">Puedes entrar ahora o cuando todo el mundo lo esté haciendo.</p>
      <a href={WHOP_URL} class="cta-btn cta-hero" target="_blank" rel="noopener"><span class="cta-text">Unirme a TribuClaw</span></a>
      <p class="cfh-hint">Desde 35€/mes · Cancela cuando quieras</p>
    </div>
  </div>
</section>

</main>

<Footer />

<script>
(function(){
'use strict';

// Mobile nav
const t=document.getElementById('nav-toggle'),mn=document.getElementById('mobile-nav');
if(t&&mn){t.onclick=()=>{t.classList.toggle('open');mn.classList.toggle('open')};mn.querySelectorAll('a').forEach(a=>a.onclick=()=>{t.classList.remove('open');mn.classList.remove('open')})}

// Scroll reveal
const ro=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const p=e.target.closest('.reveal,section');if(p)p.querySelectorAll('.reveal-stagger').forEach((el,i)=>setTimeout(()=>el.classList.add('revealed'),i*100));e.target.classList.add('revealed');ro.unobserve(e.target)}})},{threshold:0.06,rootMargin:'-20px'});
document.querySelectorAll('.reveal').forEach(el=>ro.observe(el));
document.querySelectorAll('.hero .reveal-stagger').forEach((el,i)=>setTimeout(()=>el.classList.add('revealed'),200+i*150));

// Particles
const c=document.getElementById('hero-particles-canvas');
if(c){const x=c.getContext('2d'),m=innerWidth<768,N=m?20:50,C=['#e94560','#ff6b6b','#8b5cf6','#fff'],P=[];
function rs(){c.width=c.offsetWidth;c.height=c.offsetHeight}rs();addEventListener('resize',rs);
for(let i=0;i<N;i++)P.push({x:Math.random()*c.width,y:Math.random()*c.height,s:Math.random()*1.5+.5,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,o:Math.random()*.5+.1,c:C[Math.floor(Math.random()*C.length)],p:Math.random()*Math.PI*2});
let pa=false;document.addEventListener('visibilitychange',()=>{pa=hidden});
function an(){if(pa){requestAnimationFrame(an);return}x.clearRect(0,0,c.width,c.height);
for(let i=0;i<P.length;i++)for(let j=i+1;j<P.length;j++){const dx=P[i].x-P[j].x,dy=P[i].y-P[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<120){x.save();x.globalAlpha=(1-d/120)*.08;x.strokeStyle='#e94560';x.lineWidth=.5;x.beginPath();x.moveTo(P[i].x,P[i].y);x.lineTo(P[j].x,P[j].y);x.stroke();x.restore()}}
P.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.p+=.02;p.o=.1+Math.sin(p.p)*.2+.2;if(p.x<0)p.x=c.width;if(p.x>c.width)p.x=0;if(p.y<0)p.y=c.height;if(p.y>c.height)p.y=0;x.save();x.globalAlpha=p.o;x.fillStyle=p.c;x.shadowBlur=6;x.shadowColor=p.c;x.beginPath();x.arc(p.x,p.y,p.s,0,Math.PI*2);x.fill();x.restore()});requestAnimationFrame(an)}an()}

// Glow cursor
if(matchMedia('(pointer:fine)').matches){document.querySelectorAll('.gc,.bc,.fc').forEach(card=>{card.addEventListener('mousemove',e=>{const r=card.getBoundingClientRect(),g=card.querySelector('.bc-glow');if(g)g.style.background=`radial-gradient(400px circle at ${e.clientX-r.left}px ${e.clientY-r.top}px, rgba(233,69,96,0.06), transparent 60%)`});card.addEventListener('mouseleave',()=>{const g=card.querySelector('.bc-glow');if(g)g.style.background=''})})}

// Marquee
const mt=document.getElementById('mq-track');if(mt)mt.innerHTML=mt.innerHTML+mt.innerHTML;

// Counters
