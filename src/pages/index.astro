---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_URL, WHOP_URL } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`${SITE_TITLE} — Aprende a montar tu equipo de IA`}
    description="TribuClaw te enseña a montar tu equipo de agentes IA con OpenClaw. Formación completa, casos de uso, soporte 24/7 y directos semanales. Todo lo que necesitas para que la IA trabaje por ti."
  />

  <!-- Product Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "TribuClaw — Membresía",
    "description": "Comunidad en español con curso completo de OpenClaw, casos de uso reales, soporte 24/7, directos semanales y TribuClaw App para gestionar tu equipo de agentes IA.",
    "url": SITE_URL,
    "brand": {
      "@type": "Brand",
      "name": "TribuClaw"
    },
    "offers": {
      "@type": "Offer",
      "url": WHOP_URL,
      "price": "35",
      "priceCurrency": "EUR",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock",
      "category": "Membresía"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "98",
      "reviewCount": "98"
    },
    "author": {
      "@type": "Person",
      "name": "Alvaro Cerpa",
      "url": SITE_URL
    }
  })} />

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "¿Qué es OpenClaw?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "OpenClaw es un sistema de agentes IA autónomos de código abierto. A diferencia de ChatGPT, tu agente no solo chatea: ejecuta tareas, gestiona emails, organiza tu calendario, navega la web y recuerda todo lo que le cuentas. Es como tener un empleado digital que trabaja 24/7. Tiene 247K estrellas en GitHub y está respaldado por una fundación independiente con soporte de OpenAI."
        }
      },
      {
        "@type": "Question",
        "name": "¿Necesito experiencia técnica?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. El curso de TribuClaw está diseñado para personas sin experiencia técnica. Te guiamos paso a paso, en español, con vídeos actualizados y soporte directo. Si sabes enviar un mensaje por Telegram, puedes usar tu agente."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué incluye la membresía?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Curso completo para aprender OpenClaw, casos de uso semanales para diferentes negocios, TribuBot 24/7, soporte personal de Álvaro, directos cada miércoles a las 19:00 y TribuClaw App para gestionar tus agentes, memoria y automatizaciones."
        }
      },
      {
        "@type": "Question",
        "name": "¿Mis datos están seguros?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tus datos nunca salen de tu servidor. No pasan por nuestros servidores ni por terceros. OpenClaw corre en tu propio VPS, así que tú tienes el control total de tus datos."
        }
      },
      {
        "@type": "Question",
        "name": "¿Qué pasa si cancelo?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tu agente sigue funcionando. TribuClaw te da la formación, la comunidad y las herramientas, pero el agente es 100% tuyo. Si cancelas, pierdes acceso a la comunidad y actualizaciones, pero tu agente no se apaga."
        }
      },
      {
        "@type": "Question",
        "name": "¿Puedo tener más de un agente?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. OpenClaw soporta múltiples agentes, cada uno con su personalidad, memoria y propósito. Dentro de TribuClaw te enseñamos a configurarlos y gestionarlos todos desde TribuClaw App."
        }
      },
      {
        "@type": "Question",
        "name": "¿Puedo ganar dinero con esto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sí. Dentro de la comunidad compartimos casos de uso reales de personas que están rentabilizando agentes: automatización de servicios, negocios unipersonales con IA, soporte automatizado para clientes, y más."
        }
      }
    ]
  })} />
</head>
<body>

<!-- ═══════════════════════════════════ HEADER ═══════════════════════════════════ -->
<header class="site-header" id="top">
  <div class="header-inner">
    <a href="#top" class="logo-link" aria-label="TribuClaw - Inicio">
      <img src="/images/logo-icon.png" width="32" height="32" alt="TribuClaw logo" fetchpriority="high" />
      <span class="logo-text">Tribu<span class="accent">Claw</span></span>
    </a>
    <nav class="header-nav" id="main-nav">
      <a href="#que-es" class="nav-link">¿Qué es?</a>
      <a href="#incluye" class="nav-link">Qué incluye</a>
      <a href="#precio" class="nav-link">Precio</a>
      <a href="#faq" class="nav-link">FAQ</a>
    </nav>
    <div class="cta-wrap cta-wrap-sm">
      <a href={WHOP_URL} class="cta-btn header-cta" target="_blank" rel="noopener">
        Entrar a TribuClaw →
      </a>
    </div>
    <button class="nav-toggle" id="nav-toggle" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-nav" id="mobile-nav">
    <a href="#que-es" class="mobile-nav-link">¿Qué es?</a>
    <a href="#incluye" class="mobile-nav-link">Qué incluye</a>
    <a href="#precio" class="mobile-nav-link">Precio</a>
    <a href="#faq" class="mobile-nav-link">FAQ</a>
    <div class="mobile-nav-cta">
      <a href={WHOP_URL} class="cta-btn" target="_blank" rel="noopener" style="width:100%;justify-content:center;">
        Entrar a TribuClaw →
      </a>
    </div>
  </nav>
</header>

<main id="main-content">

<!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
<section class="hero">
  <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>
  <div class="hero-noise"></div>

  <div class="hero-inner">
    <div class="hero-copy">
      <span class="hero-badge reveal-stagger">98 miembros · Formación completa</span>
      <h1 class="hero-headline reveal-stagger">
        <span class="gradient-text-hero">Te enseñamos a montar tu equipo de IA</span> y te damos todas las herramientas para gestionarlo.
      </h1>
      <p class="hero-sub reveal-stagger">
        Kimo coordina. Mao escribe código. Pluma redacta. Mei gestiona. Data analiza.
        Todo a la vez, sin descanso, sin sueldo.
      </p>
      <p class="hero-body reveal-stagger">
        No es un chatbot más. Es un equipo completo de agentes especializados que opera en tu negocio mientras tú haces otra cosa.
        247.000 personas ya confían en la tecnología que usamos.
      </p>
      <div class="hero-cta-row reveal-stagger">
        <div class="cta-wrap">
          <a href={WHOP_URL} class="cta-btn cta-large" target="_blank" rel="noopener">
            <span class="cta-main">Unirme a TribuClaw</span>
            <span class="cta-sub-line">Desde 35€/mes · Cancela cuando quieras</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Dashboard -->
    <div class="hero-dashboard" id="agent-dashboard">
      <div class="dash-titlebar">
        <div class="dash-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="dash-title">TribuClaw OS — Agentes activos</span>
        <div class="dash-live">
          <span class="live-dot"></span>
          <span>LIVE</span>
        </div>
      </div>
      <div class="agents-grid">
        <div class="agent-card" data-agent="kimo">
          <div class="agent-avatar">🎯</div>
          <div class="agent-info">
            <span class="agent-name">Kimo</span>
            <span class="agent-role">Estrategia</span>
          </div>
          <div class="agent-status online"><span class="status-dot"></span><span>Activo</span></div>
          <div class="agent-activity">Revisando métricas de growth...</div>
        </div>
        <div class="agent-card" data-agent="mao">
          <div class="agent-avatar">🔧</div>
          <div class="agent-info">
            <span class="agent-name">Mao</span>
            <span class="agent-role">Desarrollo</span>
          </div>
          <div class="agent-status online"><span class="status-dot"></span><span>Activo</span></div>
          <div class="agent-activity">Desplegando nueva landing...</div>
        </div>
        <div class="agent-card" data-agent="pluma">
          <div class="agent-avatar">✍️</div>
          <div class="agent-info">
            <span class="agent-name">Pluma</span>
            <span class="agent-role">Copy</span>
          </div>
          <div class="agent-status busy"><span class="status-dot"></span><span>Ocupado</span></div>
          <div class="agent-activity">Redactando posts para LinkedIn...</div>
        </div>
        <div class="agent-card" data-agent="mika">
          <div class="agent-avatar">🎨</div>
          <div class="agent-info">
            <span class="agent-name">Mika</span>
            <span class="agent-role">Diseño</span>
          </div>
          <div class="agent-status online"><span class="status-dot"></span><span>Activo</span></div>
          <div class="agent-activity">Generando creatividades...</div>
        </div>
        <div class="agent-card" data-agent="mei">
          <div class="agent-avatar">📋</div>
          <div class="agent-info">
            <span class="agent-name">Mei</span>
            <span class="agent-role">Gestión</span>
          </div>
          <div class="agent-status online"><span class="status-dot"></span><span>Activo</span></div>
          <div class="agent-activity">Procesando facturas del mes...</div>
        </div>
        <div class="agent-card" data-agent="data">
          <div class="agent-avatar">📊</div>
          <div class="agent-info">
            <span class="agent-name">Data</span>
            <span class="agent-role">Analítica</span>
          </div>
          <div class="agent-status busy"><span class="status-dot"></span><span>Ocupado</span></div>
          <div class="agent-activity">Analizando tendencias semanales...</div>
        </div>
      </div>
      <div class="activity-feed" id="activity-feed">
        <div class="feed-item new">
          <span class="feed-time">ahora</span>
          <span class="feed-text"><strong>Kimo</strong> preparó briefing matutino</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ QUÉ ES OPENCLAW ═══════════════════════════════════ -->
<section class="section-openclaw reveal" id="que-es">
  <div class="container">
    <div class="text-center">
      <span class="badge badge-accent">🦞 Esto es OpenClaw</span>
      <h2 class="section-title">El proyecto de IA más viral de la historia</h2>
      <p class="section-lead section-lead-narrow">
        OpenClaw no es un chatbot. Es un sistema de agentes autónomos de código abierto que vive en tu servidor y trabaja para ti 24/7.
      </p>
    </div>

    <div class="oc-stats-row reveal-stagger">
      <div class="oc-stat">
        <span class="oc-stat-number gradient-text-stat">247K</span>
        <span class="oc-stat-label">GitHub Stars</span>
      </div>
      <div class="oc-stat-divider"></div>
      <div class="oc-stat">
        <span class="oc-stat-number gradient-text-stat">10 días</span>
        <span class="oc-stat-label">de 0 a 210K stars</span>
      </div>
      <div class="oc-stat-divider"></div>
      <div class="oc-stat">
        <span class="oc-stat-number gradient-text-stat">47.7K</span>
        <span class="oc-stat-label">Forks</span>
      </div>
    </div>

    <div class="oc-timeline reveal-stagger">
      <div class="oc-event">
        <div class="oc-event-date">Nov 2025</div>
        <div class="oc-event-text">Peter Steinberger crea el proyecto como código abierto</div>
      </div>
      <div class="oc-event">
        <div class="oc-event-date">Ene 2026</div>
        <div class="oc-event-text">Explota viralmente: 100K GitHub stars en menos de un mes</div>
      </div>
      <div class="oc-event">
        <div class="oc-event-date">Feb 2026</div>
        <div class="oc-event-text">OpenAI contrata al fundador. Sam Altman anuncia que OpenClaw vivirá en una fundación independiente con apoyo de OpenAI</div>
      </div>
      <div class="oc-event highlight">
        <div class="oc-event-date">Ahora</div>
        <div class="oc-event-text">247K stars, fundación independiente, respaldado por OpenAI. El futuro de los agentes personales de IA.</div>
      </div>
    </div>

    <div class="oc-pillars">
      <div class="glass-card reveal-stagger">
        <div class="oc-pillar-icon">🧠</div>
        <h3>No chatea. Ejecuta.</h3>
        <p>A diferencia de ChatGPT, OpenClaw tiene "manos": navega la web, gestiona archivos, envía emails, organiza tu calendario. Actúa, no solo responde.</p>
      </div>
      <div class="glass-card reveal-stagger">
        <div class="oc-pillar-icon">🏠</div>
        <h3>Vive en tu servidor</h3>
        <p>Tu agente corre en tu VPS. Tus datos nunca salen de ahí. Si OpenClaw desaparece mañana, tu agente sigue funcionando. Es tuyo.</p>
      </div>
      <div class="glass-card reveal-stagger">
        <div class="oc-pillar-icon">👥</div>
        <h3>Multi-agente</h3>
        <p>No solo un agente: un equipo entero. Agente de ventas, de soporte, personal, de contenido... cada uno con su personalidad y memoria aislada.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ QUÉ INCLUYE — BENTO GRID ═══════════════════════════════════ -->
<section class="section-includes reveal" id="incluye">
  <div class="container">
    <div class="text-center">
      <span class="badge badge-accent">📦 Todo lo que obtienes</span>
      <h2 class="section-title">Una membresía. Todo lo que necesitas para dominar la IA.</h2>
      <p class="section-lead section-lead-narrow">
        Formación, comunidad, herramientas y soporte. Todo lo que separa a los que ya tienen agentes de los que siguen "explorando opciones".
      </p>
    </div>

    <div class="bento-grid">
      <!-- Card 1: Formación — grande -->
      <div class="bento-card bento-card-lg reveal-stagger">
        <div class="bento-glow"></div>
        <span class="bento-icon">🎓</span>
        <h3>Curso completo de OpenClaw</h3>
        <p>De cero a tener tu equipo de agentes funcionando. Todo en español, paso a paso, con vídeos actualizados. Vas a tu ritmo, pero sin relleno.</p>
        <div class="bento-tags">
          <span class="bento-tag">Vídeos actualizados</span>
          <span class="bento-tag">En español</span>
          <span class="bento-tag">Paso a paso</span>
        </div>
      </div>

      <!-- Card 2: Casos de uso -->
      <div class="bento-card reveal-stagger">
        <div class="bento-glow"></div>
        <span class="bento-icon">💡</span>
        <h3>Casos de uso reales</h3>
        <p>Ejemplos concretos de cómo aplicar agentes a tu negocio. Coaching, e-commerce, freelance, SaaS...</p>
      </div>

      <!-- Card 3: Soporte -->
      <div class="bento-card reveal-stagger">
        <div class="bento-glow"></div>
        <span class="bento-icon">🤝</span>
        <h3>Soporte 24/7</h3>
        <p>TribuBot resuelve tus dudas a cualquier hora. Y si necesitas algo más, Álvaro está ahí personalmente.</p>
      </div>

      <!-- Card 4: Directos — ancho -->
      <div class="bento-card bento-card-wide reveal-stagger">
        <div class="bento-glow"></div>
        <span class="bento-icon">📡</span>
        <h3>Directos semanales — Cada miércoles a las 19:00</h3>
        <p>Q&A en vivo con Álvaro. Troubleshooting, estrategia, casos de uso. Preguntas que importan, respuestas de gente que lo usa cada día.</p>
      </div>

      <!-- Card 5: TribuClaw App — grande -->
      <div class="bento-card bento-card-lg reveal-stagger">
        <div class="bento-glow"></div>
        <span class="bento-icon">🖥️</span>
        <h3>TribuClaw App</h3>
        <p>Tu centro de mandos para gestionar todo: skills, memoria, automatizaciones y agentes. Sin tocar código si no quieres.</p>
        <div class="bento-tags">
          <span class="bento-tag">Skills</span>
          <span class="bento-tag">Memoria</span>
          <span class="bento-tag">Automatizaciones</span>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ UN DÍA CON TU AGENTE ═══════════════════════════════════ -->
<section class="timeline-section" id="timeline">
  <div class="container">
    <div class="text-center">
      <h2 class="section-title">Lo que tu agente hace mientras tú vives.</h2>
      <p class="section-lead section-lead-narrow">
        Un día normal cuando tienes un equipo de IA. Sin exagerar: esto es lo que hacen los agentes de TribuClaw ahora mismo.
      </p>
    </div>
    <div class="timeline-wrapper">
      <div class="timeline-track">
        <div class="timeline-progress" id="timeline-progress"></div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-time">07:00 — Briefing automático</div>
        <div class="timeline-event-title">Kimo lee tus mensajes pendientes, revisa las novedades relevantes para tu negocio y te prepara un resumen antes de que abras el ordenador.</div>
        <div class="timeline-event-desc">Tú te despiertas informado.</div>
        <div class="timeline-preview">Kimo → Briefing listo: 3 emails nuevos, 1 propuesta pendiente</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-time">10:00 — Emails y agenda</div>
        <div class="timeline-event-title">Mientras atiendes lo urgente, Kimo filtra, responde y organiza. Solo llegan a ti los que de verdad necesitan tu criterio.</div>
        <div class="timeline-event-desc">El resto, resuelto.</div>
        <div class="timeline-preview">Kimo → 8 emails procesados, 2 requieren tu aprobación</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-time">14:00 — Competencia y tendencias</div>
        <div class="timeline-event-title">Data monitoriza lo que se mueve en tu sector. Si hay algo que te afecta, lo sabes antes que la mayoría.</div>
        <div class="timeline-event-desc">Sin pasar horas en Twitter buscando.</div>
        <div class="timeline-preview">Data → 3 tendencias detectadas en tu sector esta semana</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-time">18:00 — Informe del día</div>
        <div class="timeline-event-title">Pluma redacta el resumen. Mei ordena las tareas para mañana. Mao prepara lo que haga falta en código.</div>
        <div class="timeline-event-desc">Cierras el día sin cabos sueltos.</div>
        <div class="timeline-preview">Pluma → Informe del día listo · Mei → 5 tareas programadas para mañana</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-time">22:00 — Trabajan. Tú duermes.</div>
        <div class="timeline-event-title">Mientras descansas, tus agentes ejecutan las tareas programadas, monitorizan, preparan y dejan todo listo para que mañana empiece rodando.</div>
        <div class="timeline-event-desc">Así cada día.</div>
        <div class="timeline-preview">Sistema → 12 tareas nocturnas en ejecución · Todo OK</div>
      </div>
    </div>

    <div class="text-center" style="margin-top:3rem;">
      <div class="cta-wrap">
        <a href={WHOP_URL} class="cta-btn" target="_blank" rel="noopener">
          <span class="cta-main">Quiero este sistema en mi negocio →</span>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ SOCIAL PROOF ═══════════════════════════════════ -->
<section class="proof-section reveal" id="proof">
  <div class="container">
    <div class="text-center">
      <span class="badge badge-accent">⭐ 4.9/5 en Whop</span>
      <h2 class="section-title">No te lo estoy contando yo. Te lo cuentan ellos.</h2>
      <p class="section-lead section-lead-narrow">
        98 miembros. Agentes activos. Tareas ejecutándose mientras lees esto.
      </p>
    </div>

    <!-- Counters -->
    <div class="counters-row">
      <div class="counter-item">
        <span class="counter-value" data-target="98" data-suffix="+">0</span>
        <span class="counter-label">Miembros activos</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="247" data-suffix="K">0</span>
        <span class="counter-label">GitHub stars</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="167" data-suffix="K">0</span>
        <span class="counter-label">Builders activos</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="5" data-suffix="">0</span>
        <span class="counter-label">Agentes listos</span>
      </div>
    </div>

    <!-- Review destacada -->
    <div class="glass-card review-featured">
      <div class="review-quote">
        <span class="review-quote-mark">"</span>
        Espectacular. Solo puedo decir esto. Gracias por el servicio que estáis dando en TribuClaw.
      </div>
      <div class="review-author-featured">
        <div class="review-avatar">AB</div>
        <div>
          <span class="review-name">Alberto Batlle</span>
          <span class="review-stars-sm">★★★★★</span>
        </div>
      </div>
    </div>

    <!-- Marquee de reviews -->
    <div class="marquee-wrap">
      <div class="marquee-track" id="marquee-track">
        <div class="marquee-item glass-card-sm">
          <span class="marquee-stars">★★★★★</span>
          <span class="marquee-text">"En menos de una semana ya tenía mi primer agente funcionando. Increíble."</span>
          <span class="marquee-author">Alvaro R.</span>
        </div>
