/* Price compare */
.price-compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  max-width: 560px;
  margin: 0 auto 3rem;
}
.price-col {
  background: rgba(22, 27, 34, 1);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.price-col.highlight {
  border-color: rgba(0, 212, 255, 0.3);
  background: rgba(0, 212, 255, 0.04);
}
.price-col-label {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #484f58;
}
.price-amount {
  font-size: 1.8rem;
  font-weight: 900;
  line-height: 1;
}
.price-col:not(.highlight) .price-amount {
  color: #484f58;
  text-decoration: line-through;
}
.price-col.highlight .price-amount {
  color: #00d4ff;
}
.price-per-day {
  font-size: 0.8rem;
  color: #484f58;
}
