   HEADER
   ═══════════════════════════════════════════════════ */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  background: rgba(13,17,23,0.8);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.header-inner {
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 3rem;
  height: 60px;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.logo-link {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: white;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: -0.02em;
}
.logo-link:hover { text-decoration: none; }
.header-nav { display: none; }
.nav-link {
  color: #8b949e;
  font-size: 0.85rem;
  font-weight: 600;
  text-decoration: none;
  transition: color 0.2s;
}
.nav-link:hover { color: #e94560; }
.nav-toggle {
  display: flex;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  z-index: 110;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: #fff;
  border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s;
}
.nav-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.nav-toggle.open span:nth-child(2) { opacity: 0; }
.nav-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

.mobile-nav {
  position: fixed;
  top: 60px;
  left: 0; right: 0; bottom: 0;
  background: rgba(13,17,23,0.98);
  backdrop-filter: blur(16px);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem;
  gap: 1rem;
  transform: translateX(100%);
  transition: transform 0.3s ease;
  z-index: 99;
}
.mobile-nav.open { transform: translateX(0); }
.mobile-nav-link {
  color: #c9d1d9;
  font-size: 1.1rem;
  font-weight: 600;
  text-decoration: none;
  padding: 0.75rem 0;
}
.mobile-nav-cta { margin-top: 1rem; width: 100%; max-width: 300px; }

/* ═══════════════════════════════════════════════════
   CTA SYSTEM
   ═══════════════════════════════════════════════════ */
.cta-wrap {
  background: #0d1117;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 4px;
  display: inline-flex;
  position: relative;
  overflow: hidden;
}
.cta-wrap::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  translate: -50% -50%;
  width: max(200%, 200vh);
  height: max(200%, 200vh);
  background: conic-gradient(transparent 0deg, transparent 280deg, #e94560 330deg, #ff6b6b 360deg);
  animation: cta-border-spin 3s linear infinite;
  z-index: 0;
}
.cta-wrap::after {
  content: '';
  position: absolute;
  inset: 2px;
  background: #0d1117;
  border-radius: 12px;
  z-index: 0;
}
.cta-wrap > * { position: relative; z-index: 1; }
@keyframes cta-border-spin { 100% { rotate: 360deg; } }

.cta-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
  background: #e94560;
  color: white;
  font-family: 'Inter', sans-serif;
  font-weight: 900;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 0.85rem 2rem;
  border-radius: 10px;
  border: none;
  border-top: 1px solid rgba(255,255,255,0.2);
  text-decoration: none;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  transition: 0.3s ease-out;
  animation: cta-pulse 2s ease-in-out infinite;
  white-space: nowrap;
}
.cta-btn:hover { transform: translateY(-2px); text-decoration: none; color: white; }
.cta-main { display: block; }
.cta-sub-line {
  display: block;
  font-size: 0.65rem;
  font-weight: 500;
  text-transform: none;
  letter-spacing: 0;
  opacity: 0.7;
  margin-top: 0.2rem;
}
@keyframes cta-pulse {
  0%, 100% { box-shadow: 0 4px 20px rgba(233,69,96,0.5), 0 8px 40px rgba(233,69,96,0.2); }
  50% { box-shadow: 0 6px 30px rgba(233,69,96,0.7), 0 12px 60px rgba(233,69,96,0.3); }
}
.cta-btn::before {
  content: '';
  position: absolute;
  bottom: -40%;
  left: 50%;
  width: 120%;
  height: 120%;
  background: radial-gradient(#ff6b6b, rgba(255,107,107,0.5) 30%, transparent 60%);
  filter: blur(10px);
  animation: cta-breathe 2.5s ease-in-out infinite;
  pointer-events: none;
  z-index: -1;
  transform: translateX(-50%);
}
@keyframes cta-breathe {
  0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(0.7); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
}
.cta-btn::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 100%;
  background-image:
    radial-gradient(1.5px 1.5px at 10% 100%, rgba(255,255,255,0.6), transparent),
    radial-gradient(1px 1px at 30% 95%, rgba(255,255,255,0.4), transparent),
    radial-gradient(1.5px 1.5px at 50% 100%, rgba(255,255,255,0.5), transparent),
    radial-gradient(1px 1px at 70% 92%, rgba(255,255,255,0.3), transparent),
    radial-gradient(1.5px 1.5px at 90% 100%, rgba(255,255,255,0.6), transparent);
  background-repeat: no-repeat;
  mask-image: linear-gradient(transparent 20%, white 100%);
  animation: cta-particles 2s linear infinite;
  pointer-events: none;
  z-index: 1;
}
@keyframes cta-particles {
  0% { opacity: 1; background-position: 10% 100%, 30% 95%, 50% 100%, 70% 92%, 90% 100%; }
  100% { opacity: 0.3; background-position: 10% 20%, 30% 10%, 50% 25%, 70% 5%, 90% 15%; }
}
.cta-large { font-size: 1rem; padding: 1rem 2.5rem; }
.cta-wrap-sm { padding: 2px; border-radius: 10px; }
.cta-wrap-sm .header-cta { font-size: 0.75rem; padding: 0.5rem 1rem; }

/* ═══════════════════════════════════════════════════
   SECTION DIVIDER & REVEAL
   ═══════════════════════════════════════════════════ */
.section-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(233,69,96,0.15), rgba(139,92,246,0.1), transparent);
  max-width: 800px;
  margin: 0 auto;
}
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s ease-out, transform 0.7s ease-out;
}
.reveal.revealed { opacity: 1; transform: translateY(0); }

.reveal-stagger {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s cubic-bezier(0.16,1,0.3,1);
}
.reveal-stagger.revealed-stagger {
  opacity: 1;
  transform: translateY(0);
}

section { padding: 5rem 0; }

/* ═══════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 7rem 0 5rem;
  overflow: hidden;
  background: #0d1117;
}
#hero-particles-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  opacity: 0.8;
}
.hero-glow {
  position: absolute;
  pointer-events: none;
  z-index: 0;
  border-radius: 50%;
}
.hero-glow-1 {
  top: -20%;
  left: 50%;
  transform: translateX(-50%);
  width: 1400px;
  height: 800px;
  background: radial-gradient(ellipse at center, rgba(233,69,96,0.1) 0%, transparent 55%);
}
.hero-glow-2 {
  bottom: -30%;
  right: -10%;
  width: 800px;
  height: 800px;
  background: radial-gradient(ellipse at center, rgba(139,92,246,0.07) 0%, transparent 55%);
}
.hero-noise {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.02) 1.5px, transparent 1.5px);
  background-size: 15px 15px;
  pointer-events: none;
  z-index: 0;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1600px;
  margin: 0 auto;
  padding: 0 3rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
  width: 100%;
}

.hero-copy { text-align: center; }

.hero-badge {
  display: inline-block;
  background: rgba(233,69,96,0.1);
  border: 1px solid rgba(233,69,96,0.25);
  color: #e94560;
  padding: 0.4rem 1rem;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 700;
  margin-bottom: 1.5rem;
}
.hero-headline {
  font-size: clamp(2rem, 6vw, 4.2rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin-bottom: 1.25rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}
.hero-sub {
  color: #c9d1d9;
  font-size: 1.1rem;
  line-height: 1.7;
  margin-bottom: 1rem;
  max-width: 620px;
  margin-left: auto;
  margin-right: auto;
}
.hero-body {
  color: #8b949e;
  font-size: 0.95rem;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}
.hero-cta-row {
  display: flex;
  justify-content: center;
}

/* Dashboard hidden on mobile by default */
.hero-dashboard { display: none; }

/* ═══════════════════════════════════════
   DASHBOARD STYLES
   ═══════════════════════════════════════ */
.hero-dashboard {
  background: rgba(13, 17, 23, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  overflow: hidden;
  backdrop-filter: blur(24px) saturate(1.2);
  -webkit-backdrop-filter: blur(24px) saturate(1.2);
  box-shadow:
    0 0 0 1px rgba(233, 69, 96, 0.06),
    0 24px 80px rgba(0, 0, 0, 0.5),
    0 0 120px rgba(233, 69, 96, 0.04),
    inset 0 1px 0 rgba(255,255,255,0.04);
  animation: dashboardFloat 6s ease-in-out infinite;
}
@keyframes dashboardFloat {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}
.dash-titlebar {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: rgba(255, 255, 255, 0.02);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.dash-dots { display: flex; gap: 6px; }
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot-red { background: #ff5f57; }
.dot-yellow { background: #ffbd2e; }
.dot-green { background: #28ca41; }
.dash-title { flex: 1; font-size: 0.75rem; color: #484f58; text-align: center; }
.dash-live {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.65rem;
  font-weight: 700;
  color: #14b8a6;
  letter-spacing: 0.05em;
}
.live-dot {
  width: 6px; height: 6px;
  background: #14b8a6;
  border-radius: 50%;
  animation: livePulse 1.5s ease-in-out infinite;
}
@keyframes livePulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(20,184,166,0.5); }
  50% { box-shadow: 0 0 0 4px rgba(20,184,166,0); }
}
.agents-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.04);
  padding: 1px;
}
.agent-card {
  background: #0d1117;
  padding: 0.75rem 1rem;
  cursor: pointer;
  transition: background 0.2s;
  position: relative;
  overflow: hidden;
}
.agent-card:hover { background: rgba(233, 69, 96, 0.04); }
.agent-card.active { background: rgba(233, 69, 96, 0.06); }
.agent-avatar { font-size: 1.5rem; margin-bottom: 0.25rem; }
.agent-name { display: block; font-size: 0.8rem; font-weight: 700; color: #f0f6fc; }
.agent-role { display: block; font-size: 0.65rem; color: #484f58; }
.agent-status {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.65rem;
  margin-top: 0.25rem;
}
.agent-status.online { color: #14b8a6; }
.agent-status.busy { color: #f59e0b; }
.status-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: currentColor;
}
.agent-activity {
  font-size: 0.6rem;
  color: #484f58;
  margin-top: 0.35rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.activity-feed {
  padding: 0.5rem 1rem;
  border-top: 1px solid rgba(255,255,255,0.04);
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  max-height: 80px;
  overflow: hidden;
}
.feed-item {
  display: flex;
  gap: 0.75rem;
  font-size: 0.65rem;
  color: #484f58;
  animation: feedSlideIn 0.4s ease-out;
}
.feed-item.new { color: #8b949e; }
.feed-time { color: #e94560; flex-shrink: 0; }
@keyframes feedSlideIn {
  from { opacity: 0; transform: translateX(-8px); }
  to { opacity: 1; transform: translateX(0); }
}

/* ═══════════════════════════════════════════════════
   QUÉ ES OPENCLAW
   ═══════════════════════════════════════════════════ */
.section-openclaw {
  background: linear-gradient(180deg, #0d1117 0%, #161b22 50%, #0d1117 100%);
  position: relative;
  overflow: hidden;
}
.section-openclaw::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 20px 20px;
  pointer-events: none;
}

.oc-stats-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 2rem;
  margin: 2.5rem 0;
  flex-wrap: wrap;
}
.oc-stat { text-align: center; }
.oc-stat-number {
  display: block;
  font-size: clamp(2.2rem, 5vw, 3.2rem);
  font-weight: 900;
  line-height: 1.1;
}
.oc-stat-label {
  display: block;
  font-size: 0.85rem;
  color: #8b949e;
  margin-top: 0.25rem;
}
.oc-stat-divider {
  width: 1px;
  height: 50px;
  background: linear-gradient(to bottom, transparent, rgba(233,69,96,0.4), transparent);
  box-shadow: 0 0 8px rgba(233,69,96,0.15);
}

.oc-timeline {
  max-width: 600px;
  margin: 0 auto 3rem;
  display: flex;
  flex-direction: column;
  position: relative;
  padding-left: 2rem;
  border-left: 2px solid rgba(233,69,96,0.2);
}
.oc-event {
  position: relative;
  padding: 1rem 0 1rem 1.5rem;
}
.oc-event::before {
  content: '';
  position: absolute;
  left: -2rem;
  top: 1.35rem;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #484f58;
  border: 2px solid #0d1117;
  transform: translateX(-50%);
  margin-left: -1px;
}
.oc-event.highlight::before {
  background: #e94560;
  box-shadow: 0 0 12px rgba(233,69,96,0.5);
}
.oc-event-date {
  font-size: 0.8rem;
  font-weight: 700;
  color: #e94560;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.3rem;
}
.oc-event-text {
  font-size: 0.95rem;
  color: #c9d1d9;
  line-height: 1.6;
  text-align: left;
}
.oc-event.highlight .oc-event-text { color: #fff; font-weight: 600; }

.oc-pillars {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-top: 2rem;
}
.oc-pillar-icon {
  font-size: 2.2rem;
  margin-bottom: 1rem;
  display: block;
}
.oc-pillar h3 {
  font-size: 1.15rem;
  font-weight: 800;
  color: #fff;
  margin: 0 0 0.75rem;
}
.oc-pillar p {
  font-size: 0.9rem;
  color: #8b949e;
  line-height: 1.6;
  margin: 0;
}

/* ═══════════════════════════════════════════════════
   BENTO GRID — QUÉ INCLUYE
   ═══════════════════════════════════════════════════ */
.section-includes {
  background: #0d1117;
  position: relative;
}
.section-includes::before {
  content: '';
  position: absolute;
  top: 20%;
  left: 50%;
  transform: translateX(-50%);
  width: 1000px;
  height: 600px;
  background: radial-gradient(ellipse at center, rgba(233,69,96,0.05) 0%, transparent 60%);
  pointer-events: none;
}

.bento-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  margin-top: 3rem;
}
.bento-card {
  background: rgba(22, 27, 34, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  padding: 2rem;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), border-color 0.4s, box-shadow 0.5s;
}
.bento-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.14);
  box-shadow:
    0 0 0 1px rgba(233,69,96,0.08),
    0 20px 60px rgba(0,0,0,0.3),
    0 0 80px rgba(233,69,96,0.04),
    inset 0 1px 0 rgba(255,255,255,0.05);
}
.bento-glow {
  position: absolute;
  inset: 0;
  pointer-events: none;
  border-radius: 24px;
  transition: background 0.3s;
}
.bento-icon {
  font-size: 2.5rem;
  display: block;
  margin-bottom: 1rem;
}
.bento-card h3 {
  font-size: 1.15rem;
  font-weight: 800;
  color: #f0f6fc;
  margin-bottom: 0.75rem;
  line-height: 1.3;
}
.bento-card p {
  font-size: 0.9rem;
  color: #8b949e;
  line-height: 1.65;
  margin: 0;
}
.bento-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1.25rem;
}
.bento-tag {
  font-size: 0.7rem;
  font-weight: 700;
  padding: 0.3rem 0.7rem;
  border-radius: 8px;
  background: rgba(233,69,96,0.08);
  border: 1px solid rgba(233,69,96,0.15);
  color: #e94560;
}

/* ═══════════════════════════════════════════════════
   TIMELINE
   ═══════════════════════════════════════════════════ */
.timeline-section {
  background: linear-gradient(180deg, #0d1117 0%, #161b22 50%, #0d1117 100%);
}
.timeline-wrapper {
  max-width: 700px;
  margin: 3rem auto 0;
  position: relative;
  padding-left: 3rem;
}
.timeline-track {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: rgba(255,255,255,0.04);
  border-radius: 3px;
}
.timeline-progress {
  position: absolute;
  left: 0; top: 0;
  width: 3px;
  height: 0%;
  background: linear-gradient(to bottom, #e94560, #8b5cf6, #ff6b6b);
  transition: height 0.1s ease-out;
  box-shadow: 0 0 16px rgba(233, 69, 96, 0.5), 0 0 40px rgba(139,92,246,0.2);
  border-radius: 3px;
}
.timeline-item {
  position: relative;
  padding: 0 0 3rem 2.5rem;
  opacity: 0;
  transform: translateX(-20px);
  transition: opacity 0.6s ease-out, transform 0.6s cubic-bezier(0.16,1,0.3,1);
}
.timeline-item.timeline-active {
  opacity: 1;
  transform: translateX(0);
}
.timeline-dot {
  position: absolute;
  left: -3rem;
  top: 0.25rem;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #161b22;
  border: 3px solid rgba(255,255,255,0.1);
  transform: translateX(-50%) translateX(1px);
  transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
  z-index: 1;
  box-shadow: 0 0 0 4px rgba(13,17,23,0.8);
}
.timeline-item.timeline-active .timeline-dot {
  background: #e94560;
  border-color: #e94560;
  box-shadow: 0 0 0 4px rgba(233,69,96,0.2), 0 0 20px rgba(233,69,96,0.5);
  animation: dotRingPulse 2s ease-in-out infinite;
}
@keyframes dotRingPulse {
  0%, 100% { box-shadow: 0 0 0 4px rgba(233,69,96,0.2), 0 0 20px rgba(233,69,96,0.5); }
  50% { box-shadow: 0 0 0 8px rgba(233,69,96,0.08), 0 0 30px rgba(233,69,96,0.6); }
}
.timeline-time {
  font-size: 0.75rem;
  font-weight: 700;
  color: #e94560;
  letter-spacing: 0.05em;
  margin-bottom: 0.4rem;
}
.timeline-event-title {
  font-size: 1.05rem;
  font-weight: 800;
  color: #f0f6fc;
  margin-bottom: 0.5rem;
  line-height: 1.5;
}
