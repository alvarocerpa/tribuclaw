/* Logo bar */
.logo-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3rem;
  padding: 2.5rem 0 1rem;
  border-top: 1px solid rgba(255,255,255,0.04);
  flex-wrap: wrap;
}
.logo-bar-item {
