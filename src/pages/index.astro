---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_URL, WHOP_URL } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`${SITE_TITLE} — Aprende a montar tu equipo de agentes IA`}
    description="TribuClaw: la comunidad #1 de OpenClaw en español. Formación completa, casos de uso reales, soporte 24/7 y directos semanales para que la IA trabaje por ti."
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "TribuClaw — Membresía",
    "description": "Comunidad en español con curso completo de OpenClaw, casos de uso reales, soporte 24/7, directos semanales y TribuClaw App.",
    "url": SITE_URL,
    "brand": { "@type": "Brand", "name": "TribuClaw" },
    "offers": {
      "@type": "Offer",
      "url": WHOP_URL,
      "price": "40",
      "priceCurrency": "EUR",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "ratingCount": "98"
    },
    "author": { "@type": "Person", "name": "Alvaro Cerpa", "url": SITE_URL }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es OpenClaw?", "acceptedAnswer": { "@type": "Answer", "text": "Sistema de agentes IA autónomos open source. 247K stars en GitHub. No es un chatbot: es un sistema de agentes que vive en tu servidor, ejecuta tareas, gestiona emails, navega la web y trabaja 24/7 por ti." } },
      { "@type": "Question", "name": "¿Necesito experiencia técnica?", "acceptedAnswer": { "@type": "Answer", "text": "No. El curso te guía paso a paso, en español. Sin experiencia técnica necesaria." } },
      { "@type": "Question", "name": "¿Qué incluye la membresía?", "acceptedAnswer": { "@type": "Answer", "text": "Curso completo, casos de uso semanales, TribuBot 24/7, directos semanales, TribuClaw App y comunidad activa." } },
      { "@type": "Question", "name": "¿Puedo tener más de un agente?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Te enseñamos a configurarlos y gestionarlos." } },
      { "@type": "Question", "name": "¿Mis datos están seguros?", "acceptedAnswer": { "@type": "Answer", "text": "100%. Tu servidor, tus datos. Nada pasa por terceros." } },
      { "@type": "Question", "name": "¿Qué pasa si cancelo?", "acceptedAnswer": { "@type": "Answer", "text": "Tu agente sigue funcionando. Pierdes acceso a comunidad y updates." } },
      { "@type": "Question", "name": "¿Puedo ganar dinero con esto?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Compartimos casos reales de monetización." } }
    ]
  })} />
</head>
<body>

<Header />

<main id="main-content">

<!-- ═══════ HERO ═══════ -->
<section class="hero" id="hero">
  <div class="hero-inner container-hero">
    <div class="hero-content">
      <div class="hero-badge" data-animate="fade-up">
        <span>✦ La comunidad #1 de OpenClaw en español</span>
      </div>
      <h1 class="hero-headline" data-animate="split-text">
        Aprende a montar tu equipo de agentes IA
      </h1>
      <p class="hero-sub" data-animate="fade-up">
        Formación completa, casos de uso reales, soporte 24/7 y todas las herramientas para que la IA trabaje por ti.
      </p>
      <div class="hero-cta" data-animate="fade-up">
        <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
          <span>Unirme a TribuClaw</span>
        </a>
        <p class="hero-cta-hint">Desde 40€/mes · Cancela cuando quieras</p>
      </div>
    </div>
    <div class="hero-visual" data-animate="fade-up">
      <p class="hero-visual-text">
        Tu agente puede gestionar emails, navegar la web, organizar tu calendario y ejecutar tareas. Todo solo.
      </p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ INCLUDES ═══════ -->
<section class="section section-includes" id="incluye">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">📦 Todo lo que incluye</span>
      <h2 class="section-title">Una membresía. Todo incluido.</h2>
      <p class="section-sub">Formación, herramientas, soporte y comunidad. Todo lo que necesitas para que la IA trabaje por ti.</p>
    </div>
    <div class="includes-grid" data-animate="stagger">
      <div class="glass-card include-card include-lg">
        <h3>Curso completo</h3>
        <p>De cero a tu primer agente funcionando. Sin experiencia técnica necesaria. Vídeos en español, paso a paso.</p>
      </div>
      <div class="glass-card include-card">
        <h3>Casos de uso semanales</h3>
        <p>Ejemplos reales para tu negocio cada semana.</p>
      </div>
      <div class="glass-card include-card">
        <h3>Soporte 24/7</h3>
        <p>TribuBot responde al instante. Y si no puede, Álvaro está detrás.</p>
      </div>
      <div class="glass-card include-card">
        <h3>Directos semanales</h3>
        <p>Cada miércoles a las 19:00. Preguntas en vivo con Álvaro.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ SOCIAL PROOF (estático) ═══════ -->
<section class="section section-proof" id="proof">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">⭐ 4.9/5 en Whop</span>
      <h2 class="section-title">Lo que dicen los miembros</h2>
      <p class="section-sub">98 miembros. Agentes activos. Tareas ejecutándose mientras lees esto.</p>
    </div>
    <div class="proof-stats" data-animate="stagger">
      <div class="proof-stat">
        <span class="proof-stat-value">98+</span>
        <span class="proof-stat-label">Miembros activos</span>
      </div>
      <div class="proof-stat">
        <span class="proof-stat-value">247K</span>
        <span class="proof-stat-label">GitHub stars</span>
      </div>
      <div class="proof-stat">
        <span class="proof-stat-value">4.9</span>
        <span class="proof-stat-label">Valoración media</span>
      </div>
    </div>
    <div class="reviews-static" data-animate="stagger">
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"Espectacular. Solo puedo decir esto. Gracias por el servicio que estáis dando en TribuClaw."</p>
        <div class="review-author">
          <div class="review-avatar">AB</div>
          <div>
            <span class="review-name">Alberto Batlle</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"En menos de una semana ya tenía mi primer agente funcionando. Increíble."</p>
        <div class="review-author">
          <div class="review-avatar">AR</div>
          <div>
            <span class="review-name">Alvaro R.</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
      <div class="glass-card review-card">
        <div class="review-stars">★★★★★</div>
        <p class="review-quote">"El soporte es de otra galaxia. Responden a cualquier hora."</p>
        <div class="review-author">
          <div class="review-avatar">M</div>
          <div>
            <span class="review-name">Maria</span>
            <span class="review-role">Miembro de TribuClaw</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ PRICING ═══════ -->
<section class="section section-pricing" id="precio">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">💰 Precio transparente</span>
      <h2 class="section-title">¿Cuánto cuesta montar tu equipo de IA?</h2>
      <p class="section-sub">Menos de lo que te gastas en café al mes.</p>
    </div>
    <div class="pricing-card glass-card" data-animate="fade-up">
      <div class="pricing-badge">Plan completo</div>
      <div class="pricing-main">
        <div class="pricing-items">
          <div class="pricing-item">
            <span class="pricing-item-label">TribuClaw</span>
            <span class="pricing-item-value">35€/mes</span>
          </div>
          <div class="pricing-item">
            <span class="pricing-item-label">VPS (Hetzner)</span>
            <span class="pricing-item-value">desde 5€/mes</span>
          </div>
        </div>
        <div class="pricing-total">
          <span class="pricing-total-label">Total</span>
          <span class="pricing-total-value">desde 40€/mes</span>
        </div>
      </div>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener" style="width:100%;text-align:center;">
        <span>Unirme a TribuClaw</span>
      </a>
      <p class="pricing-note">98 miembros · 4.9/5 en Whop · Sin permanencia</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ CTA FINAL ═══════ -->
<section class="section section-cta-final">
  <div class="container">
    <div class="cta-final-inner" data-animate="fade-up">
      <h2 class="cta-final-title"><span class="gradient-text">En 6 meses, tener un agente va a ser lo normal.</span></h2>
      <p class="cta-final-sub">Puedes entrar ahora o cuando todo el mundo lo esté haciendo.</p>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
        <span>Unirme a TribuClaw</span>
      </a>
      <p class="cta-final-hint">Desde 40€/mes · Cancela cuando quieras</p>
    </div>
  </div>
</section>

</main>

<Footer />

<script>
// ═══════ GSAP ANIMATIONS ═══════
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// ─── Hero animations on load ───
const heroBadge = document.querySelector('.hero-badge');
const heroHeadline = document.querySelector('.hero-headline');
const heroSub = document.querySelector('.hero-sub');
const heroCta = document.querySelector('.hero-cta');
const heroVisual = document.querySelector('.hero-visual');

const heroTl = gsap.timeline({ delay: 0.3 });
heroTl
  .from(heroBadge, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' })
  .from(heroHeadline, { opacity: 0, y: 30, duration: 0.7, ease: 'power2.out' }, '-=0.3')
  .from(heroSub, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3')
  .from(heroCta, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3')
  .from(heroVisual, { opacity: 0, y: 30, duration: 0.6, ease: 'power2.out' }, '-=0.3');

// ─── Section headers: fade up ───
gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach(el => {
  if (el.closest('.hero')) return;
  gsap.from(el, {
    scrollTrigger: {
      trigger: el,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.7,
    ease: 'power2.out',
  });
});

// ─── Stagger animations ───
gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach(container => {
  if (container.closest('.hero')) return;
  const children = container.children;
  gsap.from(children, {
    scrollTrigger: {
      trigger: container,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.6,
    stagger: 0.1,
    ease: 'power2.out',
  });
});
</script>

<style>
/* ═══════ HERO ═══════ */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 6rem 0 4rem;
  overflow: hidden;
}

.hero-inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
  width: 100%;
}

.hero-content {
  text-align: center;
}

.hero-badge {
  margin-bottom: 1.5rem;
}
.hero-badge span {
  display: inline-block;
  background: rgba(233,69,96,0.08);
  border: 1px solid rgba(233,69,96,0.2);
  color: var(--accent);
  padding: 0.4rem 1rem;
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 600;
}

.hero-headline {
  font-size: clamp(2.2rem, 6vw, 3.8rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.08;
  margin-bottom: 1.25rem;
}

.hero-sub {
  color: var(--text-muted);
  font-size: 1.1rem;
  line-height: 1.7;
  margin-bottom: 2rem;
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
}

.hero-cta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
}

.hero-cta-hint {
  color: rgba(250,250,250,0.35);
  font-size: 0.8rem;
}

.hero-visual {
  max-width: 560px;
  margin: 0 auto;
  width: 100%;
  padding: 2rem;
  background: rgba(255,255,255,0.02);
  border: 1px solid var(--border);
  border-radius: 12px;
  text-align: center;
}

.hero-visual-text {
  color: var(--text-muted);
  font-size: 1rem;
  line-height: 1.7;
  margin: 0;
}

/* ═══════ SECTIONS ═══════ */
.section {
  padding: 5rem 0;
  position: relative;
  overflow: hidden;
}

/* ═══════ INCLUDES SECTION ═══════ */
.section-includes {
  background: var(--bg);
}

.includes-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  position: relative;
  z-index: 1;
}

.include-card {
  padding: 1.75rem;
}
.include-card h3 {
  font-size: 1.1rem;
  font-weight: 800;
  margin-bottom: 0.5rem;
}
.include-card p {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0;
}

/* ═══════ SOCIAL PROOF (estático) ═══════ */
.section-proof {
  background: var(--bg-alt);
}

.proof-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  max-width: 600px;
  margin: 0 auto 3rem;
  text-align: center;
}
.proof-stat-value {
  font-size: clamp(2rem, 5vw, 2.8rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1;
  display: block;
}
.proof-stat-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-top: 0.35rem;
  display: block;
}

.reviews-static {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
  max-width: 900px;
  margin: 0 auto;
}

.review-card {
  padding: 1.75rem;
  text-align: center;
}
.review-stars {
  color: var(--accent);
  font-size: 1rem;
  margin-bottom: 0.75rem;
}
.review-quote {
  font-size: 1rem;
  color: rgba(250,250,250,0.8);
  font-style: italic;
  line-height: 1.6;
  margin-bottom: 1rem;
}
.review-author {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
}
.review-avatar {
  width: 32px;
  height: 32px;
  background: var(--gradient);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.review-name {
  display: block;
  font-size: 0.85rem;
  font-weight: 700;
}
.review-role {
  display: block;
  font-size: 0.7rem;
  color: var(--text-muted);
}

/* ═══════ PRICING ═══════ */
.section-pricing {
  background: var(--bg);
}

.pricing-card {
  max-width: 480px;
  margin: 0 auto;
  padding: 2rem;
  text-align: center;
  position: relative;
  z-index: 1;
  border: 1px solid rgba(233,69,96,0.15);
}

.pricing-badge {
  display: inline-block;
  padding: 0.25rem 0.8rem;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  background: rgba(233,69,96,0.1);
  color: var(--accent);
  border: 1px solid rgba(233,69,96,0.2);
  margin-bottom: 1.5rem;
}

.pricing-items {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}
.pricing-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  font-size: 0.9rem;
}
.pricing-item-label {
  color: rgba(250,250,250,0.7);
}
.pricing-item-value {
  font-weight: 700;
  color: #fafafa;
}

.pricing-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem;
  background: rgba(233,69,96,0.06);
  border-radius: 10px;
  margin-bottom: 1.5rem;
}
.pricing-total-label {
  font-weight: 700;
  font-size: 1rem;
}
.pricing-total-value {
  font-size: 1.4rem;
  font-weight: 900;
  color: var(--accent);
}

.pricing-note {
  color: rgba(250,250,250,0.3);
  font-size: 0.8rem;
  margin-top: 1rem;
}

/* ═══════ CTA FINAL ═══════ */
.section-cta-final {
  background: var(--bg-alt);
  padding: 6rem 0;
}

.cta-final-inner {
  text-align: center;
  position: relative;
  z-index: 1;
}
.cta-final-title {
  font-size: clamp(1.8rem, 5vw, 2.8rem);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.1;
  margin-bottom: 1rem;
}
.cta-final-sub {
  color: var(--text-muted);
  font-size: 1.05rem;
  margin-bottom: 2rem;
}
.cta-final-hint {
  color: rgba(250,250,250,0.3);
  font-size: 0.85rem;
  margin-top: 1.5rem;
}

/* ═══════ RESPONSIVE ═══════ */
@media (min-width: 640px) {
  .includes-grid { grid-template-columns: repeat(2, 1fr); }
  .reviews-static { grid-template-columns: repeat(3, 1fr); }
  .section { padding: 6rem 0; }
}

@media (min-width: 1024px) {
  .hero-inner {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    text-align: left;
  }
  .hero-content { text-align: left; }
  .hero-sub { margin-left: 0; margin-right: 0; }
  .hero-cta { align-items: flex-start; }
  .hero-visual { margin: 0; max-width: none; }
  .section { padding: 7rem 0; }
}

@media (max-width: 639px) {
  .hero { padding: 5rem 0 3rem; min-height: auto; }
  .hero-badge span { font-size: 0.7rem; padding: 0.3rem 0.7rem; }
  .hero-sub { font-size: 0.95rem; }
  .section { padding: 4rem 0; }
  .proof-stats { gap: 1rem; }
  .reviews-static { gap: 1rem; }
  .review-card { padding: 1.25rem; }
  .pricing-card { padding: 1.5rem; }
  .cta-final-title { font-size: 1.5rem; }
}
</style>

</body>
</html>
