  padding: 2rem 2.5rem;
  text-align: center;
}
.review-quote {
  font-size: 1.1rem;
  color: #c9d1d9;
  font-style: italic;
  line-height: 1.7;
}
.review-quote-mark {
  font-size: 3rem;
  color: #00d4ff;
  line-height: 0;
  vertical-align: -0.4em;
  margin-right: 0.1rem;
  font-style: normal;
}
.review-author-featured {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
