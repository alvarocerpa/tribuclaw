    .cta-final-note {
      font-size: 0.8125rem;
      color: var(--color-text-tertiary);
    }

    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: 0.75rem;
    }
    .trust-badge {
      font-size: 0.75rem;
      color: var(--color-text-tertiary);
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--color-border);
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
    }

    /* ===== AUDIENCIA ===== */
    .audiencia-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .audiencia-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1.75rem;
      transition: border-color 0.3s, transform 0.3s;
    }
    .audiencia-card:hover {
      border-color: var(--color-border-accent);
      transform: translateY(-2px);
    }
    .audiencia-icon {
      font-size: 1.75rem;
      margin-bottom: 0.75rem;
    }
    .audiencia-title {
      font-family: var(--font-display);
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: 0.5rem;
    }
    .audiencia-desc {
      font-size: 0.9375rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
    }
    .cta-intermedio {
      text-align: center;
      padding-top: 1rem;
    }

    /* ===== RESPONSIVE ===== */
    @media (min-width: 640px) {
      .audiencia-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .proof-counters {
        grid-template-columns: repeat(4, 1fr);
      }

      .testimonials-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .pricing-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .faq-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 768px) {
      .hero-grid {
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
      }

      .value-steps {
        flex-direction: row;
        align-items: flex-start;
        gap: 0;
      }

      .value-connector {
        padding-top: 3rem;
      }

      .value-connector-line {
        width: 60px;
        height: 2px;
      }

      .bento-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .bento-hero {
        grid-column: span 2;
      }
    }
  </style>

  <!-- ==================== SCRIPTS ==================== -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // ===== Scroll Progress Bar =====
    const progressBar = document.getElementById('scroll-progress');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        const height = document.documentElement.scrollHeight - window.innerHeight;
        progressBar.style.width = `${(scrolled / height) * 100}%`;
      }, { passive: true });
    }

    // ===== Hero entrance =====
    const heroTl = gsap.timeline({ defaults: { ease: 'power2.out' } });
    heroTl
      .from('[data-animate="badge"]', { opacity: 0, y: -10, duration: 0.5 })
      .from('.hero-headline', { opacity: 0, y: 20, duration: 0.7 }, '-=0.2')
      .from('[data-animate="fade-up"]', { opacity: 0, y: 15, duration: 0.5, stagger: 0.15 }, '-=0.3')
      .from('[data-animate="cta"]', { opacity: 0, scale: 0.95, duration: 0.4 }, '-=0.2')
      .from('[data-animate="terminal"]', { opacity: 0, x: 30, duration: 0.6 }, '-=0.3');

    // ===== Scroll reveals =====
    gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach(el => {
      if (el.closest('.hero')) return;
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        opacity: 0, y: 30, duration: 0.7, ease: 'power2.out',
      });
    });

    gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach(container => {
      gsap.from(container.children, {
        scrollTrigger: { trigger: container, start: 'top 85%', once: true },
        opacity: 0, y: 25, duration: 0.6, stagger: 0.1, ease: 'power2.out',
      });
    });

    // ===== Counter animation =====
    gsap.utils.toArray<HTMLElement>('.proof-counter-value').forEach(el => {
      const target = parseFloat(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      const isDecimal = target % 1 !== 0;
      ScrollTrigger.create({
        trigger: el,
        start: 'top 85%',
        once: true,
        onEnter: () => {
          const obj = { val: 0 };
          gsap.to(obj, {
            val: target,
            duration: 2,
            ease: 'power2.out',
            snap: isDecimal ? { val: 0.1 } : { val: 1 },
            onUpdate: () => {
              el.textContent = (isDecimal ? obj.val.toFixed(1) : Math.round(obj.val)) + suffix;
            }
          });
        }
      });
    });

    // ===== Terminal typing effect =====
    const termCmd = document.getElementById('term-cmd');
    const termCursor = document.getElementById('term-cursor');
    const termBody = document.getElementById('terminal-body');

    const termLines = [
      { cmd: 'openclaw install kimo', outputs: ['Instalando agente "kimo"...', 'Configurando memoria...', '<span class="success">✓ Agente instalado en 8 minutos</span>'] },
      { cmd: 'openclaw skill add email-reader', outputs: ['Conectando Gmail...', 'Sincronizando bandeja...', '<span class="success">✓ 47 emails procesados</span>'] },
      { cmd: 'openclaw deploy --agent kimo', outputs: ['Compilando skills...', 'Desplegando en VPS...', '<span class="info">→ Kimo está LIVE. Trabajando 24/7.</span>'] },
    ];

    async function typeText(el: HTMLElement, text: string, speed = 40): Promise<void> {
      for (let i = 0; i < text.length; i++) {
        el.textContent += text[i];
        await new Promise(r => setTimeout(r, speed));
      }
    }

    async function runTerminal(): Promise<void> {
      if (!termCmd || !termCursor || !termBody) return;

      for (const line of termLines) {
        // Clear previous
        termBody.innerHTML = '';
        const lineEl = document.createElement('div');
        lineEl.className = 'terminal-line';
        lineEl.innerHTML = `<span class="terminal-prompt">$</span><span class="terminal-cmd" id="term-cmd"></span><span class="terminal-cursor" id="term-cursor">▋</span>`;
        termBody.appendChild(lineEl);

        const cmdEl = lineEl.querySelector('#term-cmd') as HTMLElement;
        const curEl = lineEl.querySelector('#term-cursor') as HTMLElement;

        await typeText(cmdEl, line.cmd, 45);
        await new Promise(r => setTimeout(r, 300));
        curEl.style.display = 'none';

        for (const output of line.outputs) {
          await new Promise(r => setTimeout(r, 400));
          const outEl = document.createElement('div');
          outEl.className = 'terminal-output';
          outEl.innerHTML = output;
          termBody.appendChild(outEl);
        }

        await new Promise(r => setTimeout(r, 2000));
      }

      // Loop
      await new Promise(r => setTimeout(r, 1500));
      runTerminal();
    }

    // Start terminal after hero animation
    setTimeout(runTerminal, 1200);

    // ===== FAQ Accordion =====
    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const answer = btn.nextElementSibling as HTMLElement;

        // Close all
        document.querySelectorAll('.faq-question').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
          const a = b.nextElementSibling as HTMLElement;
          if (a) a.style.maxHeight = '0';
        });

        if (!expanded) {
          btn.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });

    // ===== Magnetic Buttons (desktop only) =====
    if (window.matchMedia('(min-width: 768px)').matches) {
      document.querySelectorAll<HTMLElement>('.magnetic-btn').forEach(btn => {
        btn.addEventListener('mousemove', (e: Event) => {
          const ev = e as MouseEvent;
          const rect = btn.getBoundingClientRect();
          const x = ev.clientX - rect.left - rect.width / 2;
          const y = ev.clientY - rect.top - rect.height / 2;
          btn.style.transform = `translate(${x * 0.15}px, ${y * 0.15}px)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = '';
        });
      });
    }
  </script>

</BaseLayout>
