<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import Lenis from '@studio-freight/lenis';
gsap.registerPlugin(ScrollTrigger);

// Lenis: only init if BaseLayout hasn't already
if (!(window as any).__lenisInit) {
  (window as any).__lenisInit = true;
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  });
  lenis.on('scroll', ScrollTrigger.update);
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);
  (window as any).__lenis = lenis;
}

// Hero headline text reveal
const headline = document.querySelector('.hero-headline');
if (headline) {
  const walk = document.createTreeWalker(headline, NodeFilter.SHOW_TEXT, null);
  const textNodes: Text[] = [];
  let n: Node | null;
  while ((n = walk.nextNode())) textNodes.push(n as Text);
  for (const tn of textNodes) {
    const frag = document.createDocumentFragment();
    for (const char of tn.textContent || '') {
      if (char === ' ') {
        frag.appendChild(document.createTextNode(' '));
      } else {
        const span = document.createElement('span');
        span.className = 'char';
        span.textContent = char;
        frag.appendChild(span);
      }
    }
    tn.parentNode!.replaceChild(frag, tn);
  }
  gsap.from('.hero-headline .char', {
    opacity: 0.05,
    y: 20,
    duration: 0.4,
    stagger: 0.015,
    ease: 'power3.out',
    delay: 0.3
  });
}


// Home-specific animations
gsap.from('[data-animate="cta"]', { opacity: 0, scale: 0.95, duration: 0.6, delay: 0.8, ease: 'power2.out' });
gsap.from('[data-animate="console"]', { opacity: 0, x: 50, duration: 1, delay: 0.3, ease: 'power2.out' });

// Counter animation
function animateCounter(el: HTMLElement, target: number, suffix: string) {
  const start = performance.now();
  const duration = 2000;
  const isDecimal = String(target).includes('.');
  function update(timestamp: number) {
    const progress = Math.min((timestamp - start) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    if (isDecimal) el.textContent = (eased * target).toFixed(1) + suffix;
    else if (target >= 1000) el.textContent = Math.floor(eased * target / 1000) + 'K+';
    else el.textContent = Math.floor(eased * target) + suffix;
    if (progress < 1) requestAnimationFrame(update);
    else {
      if (target >= 1000) el.textContent = Math.floor(target / 1000) + 'K+';
      else if (isDecimal) el.textContent = target.toFixed(1) + suffix;
      else el.textContent = target + suffix;
    }
  }
  requestAnimationFrame(update);
}
const counterObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target as HTMLElement;
      const target = parseFloat(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      animateCounter(el, target, suffix);
      counterObserver.unobserve(el);
    }
  });
}, { threshold: 0.5 });
document.querySelectorAll('.proof-counter-value').forEach(el => counterObserver.observe(el));

// Console typing effect — continuous streaming terminal with cleanup
(function initConsole() {
  const body = document.getElementById('console-body');
  if (!body) return;
  let stopped = false;
  let totalLines = 0;
  const MAX_LINES = 8;
  const MAX_TOTAL = 100;
  const activeTimers: ReturnType<typeof setTimeout>[] = [];
  const agentTasks = [
    { agent: '🦞 Kimo', tasks: ['Analizando métricas de la semana...', 'Coordinando 5 agentes activos...', 'Revisando cola de tareas pendientes...', 'Enviando resumen diario por Telegram...', 'Priorizando tareas del sprint...'] },
    { agent: '📊 Data', tasks: ['Revenue +23% vs semana anterior', 'Generando reporte mensual de conversión...', 'Analizando funnel de Onboarding...', 'Detectando patrón: mejores posts → 2pm-4pm', 'Actualizando dashboard de métricas...'] },
    { agent: '🎨 Mika', tasks: ['Generando thumbnail para el blog...', 'Diseñando banner para Whop...', 'Creando variante A/B del CTA...', 'Optimizando assets para móvil...'] },
    { agent: '✍️ Pluma', tasks: ['Redactando post de LinkedIn...', 'Editando draft del artículo semanal...', 'Generando 5 hooks para Twitter...', 'Revisando copy de la landing...'] },
    { agent: '🤖 Mao', tasks: ['Desplegando nueva feature en producción', 'Refactorizando módulo de autenticación...', 'Fix: bug en integración con Whop API...', 'Ejecutando tests → 47/47 passing ✓'] },
    { agent: '⚡ Sistema', tasks: ['5 agentes activos · 847 tareas completadas hoy', 'Uptime: 99.97% · Latencia: 42ms', 'Backup completado · 2.3GB comprimidos', 'SSL renovado · expira en 89 días'] },
  ];
  const statusSymbols = ['✓', '✓', '✓', '✓', '⟳'];
  function getTimestamp() {
    const now = new Date();
    return now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  let taskIdx = 0;
  function getNextTask() {
    const agent = agentTasks[taskIdx % agentTasks.length];
    const task = agent.tasks[Math.floor(Math.random() * agent.tasks.length)];
    taskIdx++;
    return { agent: agent.agent, task };
  }
  function typeLine(text: string, el: HTMLElement, callback: () => void) {
    let i = 0;
    const speed = 18 + Math.random() * 12;
    function typeChar() {
      if (stopped || !body.isConnected) return;
      if (i < text.length) {
        el.textContent = text.substring(0, i + 1);
        i++;
        const t = setTimeout(typeChar, speed);
        activeTimers.push(t);
      } else {
        callback();
      }
    }
    typeChar();
  }
  function addLine() {
    if (stopped || !body.isConnected) return;
    if (totalLines >= MAX_TOTAL) {
      body.innerHTML = '';
      totalLines = 0;
    }
    totalLines++;
    const { agent, task } = getNextTask();
    const line = document.createElement('div');
    line.className = 'console-line';
    const ts = document.createElement('span');
    ts.className = 'console-ts';
    ts.textContent = getTimestamp();
    const content = document.createElement('span');
    content.className = 'console-content';
    line.appendChild(ts);
    line.appendChild(content);
    body.appendChild(line);
    // Remove old lines to keep max
    while (body.children.length > MAX_LINES) {
      const first = body.firstChild as HTMLElement;
      first.style.opacity = '0';
      first.style.transform = 'translateY(-8px)';
      first.style.transition = 'opacity 0.3s, transform 0.3s';
      setTimeout(() => { if (first.parentNode) first.remove(); }, 300);
    }
    body.scrollTop = body.scrollHeight;
    const fullText = `${agent} > ${task}`;
    typeLine(fullText, content, () => {
      if (stopped || !body.isConnected) return;
      // Add status symbol after typing
      const status = document.createElement('span');
      status.className = 'console-status';
      status.textContent = ' ' + statusSymbols[Math.floor(Math.random() * statusSymbols.length)];
      content.appendChild(status);
      const t = setTimeout(addLine, 1200 + Math.random() * 1500);
      activeTimers.push(t);
    });
  }
  // Start after hero animation
  const startTimer = setTimeout(addLine, 800);
  activeTimers.push(startTimer);
})();

// Hero Particles with IntersectionObserver cleanup
(function initParticles() {
  const canvas = document.getElementById('hero-particles') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;
  let rafId = 0;
  let isVisible = true;
  function resize() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const COUNT = window.innerWidth < 768 ? 25 : 50;
  const COLORS = ['#e94560', '#ff6b6b', '#ffffff'];
  const particles: {x:number;y:number;size:number;speedX:number;speedY:number;opacity:number;color:string;pulse:number}[] = [];
  for (let i = 0; i < COUNT; i++) {
    particles.push({
      x: Math.random() * canvas.width, y: Math.random() * canvas.height,
      size: Math.random() * 1.5 + 0.5, speedX: (Math.random() - 0.5) * 0.3, speedY: (Math.random() - 0.5) * 0.3,
      opacity: Math.random() * 0.4 + 0.1, color: COLORS[Math.floor(Math.random() * COLORS.length)], pulse: Math.random() * Math.PI * 2
    });
  }
  function draw() {
    if (!canvas.isConnected) { cancelAnimationFrame(rafId); return; }
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (const p of particles) {
      p.x += p.speedX; p.y += p.speedY; p.pulse += 0.02;
      if (p.x < 0) p.x = canvas.width; if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height; if (p.y > canvas.height) p.y = 0;
      ctx.save();
      ctx.globalAlpha = 0.1 + Math.sin(p.pulse) * 0.2 + 0.2;
      ctx.fillStyle = p.color; ctx.shadowBlur = 6; ctx.shadowColor = p.color;
      ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
    }
    rafId = requestAnimationFrame(draw);
  }
  rafId = requestAnimationFrame(draw);
  // Pause/resume when canvas enters/leaves viewport
  const obs = new IntersectionObserver(([entry]) => {
    isVisible = entry.isIntersecting;
    if (isVisible && canvas.isConnected) { rafId = requestAnimationFrame(draw); }
    else { cancelAnimationFrame(rafId); }
  }, { threshold: 0 });
  obs.observe(canvas);
})();
</script>

