---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Console from '../components/Console.astro';
import { SITE_TITLE, SITE_URL, WHOP_URL } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`${SITE_TITLE} — Aprende a montar tu equipo de agentes IA`}
    description="TribuClaw: la comunidad #1 de OpenClaw en español. Formación completa, casos de uso reales, soporte 24/7 y directos semanales para que la IA trabaje por ti."
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "TribuClaw — Membresía",
    "description": "Comunidad en español con curso completo de OpenClaw, casos de uso reales, soporte 24/7, directos semanales y TribuClaw App.",
    "url": SITE_URL,
    "brand": { "@type": "Brand", "name": "TribuClaw" },
    "offers": {
      "@type": "Offer",
      "url": WHOP_URL,
      "price": "40",
      "priceCurrency": "EUR",
      "priceValidUntil": "2027-12-31",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "ratingCount": "98"
    },
    "author": { "@type": "Person", "name": "Alvaro Cerpa", "url": SITE_URL }
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "¿Qué es OpenClaw?", "acceptedAnswer": { "@type": "Answer", "text": "Sistema de agentes IA autónomos open source. 247K stars en GitHub. No es un chatbot: es un sistema de agentes que vive en tu servidor, ejecuta tareas, gestiona emails, navega la web y trabaja 24/7 por ti." } },
      { "@type": "Question", "name": "¿Necesito experiencia técnica?", "acceptedAnswer": { "@type": "Answer", "text": "No. El curso te guía paso a paso, en español. Sin experiencia técnica necesaria." } },
      { "@type": "Question", "name": "¿Qué incluye la membresía?", "acceptedAnswer": { "@type": "Answer", "text": "Curso completo, casos de uso semanales, TribuBot 24/7, directos semanales, TribuClaw App y comunidad activa." } },
      { "@type": "Question", "name": "¿Puedo tener más de un agente?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Te enseñamos a configurarlos y gestionarlos." } },
      { "@type": "Question", "name": "¿Mis datos están seguros?", "acceptedAnswer": { "@type": "Answer", "text": "100%. Tu servidor, tus datos. Nada pasa por terceros." } },
      { "@type": "Question", "name": "¿Qué pasa si cancelo?", "acceptedAnswer": { "@type": "Answer", "text": "Tu agente sigue funcionando. Pierdes acceso a comunidad y updates." } },
      { "@type": "Question", "name": "¿Puedo ganar dinero con esto?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Compartimos casos reales de monetización." } }
    ]
  })} />
</head>
<body class="dot-bg">

<Header />

<main id="main-content">

<!-- ═══════ HERO ═══════ -->
<section class="hero" id="hero">
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>
  <canvas id="hero-particles" aria-hidden="true"></canvas>
  <div class="hero-inner container-hero">
    <div class="hero-content">
      <div class="hero-badge" data-animate="fade-up">
        <span>✦ La comunidad #1 de OpenClaw en español</span>
      </div>
      <h1 class="hero-headline" data-animate="split-text">
        Aprende a montar tu equipo de agentes IA
      </h1>
      <p class="hero-sub" data-animate="fade-up">
        Formación completa, casos de uso reales, soporte 24/7 y todas las herramientas para que la IA trabaje por ti.
      </p>
      <div class="hero-cta" data-animate="fade-up">
        <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
          <span>Unirme a TribuClaw</span>
        </a>
        <p class="hero-cta-hint">Desde 40€/mes · Cancela cuando quieras</p>
      </div>
    </div>
    <div class="hero-console" data-animate="fade-up">
      <Console />
    </div>
  </div>
</section>

<!-- ═══════ WHAT IS OPENCLAW ═══════ -->
<section class="section section-openclaw" id="openclaw">
  <div class="section-glow" style="width:900px;height:900px;background:radial-gradient(ellipse,rgba(233,69,96,0.07) 0%,transparent 55%);top:-200px;left:50%;transform:translateX(-50%)"></div>
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">🦞 OpenClaw</span>
      <h2 class="section-title">El proyecto open source con 247K estrellas en GitHub</h2>
      <p class="section-sub">No es un chatbot. Es un sistema de agentes autónomos que vive en tu servidor.</p>
    </div>
    <div class="oc-stats" data-animate="stagger">
      <div class="oc-stat">
        <span class="gradient-text">247K</span>
        <span>GitHub Stars</span>
      </div>
      <div class="oc-sep"></div>
      <div class="oc-stat">
        <span class="gradient-text">47.7K</span>
        <span>Forks</span>
      </div>
      <div class="oc-sep"></div>
      <div class="oc-stat">
        <span class="gradient-text">167K</span>
        <span>Builders</span>
      </div>
    </div>
    <div class="oc-cards" data-animate="stagger">
      <div class="glass-card oc-card">
        <div class="oc-card-icon">🧠</div>
        <h3>No chatea. Ejecuta.</h3>
        <p>A diferencia de ChatGPT, tu agente tiene "manos": navega la web, gestiona archivos, envía emails, organiza tu calendario. Actúa, no solo responde.</p>
      </div>
      <div class="glass-card oc-card">
        <div class="oc-card-icon">🏠</div>
        <h3>Vive en tu servidor</h3>
        <p>Tu agente corre en tu VPS. Tus datos nunca salen de ahí. Si OpenClaw desaparece mañana, tu agente sigue funcionando.</p>
      </div>
      <div class="glass-card oc-card">
        <div class="oc-card-icon">👥</div>
        <h3>Multi-agente</h3>
        <p>Un equipo entero: ventas, soporte, personal, contenido... cada uno con su personalidad y memoria aislada.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ INCLUDES (Features + Incluye fusionados) ═══════ -->
<section class="section section-includes" id="incluye">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">📦 Todo lo que incluye</span>
      <h2 class="section-title">Una membresía. Todo incluido.</h2>
      <p class="section-sub">Formación, herramientas, soporte y comunidad. Todo lo que necesitas para que la IA trabaje por ti.</p>
    </div>
    <div class="includes-grid" data-animate="stagger">
      <div class="glass-card include-card include-lg">
        <span class="include-icon">🎓</span>
        <h3>Curso completo</h3>
        <p>De cero a tu primer agente funcionando. Sin experiencia técnica necesaria.</p>
        <div class="include-tags">
          <span class="include-tag">Vídeos</span>
          <span class="include-tag">Español</span>
          <span class="include-tag">Paso a paso</span>
        </div>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">💡</span>
        <h3>Casos de uso semanales</h3>
        <p>Ejemplos reales para tu negocio cada semana.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">🤖</span>
        <h3>Soporte 24/7</h3>
        <p>TribuBot responde al instante. Y si no puede, Álvaro está detrás.</p>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">📺</span>
        <h3>Directos semanales</h3>
        <p>Cada miércoles a las 19:00. Preguntas en vivo con Álvaro.</p>
      </div>
      <div class="glass-card include-card include-lg">
        <span class="include-icon">🖥️</span>
        <h3>TribuClaw App</h3>
        <p>Gestiona todo desde un solo sitio. Tu centro de mandos para agentes IA.</p>
        <div class="include-tags">
          <span class="include-tag">Skills</span>
          <span class="include-tag">Memoria</span>
          <span class="include-tag">Automatizaciones</span>
        </div>
      </div>
      <div class="glass-card include-card">
        <span class="include-icon">👥</span>
        <h3>Comunidad activa</h3>
        <p>98 miembros que comparten, ayudan y construyen juntos.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ SOCIAL PROOF ═══════ -->
<section class="section section-proof" id="proof">
  <div class="section-glow" style="width:1000px;height:800px;background:radial-gradient(ellipse,rgba(233,69,96,0.06) 0%,transparent 55%);top:-200px;left:50%;transform:translateX(-50%)"></div>
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">⭐ 4.9/5 en Whop</span>
      <h2 class="section-title">No te lo cuento yo. Te lo cuentan ellos.</h2>
      <p class="section-sub">98 miembros. Agentes activos. Tareas ejecutándose mientras lees esto.</p>
    </div>
    <div class="counters-row" data-animate="stagger">
      <div class="counter-item">
        <span class="counter-value" data-target="98" data-suffix="+">0</span>
        <span class="counter-label">Miembros activos</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="247" data-suffix="K">0</span>
        <span class="counter-label">GitHub stars</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="167" data-suffix="K">0</span>
        <span class="counter-label">Builders activos</span>
      </div>
      <div class="counter-item">
        <span class="counter-value" data-target="4.9" data-suffix="" data-decimal="true">0</span>
        <span class="counter-label">Valoración media</span>
      </div>
    </div>
    <div class="review-featured glass-card" data-animate="fade-up">
      <div class="review-stars">★★★★★</div>
      <p class="review-quote">"Espectacular. Solo puedo decir esto. Gracias por el servicio que estáis dando en TribuClaw."</p>
      <div class="review-author">
        <div class="review-avatar">AB</div>
        <div>
          <span class="review-name">Alberto Batlle</span>
          <span class="review-role">Miembro de TribuClaw</span>
        </div>
      </div>
    </div>
    <div class="marquee-wrap">
      <div class="marquee-track" id="marquee-track">
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"En menos de una semana ya tenía mi primer agente funcionando. Increíble."</p><span class="mq-author">Alvaro R.</span></div>
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"El soporte es de otra galaxia. Responden a cualquier hora."</p><span class="mq-author">Maria</span></div>
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"Llevo un mes y ya no puedo vivir sin mis agentes. Serio."</p><span class="mq-author">Raul</span></div>
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"La mejor inversión que he hecho este año. Sin duda."</p><span class="mq-author">Carlos M.</span></div>
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"Los directos de los miércoles son oro puro. Aprendo algo nuevo cada semana."</p><span class="mq-author">Laura P.</span></div>
        <div class="marquee-item"><span class="mq-stars">★★★★★</span><p>"El curso está genial. Todo claro, sin rollo, y en español."</p><span class="mq-author">Javier S.</span></div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ PRICING ═══════ -->
<section class="section section-pricing" id="precio">
  <div class="section-glow" style="width:1200px;height:800px;background:radial-gradient(ellipse,rgba(233,69,96,0.08) 0%,transparent 55%);top:-200px;left:50%;transform:translateX(-50%)"></div>
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">💰 Precio transparente</span>
      <h2 class="section-title">¿Cuánto cuesta montar tu equipo de IA?</h2>
      <p class="section-sub">Menos de lo que te gastas en café al mes.</p>
    </div>
    <div class="pricing-card glass-card" data-animate="fade-up">
      <div class="pricing-badge">Plan completo</div>
      <div class="pricing-main">
        <div class="pricing-items">
          <div class="pricing-item">
            <span class="pricing-item-label">TribuClaw</span>
            <span class="pricing-item-value">35€/mes</span>
          </div>
          <div class="pricing-item">
            <span class="pricing-item-label">VPS (Hetzner)</span>
            <span class="pricing-item-value">desde 5€/mes</span>
          </div>
        </div>
        <div class="pricing-total">
          <span class="pricing-total-label">Total</span>
          <span class="pricing-total-value">desde 40€/mes</span>
        </div>
      </div>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener" style="width:100%;text-align:center;">
        <span>Unirme a TribuClaw</span>
      </a>
      <p class="pricing-note">98 miembros · 4.9/5 en Whop · Sin permanencia</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ FAQ ═══════ -->
<section class="section section-faq" id="faq">
  <div class="container">
    <div class="section-header" data-animate="fade-up">
      <span class="section-badge">❓ FAQ</span>
      <h2 class="section-title">Preguntas frecuentes</h2>
    </div>
    <div class="faq-list" data-animate="stagger">
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Qué es OpenClaw?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>Sistema de agentes IA autónomos open source. 247K stars en GitHub. No es un chatbot: es un sistema de agentes que vive en tu servidor, ejecuta tareas, gestiona emails, navega la web y trabaja 24/7 por ti.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Necesito experiencia técnica?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>No. El curso te guía paso a paso, en español. Sin experiencia técnica necesaria.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Qué incluye la membresía?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>Curso completo, casos de uso semanales, TribuBot 24/7, directos semanales, TribuClaw App y comunidad activa de 98 miembros.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Puedo tener más de un agente?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>Sí. Te enseñamos a configurarlos y gestionarlos.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Mis datos están seguros?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>100%. Tu servidor, tus datos. Nada pasa por terceros.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Qué pasa si cancelo?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>Tu agente sigue funcionando. Pierdes acceso a comunidad y updates.</p></div>
      </div>
      <div class="faq-item glass-card">
        <button class="faq-question"><span>¿Puedo ganar dinero con esto?</span><span class="faq-icon">+</span></button>
        <div class="faq-answer"><p>Sí. Compartimos casos reales de monetización dentro de la comunidad.</p></div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════ CTA FINAL ═══════ -->
<section class="section section-cta-final">
  <div class="section-glow" style="width:1200px;height:800px;background:radial-gradient(ellipse,rgba(233,69,96,0.08) 0%,transparent 55%);top:-200px;left:50%;transform:translateX(-50%)"></div>
  <div class="container">
    <div class="cta-final-inner" data-animate="fade-up">
      <h2 class="cta-final-title"><span class="gradient-text">En 6 meses, tener un agente va a ser lo normal.</span></h2>
      <p class="cta-final-sub">Puedes entrar ahora o cuando todo el mundo lo esté haciendo.</p>
      <a href={WHOP_URL} class="cta-btn cta-btn-lg" target="_blank" rel="noopener">
        <span>Unirme a TribuClaw</span>
      </a>
      <p class="cta-final-hint">Desde 40€/mes · Cancela cuando quieras</p>
    </div>
  </div>
</section>

</main>

<Footer />

<script>
// ═══════ GSAP ANIMATIONS ═══════
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

// Lenis smooth scroll REMOVED — using native browser scroll

// ─── Hero animations on load ───
const heroBadge = document.querySelector('.hero-badge');
const heroHeadline = document.querySelector('.hero-headline');
const heroSub = document.querySelector('.hero-sub');
const heroCta = document.querySelector('.hero-cta');
const heroConsole = document.querySelector('.hero-console');

const heroTl = gsap.timeline({ delay: 0.3 });
heroTl
  .from(heroBadge, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' })
  .from(heroHeadline, { opacity: 0, y: 30, duration: 0.7, ease: 'power2.out' }, '-=0.3')
  .from(heroSub, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3')
  .from(heroCta, { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' }, '-=0.3')
  .from(heroConsole, { opacity: 0, y: 40, scale: 0.95, duration: 0.8, ease: 'power2.out' }, '-=0.4');

// ─── Section headers: fade up ───
gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach(el => {
  // Skip hero elements (already animated)
  if (el.closest('.hero')) return;
  gsap.from(el, {
    scrollTrigger: {
      trigger: el,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.7,
    ease: 'power2.out',
  });
});

// ─── Stagger animations ───
gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach(container => {
  if (container.closest('.hero')) return;
  const children = container.children;
  gsap.from(children, {
    scrollTrigger: {
      trigger: container,
      start: 'top 85%',
      once: true,
    },
    opacity: 0,
    y: 30,
    duration: 0.6,
    stagger: 0.1,
    ease: 'power2.out',
  });
});

// ─── Parallax on glows ───
gsap.utils.toArray<HTMLElement>('.hero-glow').forEach(glow => {
  gsap.to(glow, {
    y: 80,
    scrollTrigger: {
      trigger: '.hero',
      start: 'top top',
      end: 'bottom top',
      scrub: 1,
    },
    ease: 'none',
  });
});

// ─── Counters ───
gsap.utils.toArray<HTMLElement>('.counter-value').forEach(el => {
  const target = parseFloat(el.dataset.target || '0');
  const suffix = el.dataset.suffix || '';
  const isDecimal = el.dataset.decimal === 'true';

  ScrollTrigger.create({
    trigger: el,
    start: 'top 90%',
    once: true,
    onEnter: () => {
      const obj = { val: 0 };
      gsap.to(obj, {
        val: target,
        duration: 2,
        ease: 'power2.out',
        onUpdate: () => {
          el.textContent = (isDecimal ? obj.val.toFixed(1) : Math.floor(obj.val).toLocaleString('es-ES')) + suffix;
        },
      });
    },
  });
});

// ─── FAQ Accordion ───
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.closest('.faq-item');
    const answer = item.querySelector('.faq-answer');
    const icon = btn.querySelector('.faq-icon');
    const isOpen = item.classList.contains('open');

    // Close all
    document.querySelectorAll('.faq-item').forEach(i => {
      i.classList.remove('open');
      const a = i.querySelector('.faq-answer') as HTMLElement;
      const ic = i.querySelector('.faq-icon');
      if (a) a.style.maxHeight = '0';
      if (ic) ic.textContent = '+';
    });

    // Open clicked if was closed
    if (!isOpen) {
      item.classList.add('open');
      (answer as HTMLElement).style.maxHeight = (answer as HTMLElement).scrollHeight + 'px';
      icon.textContent = '−';
    }
  });
});

// ─── Marquee ───
const track = document.getElementById('marquee-track');
if (track) track.innerHTML = track.innerHTML + track.innerHTML;

// ─── Particles ───
const canvas = document.getElementById('hero-particles');
if (canvas) {
  const ctx = canvas.getContext('2d');
  const isMobile = innerWidth < 768;
  const count = isMobile ? 25 : 50;
  const colors = ['#e94560', '#ff6b6b', '#fff'];
  const particles: any[] = [];

  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
  }
  resize();
  addEventListener('resize', resize);

  for (let i = 0; i < count; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height,
      size: Math.random() * 1.5 + 0.5,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.3,
      opacity: Math.random() * 0.4 + 0.1,
      color: colors[Math.floor(Math.random() * colors.length)],
      phase: Math.random() * Math.PI * 2,
    });
  }

  let paused = false;
  document.addEventListener('visibilitychange', () => { paused = document.hidden; });

  function animate() {
    if (paused) { requestAnimationFrame(animate); return; }
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Draw connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const dx = particles[i].x - particles[j].x;
        const dy = particles[i].y - particles[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 120) {
          ctx.save();
          ctx.globalAlpha = (1 - dist / 120) * 0.06;
          ctx.strokeStyle = '#e94560';
          ctx.lineWidth = 0.5;
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
          ctx.restore();
        }
      }
    }

    // Draw particles
    particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.phase += 0.02;
      p.opacity = 0.1 + Math.sin(p.phase) * 0.15 + 0.15;

      if (p.x < 0) p.x = canvas.width;
      if (p.x > canvas.width) p.x = 0;
      if (p.y < 0) p.y = canvas.height;
      if (p.y > canvas.height) p.y = 0;

      ctx.save();
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle = p.color;
      ctx.shadowBlur = 6;
      ctx.shadowColor = p.color;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();
    });

    requestAnimationFrame(animate);
  }
  animate();
}
</script>

