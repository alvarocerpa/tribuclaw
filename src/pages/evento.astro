---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="El Evento que Cambiará tu Forma de Trabajar con IA | TribuClaw"
			description="Si te da miedo quedarte atrás con la IA, este evento es para ti. Ve cómo Pablo y Álvaro usan agentes que trabajan 24/7. Sin programar."
		/>
		<style>
			/* Event Landing Styles */
			.event-hero {
				background: linear-gradient(135deg, #050505 0%, #0d0d0d 100%);
				position: relative;
				overflow: hidden;
				padding: 3rem 0 4rem;
			}
			.event-hero::before {
				content: '';
				position: absolute;
				top: -200px;
				left: 50%;
				transform: translateX(-50%);
				width: 800px;
				height: 800px;
				background: radial-gradient(circle, rgba(233,69,96,0.05) 0%, transparent 70%);
				pointer-events: none;
			}
			.event-container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 2rem;
				position: relative;
				z-index: 1;
			}
			.event-grid {
				display: grid;
				grid-template-columns: 1fr 400px;
				gap: 4rem;
				align-items: start;
			}
			.event-content h1 {
				font-size: 3.2rem;
				line-height: 1.1;
				margin-bottom: 1.5rem;
				background: linear-gradient(135deg, #fff, #e0e0e0);
				background-clip: text;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
			.event-content .subtitle {
				font-size: 1.3rem;
				color: #aaa;
				margin-bottom: 2rem;
				line-height: 1.5;
			}
			.event-highlights {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5rem;
				margin: 2rem 0;
			}
			.highlight-card {
				background: rgba(233,69,96,0.05);
				border: 1px solid rgba(233,69,96,0.15);
				border-radius: 12px;
				padding: 1.5rem;
			}
			.highlight-card .icon {
				font-size: 1.8rem;
				margin-bottom: 0.5rem;
				display: block;
			}
			.highlight-card h3 {
				font-size: 1.1rem;
				margin-bottom: 0.5rem;
				color: #e94560;
			}
			.highlight-card p {
				color: #888;
				font-size: 0.9rem;
				line-height: 1.4;
				margin: 0;
			}

			/* Registration Form */
			.registration-form {
				background: #0a0a0a;
				border: 1px solid #1a1a1a;
				border-radius: 16px;
				padding: 2rem;
				position: sticky;
				top: 120px;
			}
			.form-header {
				text-align: center;
				margin-bottom: 1.5rem;
			}
			.form-header h3 {
				font-size: 1.4rem;
				margin-bottom: 0.5rem;
				color: #e94560;
			}
			.form-header p {
				color: #888;
				font-size: 0.9rem;
				margin: 0;
			}
			.form-group {
				margin-bottom: 1rem;
			}
			.form-group label {
				display: block;
				margin-bottom: 0.5rem;
				color: #e0e0e0;
				font-weight: 600;
				font-size: 0.9rem;
			}
			.form-group input,
			.form-group select {
				width: 100%;
				padding: 0.8rem 1rem;
				background: #050505;
				border: 1px solid #2a2a2a;
				border-radius: 8px;
				color: #e0e0e0;
				font-size: 0.9rem;
				transition: border-color 0.3s;
			}
			.form-group input:focus,
			.form-group select:focus {
				outline: none;
				border-color: #e94560;
			}
			.submit-btn {
				width: 100%;
				background: linear-gradient(135deg, #e94560, #d63851);
				color: white;
				padding: 1rem;
				border: none;
				border-radius: 8px;
				font-weight: 700;
				font-size: 1rem;
				cursor: pointer;
				transition: transform 0.2s, box-shadow 0.2s;
				box-shadow: 0 4px 15px rgba(233,69,96,0.3);
			}
			.submit-btn:hover {
				transform: translateY(-2px);
				box-shadow: 0 6px 25px rgba(233,69,96,0.45);
			}
			.event-info {
				background: #0d0d0d;
				border-radius: 8px;
				padding: 1rem;
				margin-bottom: 1.5rem;
				text-align: center;
			}
			.event-date {
				color: #e94560;
				font-weight: 700;
				font-size: 1.1rem;
			}
			.event-time {
				color: #aaa;
				font-size: 0.9rem;
			}

			/* What You'll See Section */
			.what-youll-see {
				padding: 4rem 0;
				background: #0a0a0a;
			}
			.section-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.section-header h2 {
				font-size: 2.5rem;
				margin-bottom: 1rem;
			}
			.section-header p {
				color: #aaa;
				font-size: 1.1rem;
				max-width: 600px;
				margin: 0 auto;
			}
			.demos-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 2rem;
				max-width: 1000px;
				margin: 0 auto;
				padding: 0 2rem;
			}
			.demo-card {
				background: #050505;
				border: 1px solid #1a1a1a;
				border-radius: 12px;
				padding: 2rem;
				transition: transform 0.3s, border-color 0.3s;
			}
			.demo-card:hover {
				transform: translateY(-4px);
				border-color: rgba(233,69,96,0.3);
			}
			.demo-card .demo-number {
				background: #e94560;
				color: white;
				width: 30px;
				height: 30px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-weight: 700;
				margin-bottom: 1rem;
			}
			.demo-card h3 {
				font-size: 1.2rem;
				margin-bottom: 0.5rem;
			}
			.demo-card p {
				color: #aaa;
				line-height: 1.5;
				margin: 0;
			}

			/* Speakers Section */
			.speakers {
				padding: 4rem 0;
				background: #050505;
			}
			.speakers-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 3rem;
				max-width: 800px;
				margin: 0 auto;
				padding: 0 2rem;
			}
			.speaker-card {
				text-align: center;
				background: #0a0a0a;
				border: 1px solid #1a1a1a;
				border-radius: 12px;
				padding: 2rem;
			}
			.speaker-avatar {
				width: 80px;
				height: 80px;
				background: linear-gradient(135deg, #e94560, #d63851);
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2rem;
				font-weight: 700;
				color: white;
				margin: 0 auto 1rem;
			}
			.speaker-card h3 {
				font-size: 1.3rem;
				margin-bottom: 0.5rem;
			}
			.speaker-card .role {
				color: #e94560;
				font-size: 0.9rem;
				margin-bottom: 1rem;
			}
			.speaker-card p {
				color: #aaa;
				line-height: 1.5;
				margin: 0;
			}

			/* Trust Indicators */
			.trust-section {
				padding: 3rem 0;
				background: #0d0d0d;
				text-align: center;
			}
			.trust-indicators {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 3rem;
				flex-wrap: wrap;
				max-width: 600px;
				margin: 0 auto;
			}
			.trust-item {
				text-align: center;
			}
			.trust-number {
				font-size: 2rem;
				font-weight: 700;
				color: #e94560;
				display: block;
			}
			.trust-label {
				color: #aaa;
				font-size: 0.9rem;
			}

			/* Responsive */
			@media (max-width: 768px) {
				.event-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.registration-form {
					position: static;
					order: -1;
				}
				.event-content h1 {
					font-size: 2.2rem;
				}
				.event-highlights {
					grid-template-columns: 1fr;
					gap: 1rem;
				}
				.demos-grid {
					grid-template-columns: 1fr;
					gap: 1.5rem;
				}
				.speakers-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.trust-indicators {
					gap: 2rem;
				}
				.event-container {
					padding: 0 1.5rem;
				}
			}

			/* Form States */
			.form-success {
				background: rgba(40, 167, 69, 0.1);
				border: 1px solid rgba(40, 167, 69, 0.3);
				border-radius: 8px;
				padding: 1rem;
				text-align: center;
				color: #28a745;
			}
			.form-error {
				background: rgba(220, 53, 69, 0.1);
				border: 1px solid rgba(220, 53, 69, 0.3);
				border-radius: 8px;
				padding: 1rem;
				text-align: center;
				color: #dc3545;
			}
			.loading {
				opacity: 0.7;
				pointer-events: none;
			}

		</style>
	</head>
	<body>
		<Header />

		<!-- Hero Section -->
		<section class="event-hero">
			<div class="event-container">
				<div class="event-grid">
					<div class="event-content">
						<h1>Si te da miedo quedarte atrás con la IA, este evento es para ti</h1>
						<p class="subtitle">
							Ve cómo Pablo y Álvaro usan agentes que trabajan 24/7. 
							<strong>Sin programar. Sin complicaciones. Sin excusas.</strong>
						</p>

						<div class="event-highlights">
							<div class="highlight-card">
								<span class="icon">👥</span>
								<h3>Para no técnicos</h3>
								<p>Si usas WhatsApp, puedes tener agentes IA</p>
							</div>
							<div class="highlight-card">
								<span class="icon">⚡</span>
								<h3>Casos reales</h3>
								<p>No demos perfectos, agentes funcionando de verdad</p>
							</div>
							<div class="highlight-card">
								<span class="icon">🎯</span>
								<h3>Delegación real</h3>
								<p>Agentes que HACEN, no que solo responden</p>
							</div>
							<div class="highlight-card">
								<span class="icon">⏰</span>
								<h3>Es ahora o nunca</h3>
								<p>Quien no actúe llegará tarde</p>
							</div>
						</div>
					</div>

					<!-- Registration Form -->
					<div class="registration-form">
						<div class="form-header">
							<h3>Reserva tu plaza</h3>
							<p>Acceso gratuito por tiempo limitado</p>
						</div>

						<div class="event-info">
							<div class="event-date">📅 Próximamente</div>
							<div class="event-time">⏱️ 2 horas • Online</div>
						</div>

						<form id="eventForm">
							<div class="form-group">
								<label for="name">Nombre completo</label>
								<input type="text" id="name" name="name" required>
							</div>
							<div class="form-group">
								<label for="email">Email</label>
								<input type="email" id="email" name="email" required>
							</div>
							<div class="form-group">
								<label for="experience">Tu experiencia con IA</label>
								<select id="experience" name="experience" required>
									<option value="">Selecciona...</option>
									<option value="beginner">Principiante (solo ChatGPT)</option>
									<option value="intermediate">Intermedio (algunas herramientas)</option>
									<option value="advanced">Avanzado (ya uso agentes)</option>
								</select>
							</div>
							<div class="form-group">
								<label for="business">¿Tienes negocio?</label>
								<select id="business" name="business" required>
									<option value="">Selecciona...</option>
									<option value="yes">Sí, tengo negocio</option>
									<option value="employed">Soy empleado</option>
									<option value="student">Estudiante</option>
									<option value="other">Otro</option>
								</select>
							</div>
							<button type="submit" class="submit-btn">
								🚀 Reservar mi plaza gratis
							</button>
						</form>

						<div id="formMessage" style="display: none; margin-top: 1rem;"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- What You'll See -->
		<section class="what-youll-see">
			<div class="section-header">
				<h2>Qué vas a ver en directo</h2>
				<p>4 agentes IA reales funcionando. No teoría, no demos perfectos. Solo resultados.</p>
			</div>
			<div class="demos-grid">
				<div class="demo-card">
					<div class="demo-number">1</div>
					<h3>Calendar + WhatsApp automático</h3>
					<p>Ve calendario, crea eventos, habla con clientes como si fuera una persona real. Trabaja 24/7 sin intervención.</p>
				</div>
				<div class="demo-card">
					<div class="demo-number">2</div>
					<h3>Kimo Voice funcionando</h3>
					<p>Agente de voz que entiende, ejecuta y responde. Cuánto costó montarlo, stack técnico, casos de uso reales.</p>
				</div>
				<div class="demo-card">
					<div class="demo-number">3</div>
					<h3>Lentejo Lab</h3>
					<p>Construido viendo Netflix, sin programar. Qué hace en el negocio diario y por qué no necesitas ser técnico.</p>
				</div>
				<div class="demo-card">
					<div class="demo-number">4</div>
					<h3>Orquestación Multi-Agente</h3>
					<p>Mika + Kimo trabajando juntos. Por qué múltiples agentes especializados en vez de uno genérico.</p>
				</div>
			</div>
		</section>

		<!-- Speakers -->
		<section class="speakers">
			<div class="section-header">
				<h2>Quién te lo enseña</h2>
				<p>Los únicos en España que viven de agentes IA autónomos</p>
			</div>
			<div class="speakers-grid">
				<div class="speaker-card">
					<div class="speaker-avatar">PC</div>
					<h3>Pablo Cerpa</h3>
					<div class="role">Cofundador TribuClaw</div>
					<p>Expert en OpenClaw y automatización. Ha construido agentes para calendario, WhatsApp y gestión de negocio sin escribir código.</p>
				</div>
				<div class="speaker-card">
					<div class="speaker-avatar">AC</div>
					<h3>Álvaro Cerpa</h3>
					<div class="role">Cofundador TribuClaw</div>
					<p>Emprendedor que transformó su forma de trabajar con Kimo y Mika. Experto en casos de uso reales y monetización con IA.</p>
				</div>
			</div>
		</section>

		<!-- Trust Indicators -->
		<section class="trust-section">
			<div class="trust-indicators">
				<div class="trust-item">
					<span class="trust-number">72h</span>
					<span class="trust-label">Para montar agentes</span>
				</div>
				<div class="trust-item">
					<span class="trust-number">24/7</span>
					<span class="trust-label">Agentes trabajando</span>
				</div>
				<div class="trust-item">
					<span class="trust-number">0€</span>
					<span class="trust-label">Conocimiento técnico</span>
				</div>
			</div>
		</section>

		<Footer />

		<script>
			document.getElementById('eventForm').addEventListener('submit', async function(e) {
				e.preventDefault();
				
				const formData = new FormData(this);
				const data = Object.fromEntries(formData);
				const submitBtn = this.querySelector('.submit-btn');
				const messageDiv = document.getElementById('formMessage');
				
				// Loading state
				submitBtn.textContent = '⏳ Registrando...';
				submitBtn.disabled = true;
				this.classList.add('loading');
				
				try {
					// Here you would integrate with GoHighLevel or your backend
					// For now, simulate success
					await new Promise(resolve => setTimeout(resolve, 2000));
					
					// Success state
					messageDiv.className = 'form-success';
					messageDiv.textContent = '✅ ¡Plaza reservada! Recibirás un email con los detalles.';
					messageDiv.style.display = 'block';
					this.reset();
					
					// Track conversion (add your analytics)
					if (typeof gtag !== 'undefined') {
						gtag('event', 'conversion', {
							send_to: 'AW-CONVERSION_ID/CONVERSION_LABEL'
						});
					}
					
				} catch (error) {
					// Error state
					messageDiv.className = 'form-error';
					messageDiv.textContent = '❌ Error al registrarte. Inténtalo de nuevo.';
					messageDiv.style.display = 'block';
				} finally {
					// Reset button
					submitBtn.textContent = '🚀 Reservar mi plaza gratis';
					submitBtn.disabled = false;
					this.classList.remove('loading');
				}
			});
		</script>
	</body>
</html>