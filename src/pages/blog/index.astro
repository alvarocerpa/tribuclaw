---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, WHOP_URL } from '../../consts';

const now = new Date();
const posts = (await getCollection('blog'))
  .filter(p => new Date(p.data.pubDate) <= now)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroImages: Record<string, string> = {
	'que-es-un-agente-ia-personal': '/images/blog/agente-ia-personal-hero.svg',
	'openclaw-que-es-guia-completa-espanol': '/images/blog/hero-openclaw.svg',
	'5-cosas-que-mi-agente-ia-hace-por-mi': '/images/blog/hero-5-cosas.svg',
	'automatizar-whatsapp-con-ia-guia-completa': '/images/blog/hero-whatsapp.svg',
	'ganar-dinero-con-ia-formas-reales': '/images/blog/hero-ganar-dinero.svg',
	'como-crear-tu-propio-agente-ia-desde-cero': '/images/blog/hero-crear-agente.svg',
	'automatizar-telegram-con-agente-ia': '/images/blog/hero-automatizar-telegram.svg',
	'instalar-openclaw-en-vps-paso-a-paso': '/images/blog/hero-instalar-openclaw-vps.svg',
	'agente-ia-personal-vs-chatgpt-diferencias': '/images/blog/hero-agente-ia-personal-vs-chatgpt-diferencias.svg',
	'herramientas-ia-para-emprendedores-2026': '/images/blog/hero-herramientas-ia-para-emprendedores-2026.svg',
	'agente-ia-que-gestiona-tu-whatsapp': '/images/blog/hero-agente-ia-que-gestiona-tu-whatsapp.svg',
};

const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="es">
<head>
  <BaseHead
    title={`Blog | ${SITE_TITLE} — Guías y tutoriales de agentes IA`}
    description="Artículos, guías y tutoriales sobre agentes IA personales, automatización con inteligencia artificial y cómo emprender con IA. Todo en español."
  />
</head>
<body class="dot-bg">
<Header />
<main id="main-content">

  <!-- Hero -->
  <section class="blog-hero">
    <div class="section-glow" style="width:800px;height:500px;background:radial-gradient(ellipse,rgba(233,69,96,0.1) 0%,transparent 65%);top:-120px;left:50%;transform:translateX(-50%)"></div>
    <div class="container">
      <div class="blog-hero-inner" data-animate="fade-up">
        <span class="badge-pill">📝 Blog TribuClaw</span>
        <h1>Blog</h1>
        <p class="blog-hero-sub">Guías, tutoriales y estrategias sobre agentes IA personales, automatización y emprendimiento con IA.</p>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="featured-section container" data-animate="fade-up">
      <div class="featured-card glass-card">
        <a href={`/blog/${featured.id}/`}>
          <div class="featured-img">
            <img src={heroImages[featured.id] || featured.data.heroImage || '/images/og-default.jpg'} alt={featured.data.title} width="600" height="338" fetchpriority="high" />
          </div>
          <div class="featured-body">
            <span class="featured-badge">DESTACADO</span>
            <h2>{featured.data.title}</h2>
            <p class="featured-excerpt">{featured.data.description}</p>
            <span class="featured-meta">
              <time datetime={featured.data.pubDate.toISOString()}>
                {featured.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              &middot; {featured.data.author}
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="blog-cta container" data-animate="fade-up">
    <div class="cta-banner glass-card">
      <div class="cta-banner-text">
        <h3>Aprende a crear tu agente IA</h3>
        <p>Guías paso a paso, comunidad activa y soporte en español.</p>
      </div>
      <a href={WHOP_URL} target="_blank" class="cta-btn">
        <span>Unirse a TribuClaw</span>
      </a>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="posts-section container">
    <h2 class="posts-title" data-animate="fade-up">Todos los artículos</h2>
    <div class="posts-grid" data-animate="stagger">
      {rest.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
          heroImage={heroImages[post.id] || post.data.heroImage}
        />
      ))}
    </div>
  </section>

</main>
<Footer />

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach(el => {
  gsap.from(el, {
    scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    opacity: 0, y: 30, duration: 0.7, ease: 'power2.out',
  });
});

gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach(container => {
  gsap.from(container.children, {
    scrollTrigger: { trigger: container, start: 'top 85%', once: true },
    opacity: 0, y: 25, duration: 0.6, stagger: 0.08, ease: 'power2.out',
  });
});
</script>

<style>
  /* Hero */
  .blog-hero {
    padding: 6rem 0 3rem;
    position: relative;
    overflow: hidden;
  }
  .blog-hero-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }
  .blog-hero-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
  }

  /* Featured */
  .featured-section {
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 1;
  }
  .featured-card {
    overflow: hidden;
  }
  .featured-card a {
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 1fr;
  }
  .featured-card a:hover { text-decoration: none; color: inherit; }
  .featured-img {
    background: var(--bg-alt);
    overflow: hidden;
    aspect-ratio: 16/9;
    max-height: 350px;
  }
  .featured-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(.23,1,.32,1);
  }
  .featured-card:hover .featured-img img {
    transform: scale(1.03);
  }
  .featured-body {
    padding: 2rem;
  }
  .featured-badge {
    display: inline-block;
    background: rgba(233,69,96,0.1);
    color: var(--accent);
    padding: 0.2rem 0.7rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .featured-body h2 {
    font-size: 1.5rem;
    line-height: 1.25;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
  }
  .featured-card:hover .featured-body h2 { color: var(--accent); }
  .featured-excerpt {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .featured-meta {
    color: rgba(250,250,250,0.3);
    font-size: 0.85rem;
  }

  /* CTA Banner */
  .blog-cta {
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }
  .cta-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2rem 2.5rem;
    border: 1px solid rgba(233,69,96,0.15);
  }
  .cta-banner-text h3 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }
  .cta-banner-text p {
    color: var(--text-muted);
    margin: 0;
    font-size: 0.9rem;
  }

  /* Posts */
  .posts-section {
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
  }
  .posts-title {
    font-size: 1.4rem;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
    .featured-card a { grid-template-columns: 1fr 1fr; }
    .featured-img { max-height: none; aspect-ratio: auto; }
  }

  @media (min-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 639px) {
    .blog-hero { padding: 4rem 0 2rem; }
    .blog-hero h1 { font-size: 1.8rem; }
    .featured-body { padding: 1.25rem; }
    .featured-body h2 { font-size: 1.2rem; }
    .cta-banner { padding: 1.5rem; flex-direction: column; text-align: center; }
  }
</style>

</body>
</html>
