---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, WHOP_URL } from '../../consts';

const now = new Date();
const posts = (await getCollection('blog'))
  .filter(p => new Date(p.data.pubDate) <= now)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const heroImages: Record<string, string> = {
	'que-es-un-agente-ia-personal': '/images/blog/agente-ia-personal-hero.svg',
	'openclaw-que-es-guia-completa-espanol': '/images/blog/hero-openclaw.svg',
	'5-cosas-que-mi-agente-ia-hace-por-mi': '/images/blog/hero-5-cosas.svg',
	'automatizar-whatsapp-con-ia-guia-completa': '/images/blog/hero-whatsapp.svg',
	'ganar-dinero-con-ia-formas-reales': '/images/blog/hero-ganar-dinero.svg',
	'como-crear-tu-propio-agente-ia-desde-cero': '/images/blog/hero-crear-agente.svg',
	'automatizar-telegram-con-agente-ia': '/images/blog/hero-automatizar-telegram.svg',
	'instalar-openclaw-en-vps-paso-a-paso': '/images/blog/hero-instalar-openclaw-vps.svg',
	'agente-ia-personal-vs-chatgpt-diferencias': '/images/blog/hero-agente-ia-personal-vs-chatgpt-diferencias.svg',
	'herramientas-ia-para-emprendedores-2026': '/images/blog/hero-herramientas-ia-para-emprendedores-2026.svg',
	'agente-ia-que-gestiona-tu-whatsapp': '/images/blog/hero-agente-ia-que-gestiona-tu-whatsapp.svg',
};

const featured = posts[0];
const rest = posts.slice(1);
---

<BaseLayout
  title={`Blog | ${SITE_TITLE} — Guías y tutoriales de agentes IA`}
  description="Artículos, guías y tutoriales sobre agentes IA personales, automatización con inteligencia artificial y cómo emprender con IA. Todo en español."
>

  <!-- Hero -->
  <section class="blog-hero">
    <div class="glow-orb glow-orb-red" style="width:600px;height:600px;top:-200px;left:20%;"></div>
    <div class="glow-orb glow-orb-blue" style="width:400px;height:400px;bottom:-100px;right:10%;"></div>
    <div class="container">
      <div class="blog-hero-inner" data-animate="fade-up">
        <span class="badge-pill">📝 Blog</span>
        <h1>Blog</h1>
        <p class="blog-hero-sub">Guías, tutoriales y estrategias sobre agentes IA personales, automatización y emprendimiento con IA.</p>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  {featured && (
    <section class="featured-section container" data-animate="fade-up">
      <div class="featured-card glass-card featured-glow">
        <a href={`/blog/${featured.id}/`}>
          <div class="featured-img">
            <img src={heroImages[featured.id] || featured.data.heroImage || '/images/og-default.jpg'} alt={featured.data.title} width="600" height="338" fetchpriority="high" />
          </div>
          <div class="featured-body">
            <div class="featured-badge">
              <span class="badge-pill" style="margin-bottom:0;font-size:0.65rem;padding:0.25rem 0.6rem;">⭐ Destacado</span>
            </div>
            <h2>{featured.data.title}</h2>
            <p class="featured-excerpt">{featured.data.description}</p>
            <div class="featured-meta">
              <time datetime={featured.data.pubDate.toISOString()}>
                {featured.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {featured.data.tags && featured.data.tags.length > 0 && (
                <div class="featured-tags">
                  {featured.data.tags.slice(0, 3).map((tag: string) => <span class="blog-tag">{tag}</span>)}
                </div>
              )}
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <div class="section-divider"></div>

  <!-- Posts grid -->
  <section class="posts-section container">
    <div class="posts-grid" data-animate="stagger">
      {rest.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
          heroImage={heroImages[post.id] || post.data.heroImage}
          readingTime={Math.max(3, Math.ceil((post.body || '').split(/\s+/).length / 200))}
        />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="blog-cta-section container" data-animate="fade-up">
    <div class="blog-cta-inner glass-card">
      <div class="glow-orb glow-orb-red" style="width:200px;height:200px;top:-60px;right:-40px;"></div>
      <h3>¿Listo para crear tu agente IA?</h3>
      <p>Curso + App + Comunidad. Todo en español.</p>
      <a href={WHOP_URL} target="_blank" class="cta-btn">Únete a TribuClaw →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .blog-hero {
    padding: 7rem 0 3rem;
    position: relative;
    overflow: hidden;
  }
  .blog-hero-inner {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .blog-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }
  .blog-hero-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  /* Featured */
  .featured-section { margin-bottom: 1rem; }
  .featured-card { overflow: hidden; }
  .featured-card a {
    text-decoration: none; color: inherit;
    display: grid; grid-template-columns: 1fr;
    transition: box-shadow 0.3s ease;
  }
  .featured-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.3); }
  .featured-card a:hover { text-decoration: none; color: inherit; }
  .featured-glow {
    border-color: rgba(233,69,96,0.2);
    box-shadow: 0 0 40px rgba(233,69,96,0.06), 0 8px 32px rgba(0,0,0,0.3);
  }
  .featured-glow:hover {
    border-color: rgba(233,69,96,0.35);
    box-shadow: 0 0 50px rgba(233,69,96,0.1), 0 12px 40px rgba(0,0,0,0.4);
  }
  .featured-img {
    background: var(--bg-alt); overflow: hidden;
    aspect-ratio: 16/9; max-height: 350px;
  }
  .featured-img img { width: 100%; height: 100%; object-fit: cover; }
  .featured-body { padding: 2rem; }
  .featured-badge { margin-bottom: 0.75rem; }
  .featured-body h2 {
    font-size: 1.35rem; line-height: 1.25; margin-bottom: 0.5rem;
    transition: color 0.2s; font-weight: 800;
  }
  .featured-card:hover .featured-body h2 { color: var(--accent); }
  .featured-excerpt {
    color: var(--text-muted); font-size: 0.9rem; line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .featured-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: rgba(250,250,250,0.3);
    font-size: 0.8rem;
  }
  .featured-tags {
    display: flex;
    gap: 0.4rem;
  }
  .blog-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    background: rgba(233,69,96,0.08);
    border: 1px solid rgba(233,69,96,0.15);
    color: var(--accent);
  }

  .posts-section { margin-bottom: 4rem; }
  .posts-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }

  /* CTA section */
  .blog-cta-section { padding-bottom: 5rem; text-align: center; }
  .blog-cta-inner {
    max-width: 500px;
    margin: 0 auto;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .blog-cta-inner h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .blog-cta-inner p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
    .featured-card a { grid-template-columns: 1fr 1fr; }
    .featured-img { max-height: none; aspect-ratio: auto; }
    .featured-body { padding: 2rem; }
    .featured-body h2 { font-size: 1.5rem; }
  }

  @media (max-width: 639px) {
    .blog-hero { padding: 5rem 0 2rem; }
    .blog-hero h1 { font-size: 1.8rem; }
    .featured-body { padding: 1.25rem; }
    .featured-body h2 { font-size: 1.2rem; }
  }
</style>
