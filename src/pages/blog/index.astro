---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, WHOP_URL } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const heroImages: Record<string, string> = {
	'que-es-un-agente-ia-personal': '/images/blog/agente-ia-personal-hero.svg',
	'openclaw-que-es-guia-completa-espanol': '/images/blog/hero-openclaw.svg',
	'5-cosas-que-mi-agente-ia-hace-por-mi': '/images/blog/hero-5-cosas.svg',
	'automatizar-whatsapp-con-ia-guia-completa': '/images/blog/hero-whatsapp.svg',
	'ganar-dinero-con-ia-formas-reales': '/images/blog/hero-ganar-dinero.svg',
	'como-crear-tu-propio-agente-ia-desde-cero': '/images/blog/hero-crear-agente.svg',
	'automatizar-telegram-con-agente-ia': '/images/blog/hero-automatizar-telegram.svg',
	'instalar-openclaw-en-vps-paso-a-paso': '/images/blog/hero-instalar-openclaw-vps.svg',
	'agente-ia-personal-vs-chatgpt-diferencias': '/images/blog/hero-agente-ia-personal-vs-chatgpt-diferencias.svg',
	'herramientas-ia-para-emprendedores-2026': '/images/blog/hero-herramientas-ia-para-emprendedores-2026.svg',
};

const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={`Blog | ${SITE_TITLE} — Guías y tutoriales de agentes IA`}
			description="Artículos, guías y tutoriales sobre agentes IA personales, automatización con inteligencia artificial y cómo emprender con IA. Todo en español."
		/>
		<style>
			.blog-hero {
				text-align: center;
				padding: 3rem 1rem 2rem;
				max-width: 700px;
				margin: 0 auto;
			}
			.blog-hero h1 {
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
			}
			.blog-hero p {
				color: #888;
				font-size: 1.05rem;
			}

			/* Featured post */
			.featured {
				max-width: 1000px;
				margin: 0 auto 3rem;
				padding: 0 1rem;
			}
			.featured-card {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 0;
				border: 1px solid #1a1a1a;
				border-radius: 16px;
				overflow: hidden;
				background: #0a0a0a;
				transition: border-color 0.3s;
			}
			.featured-card:hover { border-color: rgba(233,69,96,0.3); }
			.featured-card a { text-decoration: none; color: inherit; display: contents; }
			.featured-img {
				background: #111;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 300px;
				aspect-ratio: 1/1;
				overflow: hidden;
			}
			.featured-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.featured-body {
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.featured-badge {
				display: inline-block;
				background: rgba(233,69,96,0.1);
				color: #e94560;
				padding: 0.2rem 0.7rem;
				border-radius: 4px;
				font-size: 0.75rem;
				font-weight: 600;
				margin-bottom: 1rem;
				width: fit-content;
			}
			.featured-body h2 {
				font-size: 1.6rem;
				line-height: 1.25;
				margin-bottom: 0.75rem;
				transition: color 0.2s;
			}
			.featured-card a:hover .featured-body h2 { color: #e94560; }
			.featured-body .excerpt {
				color: #888;
				font-size: 0.95rem;
				line-height: 1.6;
				margin-bottom: 1rem;
			}
			.featured-body .meta {
				color: #555;
				font-size: 0.85rem;
			}

			/* Post grid */
			.posts-section {
				max-width: 1000px;
				margin: 0 auto 4rem;
				padding: 0 1rem;
			}
			.posts-section h2 {
				font-size: 1.5rem;
				margin-bottom: 1.5rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid #1a1a1a;
			}
			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.5rem;
			}
			.post-card {
				border: 1px solid #1a1a1a;
				border-radius: 14px;
				overflow: hidden;
				background: #0a0a0a;
				transition: border-color 0.3s, transform 0.2s;
			}
			.post-card:hover {
				border-color: rgba(233,69,96,0.3);
				transform: translateY(-3px);
			}
			.post-card a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-card-img {
				width: 100%;
				height: 180px;
				aspect-ratio: 16/9;
				background: #111;
				overflow: hidden;
				border-bottom: 1px solid #1a1a1a;
			}
			.post-card-img img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
			.post-card-body {
				padding: 1.25rem;
			}
			.post-card .meta {
				font-size: 0.8rem;
				color: #555;
				margin-bottom: 0.4rem;
			}
			.post-card .tags {
				display: flex;
				gap: 0.4rem;
				flex-wrap: wrap;
				margin-bottom: 0.6rem;
			}
			.post-card .tag {
				background: #141414;
				color: #888;
				padding: 0.2rem 0.6rem;
				border-radius: 3px;
				font-size: 0.7rem;
				margin: 0.2rem;
			}
			.post-card h3 {
				font-size: 1.05rem;
				margin-bottom: 0.4rem;
				line-height: 1.35;
				transition: color 0.2s;
			}
			.post-card a:hover h3 { color: #e94560; }
			.post-card .excerpt {
				color: #777;
				font-size: 0.85rem;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* CTA banner */
			.blog-cta {
				max-width: 1000px;
				margin: 0 auto 3rem;
				padding: 0 1rem;
			}
			.cta-banner {
				background: linear-gradient(135deg, rgba(233,69,96,0.08), rgba(233,69,96,0.03));
				border: 1px solid rgba(233,69,96,0.2);
				border-radius: 16px;
				padding: 2.5rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 2rem;
				flex-wrap: wrap;
			}
			.cta-banner-text h3 {
				font-size: 1.3rem;
				margin-bottom: 0.3rem;
			}
			.cta-banner-text p {
				color: #888;
				margin: 0;
			}
			.cta-banner a {
				background: #e94560;
				color: white;
				padding: 0.7rem 1.5rem;
				border-radius: 8px;
				font-weight: 700;
				text-decoration: none;
				white-space: nowrap;
				transition: background 0.2s;
			}
			.cta-banner a:hover {
				background: #c23152;
				text-decoration: none;
			}
			.cta-banner a {
				min-height: 44px;
				min-width: 44px;
				display: inline-flex;
				align-items: center;
				justify-content: center;
			}

			@media (max-width: 720px) {
				.blog-hero { padding: 2.5rem 1.25rem 1.5rem; }
				.blog-hero h1 { font-size: 1.8rem; }
				.blog-hero p { font-size: 0.92rem; }
				.featured { padding: 0 1.25rem; }
				.featured-card { grid-template-columns: 1fr; }
				.featured-img { min-height: 180px; }
				.featured-body { padding: 1.25rem; }
				.featured-body h2 { font-size: 1.2rem; }
				.posts-section { padding: 0 1.25rem; }
				.posts-grid { grid-template-columns: 1fr; }
				.post-card-img { height: 160px; }
				.blog-cta { padding: 0 1.25rem; }
				.cta-banner { padding: 1.5rem; flex-direction: column; text-align: center; }
				.cta-banner a { max-width: 280px; text-align: center; }
				.posts-section h2 { font-size: 1.25rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<section class="blog-hero">
				<h1>Blog</h1>
				<p>Guías, tutoriales y estrategias sobre agentes IA personales, automatización y emprendimiento con IA.</p>
			</section>

			<!-- Featured post -->
			{featured && (
				<section class="featured">
					<div class="featured-card">
						<a href={`/blog/${featured.id}/`}>
							<div class="featured-img">
								<img src={heroImages[featured.id] || featured.data.heroImage || '/images/og-default.jpg'} alt={featured.data.title} width="600" height="338" fetchpriority="high" />
							</div>
							<div class="featured-body">
								<span class="featured-badge">DESTACADO</span>
								<h2>{featured.data.title}</h2>
								<p class="excerpt">{featured.data.description}</p>
								<span class="meta"><FormattedDate date={featured.data.pubDate} /> &middot; {featured.data.author}</span>
							</div>
						</a>
					</div>
				</section>
			)}

			<!-- CTA Banner -->
			<section class="blog-cta">
				<div class="cta-banner">
					<div class="cta-banner-text">
						<h3>Aprende a crear tu agente IA</h3>
						<p>Guías paso a paso, comunidad activa y soporte en español.</p>
					</div>
					<a href={WHOP_URL} target="_blank">Unirse a TribuClaw</a>
				</div>
			</section>

			<!-- Rest of posts -->
			<section class="posts-section">
				<h2>Todos los artículos</h2>
				<div class="posts-grid">
					{rest.map((post) => (
						<div class="post-card">
							<a href={`/blog/${post.id}/`}>
								<div class="post-card-img">
									<img src={heroImages[post.id] || post.data.heroImage || '/images/og-default.jpg'} alt={post.data.title} loading="lazy" decoding="async" width="300" height="169" />
								</div>
								<div class="post-card-body">
									<div class="meta"><FormattedDate date={post.data.pubDate} /></div>
									{post.data.tags.length > 0 && (
										<div class="tags">
											{post.data.tags.slice(0, 3).map((tag: string) => <span class="tag">{tag}</span>)}
										</div>
									)}
									<h3>{post.data.title}</h3>
									<p class="excerpt">{post.data.description}</p>
								</div>
							</a>
						</div>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
