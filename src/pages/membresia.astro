---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { WHOP_URL } from '../consts';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <BaseHead
    title="Únete a TribuClaw — Tu agente IA en 8 minutos"
    description="La comunidad en español que te enseña a instalar, configurar y dominar tu propio agente de IA. Un comando. 8 minutos. Bajo tu control."
  />
  <link rel="preconnect" href="https://assets-2-prod.whop.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══════════════════════════════════ HEADER ═══════════════════════════════════ -->
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
      <img src="/images/logo-icon.png" width="32" height="32" alt="TribuClaw logo" fetchpriority="high" />
      <span class="logo-text">Tribu<span class="accent">Claw</span></span>
    </a>
    <nav class="header-nav">
      <a href="#que-es" class="nav-link">¿Qué es?</a>
      <a href="#incluye" class="nav-link">Qué incluye</a>
      <a href="#precio" class="nav-link">Precio</a>
      <a href="#faq" class="nav-link">FAQ</a>
    </nav>
    <div class="cta-wrap cta-wrap-sm">
      <a href={WHOP_URL} class="cta-btn header-cta" target="_blank" rel="noopener">
        Prueba gratis →
      </a>
    </div>
  </div>
</header>

<!-- ═══════════════════════════════════ HERO ════════════════════════════════════ -->
<section class="hero">
  <!-- Capa 1: Star field -->
  <!-- via ::before CSS -->
  <!-- Capa 2: Dot pattern -->
  <div class="hero-dots"></div>
  <!-- Capa 3: Glow top -->
  <div class="hero-glow-top"></div>
  <!-- Capa 4: Glow bottom -->
  <div class="hero-glow-bottom"></div>
  <!-- Capa 5: Water distortion -->
  <div class="hero-water"></div>
  <!-- Capa 6: Particles -->
  <div class="hero-particles">
    <div class="bubble b1"></div>
    <div class="bubble b2"></div>
    <div class="bubble b3"></div>
    <div class="bubble b4"></div>
    <div class="bubble b5"></div>
    <div class="bubble b6"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badge">🦞 +95 miembros ya dentro</div>
    <h1 class="hero-headline">
      Tu agente de IA.<br/>
      <span class="accent glow-text">En 8 minutos.</span><br/>
      En tu servidor. Bajo tu control.
    </h1>
    <p class="hero-sub">
      OpenClaw instalado automáticamente en tu VPS. Sin configuraciones complejas, sin inglés, sin horas perdidas. Tu agente trabajando para ti desde el primer día.
    </p>
    <div class="cta-wrap">
      <a href={WHOP_URL} class="cta-btn cta-large" target="_blank" rel="noopener">
        <span class="cta-main">🚀 Empieza gratis</span>
        <span class="cta-sub-line">1 día de prueba gratis · Después 35€/mes</span>
      </a>
    </div>
    <div class="social-proof">
      <span class="stars-row">★★★★★</span>
      <span class="proof-text">emprendedores, freelancers y solopreneurs ya con agentes IA</span>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ VÍDEO ════════════════════════════════════ -->
<section class="section-video reveal">
  <div class="container">
    <h2 class="section-title">Míralo en acción</h2>
    <p class="section-lead">Un vídeo vale más que mil palabras. Esto es lo que consigues en 8 minutos.</p>
    <div class="video-wrap">
      <video
        controls
        playsinline
        preload="metadata"
        poster="/images/video-poster.jpg"
        style="width:100%;border-radius:12px;display:block;"
      >
        <source src="https://assets-2-prod.whop.com/uploads/user_9023883/video/bots/2026-02-19/932b070b-9cc8-4980-a20a-de5a1b9a9eac.mp4" type="video/mp4" />
      </video>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ QUÉ ES OPENCLAW ════════════════════════ -->
<section class="section-openclaw reveal" id="que-es">
  <div class="container text-center">
    <div class="badge badge-accent">🦞 Esto es OpenClaw</div>
    <h2 class="section-title">El proyecto de IA más viral de la historia</h2>
    <p class="section-lead" style="max-width:640px;margin:0 auto 2.5rem;">
      OpenClaw no es un chatbot. Es un sistema de agentes autónomos de código abierto que vive en tu servidor y trabaja para ti 24/7.
    </p>

    <div class="oc-stats-row">
      <div class="oc-stat">
        <span class="oc-stat-number">247K</span>
        <span class="oc-stat-label">GitHub Stars</span>
      </div>
      <div class="oc-stat-divider"></div>
      <div class="oc-stat">
        <span class="oc-stat-number">10 días</span>
        <span class="oc-stat-label">de 0 a 210K stars</span>
      </div>
      <div class="oc-stat-divider"></div>
      <div class="oc-stat">
        <span class="oc-stat-number">47.7K</span>
        <span class="oc-stat-label">Forks</span>
      </div>
    </div>

    <div class="oc-timeline">
      <div class="oc-event reveal">
        <div class="oc-event-date">Nov 2025</div>
        <div class="oc-event-text">Peter Steinberger crea el proyecto como código abierto</div>
      </div>
      <div class="oc-event reveal">
        <div class="oc-event-date">Ene 2026</div>
        <div class="oc-event-text">Explota viralmente: 100K GitHub stars en menos de un mes</div>
      </div>
      <div class="oc-event reveal">
        <div class="oc-event-date">Feb 2026</div>
        <div class="oc-event-text">OpenAI contrata al fundador. Sam Altman anuncia: "OpenClaw vivirá en una fundación como proyecto open source que OpenAI apoyará"</div>
      </div>
      <div class="oc-event highlight reveal">
        <div class="oc-event-date">Ahora</div>
        <div class="oc-event-text">247K stars, fundación independiente, respaldado por OpenAI. El futuro de los agentes personales de IA.</div>
      </div>
    </div>

    <div class="oc-pillars">
      <div class="oc-pillar reveal">
        <div class="oc-pillar-icon" style="animation-delay:0s">🧠</div>
        <h3>No chatea. Ejecuta.</h3>
        <p>A diferencia de ChatGPT, OpenClaw tiene "manos": navega la web, gestiona archivos, envía emails, organiza tu calendario. Actúa, no solo responde.</p>
      </div>
      <div class="oc-pillar reveal">
        <div class="oc-pillar-icon" style="animation-delay:0.3s">🏠</div>
        <h3>Vive en tu servidor</h3>
        <p>Tu agente corre en tu VPS. Tus datos nunca salen de ahí. Si OpenClaw desaparece mañana, tu agente sigue funcionando. Es tuyo.</p>
      </div>
      <div class="oc-pillar reveal">
        <div class="oc-pillar-icon" style="animation-delay:0.6s">👥</div>
        <h3>Multi-agente</h3>
        <p>No solo un agente: un equipo entero. Agente de ventas, de soporte, personal, de contenido... cada uno con su personalidad y memoria aislada.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ PROBLEMA ═════════════════════════════════ -->
<section class="section-problem reveal">
  <div class="container text-center">
    <div class="badge badge-warn">⚠️ El problema</div>
    <h2 class="section-title" style="max-width:640px;margin:0 auto 1rem;">
      La IA promete mucho. Pero la realidad es más dura.
    </h2>
    <p class="section-lead" style="max-width:640px;margin:0 auto 2rem;">
      Llevas meses viendo demos increíbles de agentes IA. Pero cuando intentas montarlo tú solo...
    </p>
    <div class="problem-list">
      <div class="problem-item">
        <span class="problem-icon">❌</span>
        <div>
          <strong>Tutoriales en inglés, desactualizados o rotos</strong>
          <p>Empiezas a seguir uno y a los 20 minutos ya hay algo que no funciona igual en tu máquina.</p>
        </div>
      </div>
      <div class="problem-item">
        <span class="problem-icon">❌</span>
        <div>
          <strong>Horas perdidas en configuraciones que no arrancan</strong>
          <p>Docker, VPS, SSH, puertos, APIs... cada cosa que tocas abre tres problemas nuevos.</p>
        </div>
      </div>
      <div class="problem-item">
        <span class="problem-icon">❌</span>
        <div>
          <strong>Nadie que te ayude cuando te atascas</strong>
          <p>Preguntas en Reddit o Discord y o no te responden o te tratan como si supieras lo mismo que ellos.</p>
        </div>
      </div>
      <div class="problem-item">
        <span class="problem-icon">❌</span>
        <div>
          <strong>Miedo a que tus datos acaben en servidores de terceros</strong>
          <p>ChatGPT, Claude, Notion AI... todo pasa por sus servidores. Tus datos, tus conversaciones, tu negocio.</p>
        </div>
      </div>
    </div>
    <div class="problem-close">
      <p>El resultado: <strong>pasas semanas intentándolo sin llegar a ningún lado</strong>, o directamente lo abandonas.</p>
      <p>Nosotros hemos pasado por eso. Por eso existe TribuClaw.</p>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ SOLUCIÓN ═════════════════════════════════ -->
<section class="section-solution reveal" style="background:#161b22;">
  <div class="container text-center">
    <div class="badge badge-green">✅ La solución</div>
    <h2 class="section-title" style="max-width:640px;margin:0 auto 1rem;">
      Un comando. 8 minutos. Tu agente listo.
    </h2>
    <p class="section-lead" style="max-width:600px;margin:0 auto 2.5rem;">
      TribuClaw te da el instalador, el curso, la comunidad y el soporte para que <strong>nunca te quedes atascado</strong>.
    </p>
    <div class="pillars">
      <div class="pillar-card">
        <div class="pillar-icon">⚡</div>
        <h3>Instalación automática</h3>
        <p>Un script instala todo: servidor seguro, OpenClaw, firewall, memoria persistente y bot de Telegram. Sin tocar nada a mano.</p>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">🇪🇸</div>
        <h3>Comunidad en español</h3>
        <p>Directos semanales, soporte 24/7 con TribuBot, y yo (Álvaro) respondiendo personalmente. Sin barreras de idioma.</p>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">🔐</div>
        <h3>100% tus datos</h3>
        <p>Tu agente corre en tu VPS. Tus datos nunca salen de tu servidor. Control total desde el minuto uno.</p>
      </div>
    </div>
    <div style="margin-top:2.5rem;">
      <a href={WHOP_URL} class="cta-btn" target="_blank" rel="noopener">
        <span class="cta-main">Quiero mi agente →</span>
        <span class="cta-sub-line">Prueba gratis 1 día</span>
      </a>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ TELEGRAM MOCKUP ══════════════════════════ -->
<section class="section-telegram reveal">
  <div class="container">
    <div class="tg-layout">
      <div class="tg-text">
        <div class="badge badge-green">🤖 Tu agente en acción</div>
        <h2 class="section-title" style="text-align:left;">
          Habla con tu agente<br/>como con un humano
        </h2>
        <p class="section-lead" style="text-align:left;">
          Tu agente entiende el contexto, recuerda lo anterior y actúa de forma autónoma. No es un chatbot: es tu asistente personal que trabaja 24/7.
        </p>
        <ul class="tg-features">
          <li>✅ Gestiona emails y respuestas</li>
          <li>✅ Prepara briefings diarios</li>
          <li>✅ Recuerda todo lo que le cuentas</li>
          <li>✅ Ejecuta tareas sin que se las repitas</li>
        </ul>
      </div>
      <div class="tg-phone-wrap">
        <div class="tg-phone-glow">
          <div class="tg-phone">
            <!-- Status bar -->
            <div class="tg-status-bar">
              <span class="tg-time">9:41</span>
              <div class="tg-status-right">
                <div class="tg-signal">
                  <span></span><span></span><span></span><span></span>
                </div>
                <span class="tg-network">5G</span>
                <div class="tg-battery">
                  <div class="tg-battery-fill"></div>
                </div>
              </div>
            </div>
            <!-- Chat header -->
            <div class="tg-chat-header">
              <span class="tg-back">‹</span>
              <div class="tg-avatar">
                <img src="/images/logo-icon.png" width="32" height="32" alt="Agente" style="border-radius:50%;object-fit:cover;" />
              </div>
              <div class="tg-contact">
                <span class="tg-contact-name">Mi Agente IA</span>
                <span class="tg-contact-status">online</span>
              </div>
              <div class="tg-header-icons">
                <svg width="18" height="18" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 5.18 2 2 0 014.98 3h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L9.91 10.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 18z"/></svg>
                <svg width="18" height="18" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
              </div>
            </div>
            <!-- Messages -->
            <div class="tg-messages">
              <!-- Mensaje 1: agente -->
              <div class="tg-msg tg-msg-in" style="animation-delay:0.5s;">
                <div class="tg-bubble tg-bubble-in">
                  Buenos días 👋 Aquí tu briefing: 3 emails nuevos, 1 propuesta urgente de cliente. Tu reunión de las 15:00 está confirmada. ¿Quieres que prepare notas?
                  <span class="tg-msg-time">9:41</span>
                </div>
              </div>
              <!-- Mensaje 2: usuario -->
              <div class="tg-msg tg-msg-out" style="animation-delay:2s;">
                <div class="tg-bubble tg-bubble-out">
                  Sí, prepara notas y borradores de respuesta para los emails
                  <span class="tg-msg-time">9:42</span>
                </div>
              </div>
              <!-- Typing dots -->
              <div class="tg-msg tg-msg-in typing-wrap" style="animation-delay:2.8s;">
                <div class="tg-bubble tg-bubble-in typing-bubble">
                  <div class="typing-dots">
                    <span></span><span></span><span></span>
                  </div>
                </div>
              </div>
              <!-- Mensaje 3: agente -->
              <div class="tg-msg tg-msg-in" style="animation-delay:3.5s;">
                <div class="tg-bubble tg-bubble-in">
                  Hecho ✅ Notas en tu workspace y 3 borradores listos para revisar. ¿Los envío o los ajusto primero?
                  <span class="tg-msg-time">9:42</span>
                </div>
              </div>
            </div>
            <!-- Input bar -->
            <div class="tg-input-bar">
              <div class="tg-input-field">
                <span class="tg-input-placeholder">Escribe un mensaje...</span>
              </div>
              <div class="tg-send-btn">
                <svg width="16" height="16" fill="white" viewBox="0 0 24 24"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ QUÉ INCLUYE ══════════════════════════════ -->
<section class="section-includes reveal" id="incluye" style="background:#161b22;">
  <div class="container text-center">
    <div class="badge badge-accent">📦 Todo lo que obtienes</div>
    <h2 class="section-title">Una membresía. Todo lo que necesitas.</h2>
    <p class="section-lead" style="max-width:560px;margin:0 auto 2.5rem;">
      No vendemos solo acceso. Vendemos resultados.
    </p>
    <div class="includes-grid">
      <div class="include-card">
        <div class="include-icon" style="animation-delay:0s;">⚡</div>
        <h3>Instalador de primer agente</h3>
        <p>Un comando instala servidor seguro, OpenClaw, firewall, fail2ban, memoria y servicio automático. 8 minutos.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:0.3s;">➕</div>
        <h3>Instalador de agentes adicionales</h3>
        <p>¿Quieres un agente de ventas, otro de soporte, otro personal? 30 segundos para añadir uno nuevo.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:0.6s;">🎓</div>
        <h3>Curso actualizado con vídeos</h3>
        <p>Lecciones de apoyo en vídeo. Actualizado constantemente con las últimas novedades de OpenClaw.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:0.9s;">📡</div>
        <h3>Directos cada miércoles 19:00</h3>
        <p>Q&amp;A en vivo conmigo. Troubleshooting, estrategia, casos de uso. Todas las semanas.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:1.2s;">🤖</div>
        <h3>TribuBot 24/7</h3>
        <p>Bot de soporte IA entrenado para TribuClaw. Resuelve tus dudas a cualquier hora, cualquier día.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:1.5s;">👨‍💻</div>
        <h3>Soporte personal de Álvaro</h3>
        <p>No estás solo. Yo estoy en la comunidad respondiendo personalmente.</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:1.8s;">📋</div>
        <h3>Casos de uso semanales</h3>
        <p>Cada semana, nuevos workflows para diferentes sectores. Coaching, e-commerce, freelance, SaaS...</p>
      </div>
      <div class="include-card">
        <div class="include-icon" style="animation-delay:2.1s;">🔐</div>
        <h3>Seguridad enterprise incluida</h3>
        <p>Firewall, fail2ban, hardening SSH. Tu agente protegido desde el minuto uno.</p>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<!-- ═══════════════════════════════════ COMPARATIVA ══════════════════════════════ -->
<section class="section-compare reveal">
  <div class="container text-center">
    <div class="badge badge-accent">📊 Comparativa</div>
    <h2 class="section-title">TribuClaw vs las alternativas</h2>
    <div class="compare-table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th></th>
            <th class="col-highlight">TribuClaw</th>
            <th>Hacerlo solo</th>
            <th>Managed</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Instalación</td>
            <td class="col-highlight accent-text">8 min (auto)</td>
            <td>Horas/días</td>
            <td>Lo hacen ellos</td>
          </tr>
          <tr>
            <td>Precio</td>
            <td class="col-highlight accent-text">35€/mes</td>
            <td>Tu tiempo</td>
            <td>100-200€/mes</td>
          </tr>
          <tr>
            <td>Idioma</td>
            <td class="col-highlight accent-text">🇪🇸 Español</td>
            <td>🇬🇧 Inglés</td>
            <td>🇬🇧 Inglés</td>
          </tr>
          <tr>
            <td>Control datos</td>
            <td class="col-highlight accent-text">100% tuyo</td>
            <td>100% tuyo</td>
            <td>Sus servidores</td>
          </tr>
          <tr>
            <td>Soporte</td>
            <td class="col-highlight accent-text">24/7 bot + humano</td>
            <td>Stack Overflow</td>
            <td>Email</td>
          </tr>
          <tr>
            <td>Más agentes</td>
            <td class="col-highlight accent-text">30 segundos</td>
            <td>Config manual</td>
            <td>Extra $$</td>
          </tr>
          <tr>
            <td>Si te vas</td>
            <td class="col-highlight accent-text">Tu agente sigue</td>
            <td>Tu agente sigue</td>
            <td>Pierdes todo</td>
          </tr>
        </tbody>
      </table>
    </div>
    <!-- Mobile cards -->
    <div class="compare-mobile">
      <div class="compare-row">
        <span class="compare-feature">Instalación</span>
        <div class="compare-vals">
          <span><strong class="accent-text">TribuClaw:</strong> 8 min (auto)</span>
          <span><strong>Solo:</strong> Horas/días</span>
          <span><strong>Managed:</strong> Lo hacen ellos</span>
        </div>
      </div>
      <div class="compare-row">
        <span class="compare-feature">Precio</span>
        <div class="compare-vals">
          <span><strong class="accent-text">TribuClaw:</strong> 35€/mes</span>
          <span><strong>Solo:</strong> Tu tiempo</span>
          <span><strong>Managed:</strong> 100-200€/mes</span>
        </div>
      </div>
      <div class="compare-row">
        <span class="compare-feature">Idioma</span>
        <div class="compare-vals">
          <span><strong class="accent-text">TribuClaw:</strong> 🇪🇸 Español</span>
          <span><strong>Solo:</strong> 🇬🇧 Inglés</span>
          <span><strong>Managed:</strong> 🇬🇧 Inglés</span>
        </div>
      </div>
      <div class="compare-row">
        <span class="compare-feature">Control datos</span>
        <div class="compare-vals">
          <span><strong class="accent-text">TribuClaw:</strong> 100% tuyo</span>
          <span><strong>Solo:</strong> 100% tuyo</span>
          <span><strong>Managed:</strong> Sus servidores</span>
        </div>
      </div>
      <div class="compare-row">
        <span class="compare-feature">Soporte</span>
        <div class="compare-vals">
          <span><strong class="accent-text">TribuClaw:</strong> 24/7 bot + humano</span>
          <span><strong>Solo:</strong> Stack Overflow</span>
          <span><strong>Managed:</strong> Email</span>
        </div>
