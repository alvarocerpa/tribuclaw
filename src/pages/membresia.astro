  .b1 { width: 80px; height: 80px; left: 5%; top: 20%; animation-duration: 18s; animation-delay: 0s; }
  .b2 { width: 120px; height: 120px; left: 80%; top: 10%; animation-duration: 22s; animation-delay: -5s; }
  .b3 { width: 60px; height: 60px; left: 60%; top: 60%; animation-duration: 15s; animation-delay: -8s; }
  .b4 { width: 40px; height: 40px; left: 20%; top: 70%; animation-duration: 20s; animation-delay: -3s; }
  .b5 { width: 100px; height: 100px; left: 40%; top: 80%; animation-duration: 25s; animation-delay: -12s; }
  .b6 { width: 50px; height: 50px; left: 90%; top: 50%; animation-duration: 17s; animation-delay: -7s; }
  @keyframes bubbleFloat {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    50% { opacity: 0.3; }
    100% { transform: translateY(-80px) rotate(180deg); opacity: 0.6; }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(233,69,96,0.1);
    border: 1px solid rgba(233,69,96,0.25);
    color: #e94560;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .hero-headline {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .glow-text {
    animation: glowText 3s ease-in-out infinite;
    display: inline-block;
  }
  @keyframes glowText {
    0%, 100% { text-shadow: 0 0 40px rgba(233,69,96,0.4); }
    50% { text-shadow: 0 0 80px rgba(233,69,96,0.7), 0 0 120px rgba(233,69,96,0.3); }
  }
  .hero-sub {
    max-width: 560px;
    margin: 0 auto 2rem;
    color: #8b949e;
    font-size: 1.05rem;
  }
  .social-proof {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    animation: textDrift 4s ease-in-out infinite;
  }
  .stars-row { color: #e94560; font-size: 1rem; letter-spacing: 2px; }
  .proof-text { color: #484f58; font-size: 0.8rem; }
  @keyframes textDrift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  /* ─── SECTION DIVIDER ─── */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(233,69,96,0.3), transparent);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ─── REVEAL ANIMATION ─── */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }
  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── SECTIONS COMMON ─── */
  section { padding: 5rem 0; }

  /* ─── VIDEO ─── */
  .section-video { background: #161b22; text-align: center; }
  .section-video .section-title { margin-bottom: 0.75rem; }
  .video-wrap {
    max-width: 720px;
    margin: 2rem auto 0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(233,69,96,0.2), 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(233,69,96,0.1);
    animation: videoBorderPulse 3s ease-in-out infinite;
  }
  @keyframes videoBorderPulse {
    0%, 100% { box-shadow: 0 0 0 1px rgba(233,69,96,0.2), 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(233,69,96,0.1); }
    50% { box-shadow: 0 0 0 2px rgba(233,69,96,0.4), 0 20px 60px rgba(0,0,0,0.5), 0 0 60px rgba(233,69,96,0.2); }
  }

  /* ─── VIDEO PLAY OVERLAY ─── */
  /* Video nativo — sin overlay custom */

  /* ─── SECTION OPENCLAW ─── */
  .section-openclaw { padding: 5rem 0; background: #161b22; }
  .oc-stats-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .oc-stat { text-align: center; }
  .oc-stat-number {
    display: block;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: #e94560;
    line-height: 1.1;
  }
  .oc-stat-label {
    display: block;
    font-size: 0.85rem;
    color: #8b949e;
    margin-top: 0.25rem;
  }
  .oc-stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.08);
  }

  .oc-timeline {
    max-width: 600px;
    margin: 0 auto 3rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    position: relative;
    padding-left: 2rem;
    border-left: 2px solid rgba(233,69,96,0.2);
  }
  .oc-event {
    position: relative;
    padding: 1rem 0 1rem 1.5rem;
  }
  .oc-event::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 1.35rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #484f58;
    border: 2px solid #0d1117;
    transform: translateX(-50%);
    margin-left: -1px;
  }
  .oc-event.highlight::before {
    background: #e94560;
    box-shadow: 0 0 12px rgba(233,69,96,0.5);
  }
  .oc-event-date {
    font-size: 0.8rem;
    font-weight: 700;
    color: #e94560;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }
  .oc-event-text {
    font-size: 0.95rem;
    color: #c9d1d9;
    line-height: 1.6;
    text-align: left;
  }
  .oc-event.highlight .oc-event-text { color: #fff; font-weight: 600; }

  .oc-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .oc-pillar {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .oc-pillar:hover {
    transform: translateY(-4px);
    border-color: rgba(233,69,96,0.2);
    box-shadow: 0 8px 30px rgba(233,69,96,0.08);
  }
  .oc-pillar-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    display: block;
    animation: floatSlow 4s ease-in-out infinite;
  }
  .oc-pillar h3 {
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.75rem;
  }
  .oc-pillar p {
    font-size: 0.9rem;
    color: #8b949e;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 720px) {
    .oc-pillars { grid-template-columns: 1fr; }
    .oc-stats-row { gap: 1.5rem; }
    .oc-stat-divider { display: none; }
    .oc-timeline { padding-left: 1.5rem; }
  }

  /* ─── PROBLEM ─── */
  .section-problem { background: #0d1117; }
  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto 2rem;
    text-align: left;
  }
  .problem-item {
    display: flex;
    gap: 1rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    transition: border-color 0.2s;
  }
  .problem-item:hover { border-color: rgba(233,69,96,0.3); }
  .problem-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
  .problem-item strong { display: block; margin-bottom: 0.25rem; font-weight: 700; }
  .problem-item p { color: #8b949e; font-size: 0.9rem; margin: 0; }
  .problem-close {
    max-width: 640px;
    margin: 0 auto;
    background: rgba(233,69,96,0.04);
    border: 1px solid rgba(233,69,96,0.15);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    color: #8b949e;
  }
  .problem-close p:first-child { margin-bottom: 0.5rem; }

  /* ─── SOLUTION ─── */
  .section-solution { background: #161b22; }
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .pillar-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 1.75rem;
    text-align: left;
    transition: transform 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
  }
  .pillar-card:hover {
    transform: translateY(-6px);
    border-color: rgba(233,69,96,0.3);
  }
  .pillar-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    display: block;
    animation: floatSlow 4s ease-in-out infinite;
  }
  .pillar-card h3 { font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; }
  .pillar-card p { color: #8b949e; font-size: 0.9rem; }
  @keyframes floatSlow { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @keyframes floatMed { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }

  /* ─── TELEGRAM MOCKUP ─── */
  .section-telegram { background: #0d1117; }
  .tg-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .tg-text .section-title { margin-bottom: 1rem; }
  .tg-features {
    list-style: none;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tg-features li { color: #8b949e; font-size: 0.95rem; }
  .tg-phone-wrap {
    display: flex;
    justify-content: center;
  }
  .tg-phone-glow {
    background: linear-gradient(rgba(0,255,65,0.6), rgba(0,255,65,0.1) 30%, transparent 60%);
    border-radius: 43px;
    padding: 3px;
    position: relative;
    box-shadow: 0 -8px 40px -10px rgba(0,255,65,0.25);
  }
  .tg-phone {
    width: 280px;
    min-height: 560px;
    background: #0e1621;
    border: 3px solid #2a2a2e;
    border-radius: 40px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.08),
      0 30px 80px rgba(0,0,0,0.6);
    position: relative;
  }
  /* Status bar */
  .tg-status-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px 4px;
    font-size: 10px;
    font-weight: 700;
    color: white;
  }
  .tg-status-right { display: flex; align-items: center; gap: 4px; }
  .tg-signal { display: flex; align-items: flex-end; gap: 1px; }
  .tg-signal span {
    width: 3px;
    background: white;
    border-radius: 1px;
  }
  .tg-signal span:nth-child(1) { height: 4px; }
  .tg-signal span:nth-child(2) { height: 6px; }
  .tg-signal span:nth-child(3) { height: 9px; }
  .tg-signal span:nth-child(4) { height: 12px; }
  .tg-network { font-size: 9px; font-weight: 700; }
  .tg-battery {
    width: 20px; height: 10px;
    border: 1.5px solid white;
    border-radius: 2px;
    padding: 1px;
    position: relative;
  }
  .tg-battery::after {
    content: '';
    position: absolute;
    right: -4px;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 5px;
    background: white;
    border-radius: 0 1px 1px 0;
  }
  .tg-battery-fill {
    width: 75%;
    height: 100%;
    background: white;
    border-radius: 1px;
  }
  /* Chat header */
  .tg-chat-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px 10px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .tg-back { color: #4dabf7; font-size: 18px; cursor: pointer; }
  .tg-avatar { flex-shrink: 0; }
  .tg-contact { flex: 1; }
  .tg-contact-name { display: block; font-size: 12px; font-weight: 700; color: white; }
  .tg-contact-status { font-size: 10px; color: #14b8a6; }
  .tg-header-icons { display: flex; gap: 10px; }
  /* Messages area */
  .tg-messages {
    flex: 1;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow: hidden;
  }
  @keyframes telegram-msg-in {
    from { opacity: 0; transform: translateY(8px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .tg-msg {
    display: flex;
    animation: telegram-msg-in 0.3s ease-out both;
    opacity: 0;
  }
  .tg-msg-in { justify-content: flex-start; }
  .tg-msg-out { justify-content: flex-end; }
  .tg-bubble {
    max-width: 85%;
    padding: 7px 10px;
    border-radius: 12px;
    font-size: 11px;
    line-height: 1.45;
    position: relative;
  }
  .tg-bubble-in {
    background: #182533;
    color: rgba(255,255,255,0.9);
    border-bottom-left-radius: 4px;
  }
  .tg-bubble-out {
    background: #2b5278;
    color: white;
    border-bottom-right-radius: 4px;
  }
  .tg-msg-time {
    display: block;
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    text-align: right;
    margin-top: 3px;
  }
  /* Typing */
  .typing-bubble { padding: 10px 14px; }
  .typing-dots { display: flex; gap: 4px; align-items: center; }
  .typing-dots span {
    width: 6px;
    height: 6px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
    display: inline-block;
    animation: typingBounce 1.4s ease-in-out infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }
  /* Input */
  .tg-input-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px 12px;
    background: #17212b;
  }
  .tg-input-field {
    flex: 1;
    background: #242f3d;
    border-radius: 16px;
    padding: 7px 12px;
  }
  .tg-input-placeholder { color: rgba(255,255,255,0.3); font-size: 11px; }
  .tg-send-btn {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #e94560, #ff6b6b);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
  }

  /* ─── INCLUDES ─── */
  .section-includes { background: #161b22; }
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .include-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    padding: 1.5rem 1.25rem;
    text-align: left;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .include-card:hover {
    transform: translateY(-4px);
    border-color: rgba(233,69,96,0.3);
    box-shadow: 0 8px 30px rgba(233,69,96,0.1);
  }
  .include-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
    animation: floatSlow 4s ease-in-out infinite;
  }
  .include-card:nth-child(2) .include-icon { animation-name: floatMed; animation-delay: 0.5s; }
  .include-card:nth-child(3) .include-icon { animation-delay: 1s; }
  .include-card:nth-child(4) .include-icon { animation-name: floatMed; animation-delay: 1.5s; }
  .include-card:nth-child(5) .include-icon { animation-delay: 0.3s; }
  .include-card:nth-child(6) .include-icon { animation-name: floatMed; animation-delay: 0.8s; }
  .include-card:nth-child(7) .include-icon { animation-delay: 1.3s; }
  .include-card:nth-child(8) .include-icon { animation-name: floatMed; animation-delay: 1.8s; }
  .include-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.4rem; }
  .include-card p { color: #8b949e; font-size: 0.82rem; line-height: 1.5; }

  /* ─── COMPARE ─── */
  .section-compare { background: #0d1117; }
  .compare-table-wrap {
    overflow-x: auto;
    max-width: 700px;
    margin: 2.5rem auto 0;
    display: flex;
    justify-content: center;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 0 auto;
  }
  .compare-table th, .compare-table td {
    padding: 0.85rem 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .compare-table th {
    font-weight: 700;
    color: #8b949e;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .col-highlight {
    background: rgba(233,69,96,0.05);
    border-left: 1px solid rgba(233,69,96,0.15);
    border-right: 1px solid rgba(233,69,96,0.15);
  }
  th.col-highlight {
    color: #e94560 !important;
    border-top: 1px solid rgba(233,69,96,0.15);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
  }
  .compare-table td:first-child { color: #8b949e; }
  .compare-mobile { display: none; }

  /* ─── REVIEWS ─── */
  .section-reviews { background: #161b22; }
  /* ─── Testimonial destacado ─── */
  .review-featured {
    max-width: 580px;
    margin: 2rem auto;
    background: rgba(233,69,96,0.04);
    border: 1px solid rgba(233,69,96,0.15);
    border-radius: 16px;
    padding: 2rem 2.5rem;
    text-align: center;
  }
  .review-quote {
    font-size: 1.1rem;
    color: #c9d1d9;
    font-style: italic;
    line-height: 1.7;
    position: relative;
  }
  .review-quote-mark {
    font-size: 3rem;
    color: #e94560;
    line-height: 0;
    vertical-align: -0.4em;
    margin-right: 0.1rem;
    font-style: normal;
  }
  .review-author-featured {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .review-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
  }
  .review-stars-sm { color: #e94560; font-size: 0.8rem; }
  .review-avatar {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, #e94560, #ff6b6b);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ─── Rating strip ─── */
  .ratings-strip {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .rating-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 100px;
    padding: 0.4rem 1rem 0.4rem 0.4rem;
  }
  .chip-avatar {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, #e94560, #ff6b6b);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .chip-name { font-size: 0.8rem; font-weight: 600; color: #c9d1d9; }
  .chip-stars { font-size: 0.7rem; color: #e94560; }
  .member-counter {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .counter-number {
    font-size: 4rem;
    font-weight: 900;
    color: #e94560;
    letter-spacing: -0.04em;
    line-height: 1;
    text-shadow: 0 0 40px rgba(233,69,96,0.4);
  }
  .counter-label { color: #8b949e; font-size: 1rem; }

  /* ─── COST ─── */
  .section-cost { background: #0d1117; }
  .cost-wrap {
    max-width: 520px;
    margin: 2rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .cost-table {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    overflow: hidden;
  }
  .cost-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    font-size: 0.9rem;
  }
  .cost-row:last-child { border-bottom: none; }
  .cost-total {
    background: rgba(233,69,96,0.05);
