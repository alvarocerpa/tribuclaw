---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { WHOP_URL, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, tags, faq } = Astro.props;
const articleUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<html lang="es">
<head>
  <BaseHead title={`${title} | TribuClaw`} description={description} type="article" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "author": { "@type": "Person", "name": author || "Álvaro Cerpa", "url": "https://www.linkedin.com/in/alvaro-cerpa/" },
    "publisher": {
      "@type": "Organization",
      "name": "TribuClaw",
      "logo": { "@type": "ImageObject", "url": SITE_URL + "/images/logo-icon.webp" }
    },
    "datePublished": pubDate.toISOString(),
    "dateModified": (updatedDate || pubDate).toISOString(),
    "mainEntityOfPage": articleUrl,
    "image": SITE_URL + "/images/og-default.jpg",
    "inLanguage": "es"
  })} />
  {faq && faq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map((f: {q: string; a: string}) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE_URL },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": SITE_URL + "/blog/" },
      { "@type": "ListItem", "position": 3, "name": title, "item": articleUrl }
    ]
  })} />
  <style>
    .prose {
      width: 768px;
      max-width: calc(100% - 2rem);
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    .article-header {
      margin-bottom: 3rem;
    }

    .breadcrumb {
      font-size: 0.8rem;
      color: rgba(250,250,250,0.25);
      margin-bottom: 2rem;
      display: flex;
      gap: 0.35rem;
    }
    .breadcrumb a {
      color: rgba(250,250,250,0.4);
      text-decoration: none;
      transition: color 0.2s;
    }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb span { color: rgba(250,250,250,0.2); }

    .article-header h1 {
      font-size: clamp(2rem, 5vw, 2.8rem);
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin: 0 0 1rem 0;
      color: #fff;
    }

    .meta-inline {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: rgba(250,250,250,0.35);
      font-size: 0.875rem;
      margin-bottom: 2rem;
    }
    .meta-sep { color: rgba(250,250,250,0.15); }

    .hero-img {
      width: 100%;
      border-radius: 12px;
      margin-top: 2rem;
      margin-bottom: 1rem;
    }

    .tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
    }
    .tag {
      color: rgba(250,250,250,0.4);
      font-size: 0.75rem;
      font-weight: 500;
    }

    /* Blog body typography */
    .prose :global(p) {
      font-size: 1.0625rem;
      line-height: 1.8;
      margin-bottom: 1.5rem;
      color: rgba(250,250,250,0.75);
    }
    .prose :global(h2) {
      font-size: 1.6rem;
      font-weight: 800;
      margin-top: 3rem;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .prose :global(h3) {
      font-size: 1.25rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
    }
    .prose :global(ul),
    .prose :global(ol) {
      margin-bottom: 1.5rem;
      color: rgba(250,250,250,0.75);
      font-size: 1.0625rem;
    }
    .prose :global(li) {
      margin-bottom: 0.5rem;
      line-height: 1.7;
    }
    .prose :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0 0 0 1.25rem;
      margin: 2rem 0;
      color: rgba(250,250,250,0.5);
      font-size: 1.0625rem;
    }
    .prose :global(pre) {
      margin: 2rem 0;
    }
    .prose :global(img) {
      border-radius: 8px;
      margin: 2rem 0;
    }

    /* FAQ section */
    .faq-section {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
    .faq-section h2 {
      font-size: 1.4rem;
      margin-bottom: 2rem;
      font-weight: 800;
    }
    .faq-item { margin-bottom: 2rem; }
    .faq-item h3 {
      font-size: 1.05rem;
      color: #fff;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }
    .faq-item p {
      color: var(--text-muted);
      font-size: 1rem;
      line-height: 1.7;
    }

    /* Author — minimal inline */
    .author-line {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      font-size: 0.9rem;
      color: rgba(250,250,250,0.4);
    }
    .author-line a {
      color: rgba(250,250,250,0.6);
      text-decoration: none;
    }
    .author-line a:hover { color: var(--accent); }

    /* Bottom CTA — clean inline */
    .cta-inline {
      margin-top: 2rem;
      font-size: 1.05rem;
      line-height: 1.7;
      color: rgba(250,250,250,0.6);
    }
    .cta-inline a {
      color: var(--accent);
      font-weight: 600;
      text-decoration: none;
      transition: color 0.2s;
    }
    .cta-inline a:hover { color: var(--accent-light); }

    @media (max-width: 640px) {
      .prose { padding: 1.5rem 1.25rem; }
      .article-header h1 { font-size: 1.75rem; }
    }
  </style>
</head>

<body>
  <Header />
  <main id="main-content">
    <article class="prose">
        <!-- Breadcrumbs -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span class="meta-sep">›</span>
          <a href="/blog/">Blog</a>
          <span class="meta-sep">›</span>
          <span>{title}</span>
        </nav>

        <div class="article-header">
          <h1>{title}</h1>
          <div class="meta-inline">
            <span>{author || 'Álvaro Cerpa'}</span>
            <span class="meta-sep">·</span>
            <span><FormattedDate date={pubDate} /></span>
            {updatedDate && (
              <>
                <span class="meta-sep">·</span>
                <span>Actualizado: <FormattedDate date={updatedDate} /></span>
              </>
            )}
          </div>
          {heroImage && (
            <img src={heroImage} alt={title} class="hero-img" width="768" height="403" fetchpriority="high" />
          )}
          {tags && tags.length > 0 && (
            <div class="tags">
              {tags.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>

        <slot />

        {faq && faq.length > 0 && (
          <section class="faq-section">
            <h2>Preguntas frecuentes</h2>
            {faq.map((f: {q: string; a: string}) => (
              <div class="faq-item">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </div>
            ))}
          </section>
        )}

        <!-- Author — minimal -->
        <div class="author-line">
          Escrito por <a href="https://www.linkedin.com/in/alvaro-cerpa/" target="_blank" rel="noopener noreferrer">Álvaro Cerpa</a> · Fundador de TribuClaw
        </div>

        <!-- Bottom CTA — clean inline -->
        <p class="cta-inline">
          ¿Listo para tener tu propio agente IA? <a href={WHOP_URL} target="_blank">Únete a TribuClaw →</a>
        </p>

        <RelatedPosts currentTags={tags || []} currentId={Astro.url.pathname.split('/').filter(Boolean).pop() || ''} />
    </article>
  </main>
  <Footer />
</body>
</html>
