---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { WHOP_URL, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, tags, faq } = Astro.props;
const articleUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<html lang="es">
	<head>
		<BaseHead title={`${title} | TribuClaw`} description={description} type="article" />
		<!-- Article Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Article",
			"headline": title,
			"description": description,
			"author": { "@type": "Person", "name": author || "Álvaro Cerpa", "url": "https://www.linkedin.com/in/alvaro-cerpa/", "sameAs": ["https://www.linkedin.com/in/alvaro-cerpa/"] },
			"publisher": {
				"@type": "Organization",
				"name": "TribuClaw",
				"logo": { "@type": "ImageObject", "url": SITE_URL + "/images/logo-icon.png" }
			},
			"datePublished": pubDate.toISOString(),
			"dateModified": (updatedDate || pubDate).toISOString(),
			"mainEntityOfPage": articleUrl,
			"image": SITE_URL + "/images/og-default.jpg",
			"inLanguage": "es"
		})} />
		<!-- FAQ Schema -->
		{faq && faq.length > 0 && (
			<script type="application/ld+json" set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "FAQPage",
				"mainEntity": faq.map((f: {q: string; a: string}) => ({
					"@type": "Question",
					"name": f.q,
					"acceptedAnswer": { "@type": "Answer", "text": f.a }
				}))
			})} />
		)}
		<!-- BreadcrumbList Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BreadcrumbList",
			"itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE_URL },
				{ "@type": "ListItem", "position": 2, "name": "Blog", "item": SITE_URL + "/blog/" },
				{ "@type": "ListItem", "position": 3, "name": title, "item": articleUrl }
			]
		})} />
		<style>
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			.title {
				margin-bottom: 1.5em;
				padding: 1em 0;
				position: relative;
			}
			.title::before {
				content: '';
				position: absolute;
				top: -100px;
				left: 50%;
				transform: translateX(-50%);
				width: 600px;
				height: 400px;
				background: radial-gradient(ellipse at center, rgba(233,69,96,0.07) 0%, transparent 65%);
				pointer-events: none;
				z-index: 0;
			}
			.title > * { position: relative; z-index: 1; }
			.title h1 { margin: 0 0 0.5em 0; font-size: 2.2rem; line-height: 1.2; }
			.meta { color: #484f58; font-size: 0.9rem; margin-bottom: 0.5rem; }
			.breadcrumb { font-size: 0.85rem; color: #484f58; margin-bottom: 1rem; }
			.breadcrumb a { color: #8b949e; }
			.breadcrumb a:hover { color: #e94560; }
			.tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }
			.tag { background: rgba(255,255,255,0.04); color: #8b949e; padding: 0.2rem 0.65rem; border-radius: 4px; font-size: 0.8rem; }
			.faq-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.06); }
			.faq-section h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
			.faq-item { margin-bottom: 1.5rem; }
			.faq-item h3 { font-size: 1.05rem; color: #fff; margin-bottom: 0.4rem; }
			.faq-item p { color: #8b949e; font-size: 0.95rem; }
			.author-bio {
				display: flex; gap: 1.25rem; align-items: flex-start;
				margin: 2.5rem 0; padding: 1.5rem;
				background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px;
			}
			.author-bio-avatar {
				width: 52px; height: 52px; border-radius: 50%; flex-shrink: 0;
				background: linear-gradient(135deg, #e94560, #d63851);
				display: flex; align-items: center; justify-content: center;
				font-weight: 700; font-size: 1rem; color: white;
			}
			.author-bio-info { flex: 1; }
			.author-bio-info .name { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.2rem; }
			.author-bio-info .bio-text { color: #8b949e; font-size: 0.875rem; line-height: 1.6; margin: 0 0 0.5rem; }
			.author-bio-info .linkedin-link {
				display: inline-flex; align-items: center; gap: 0.35rem;
				color: #0077b5; font-size: 0.8rem; font-weight: 600;
				text-decoration: none; transition: opacity 0.2s;
			}
			.author-bio-info .linkedin-link:hover { opacity: 0.75; text-decoration: none; }
			@media (max-width: 560px) {
				.author-bio { flex-direction: column; }
			}
			.cta-box {
				margin-top: 3rem; padding: 2rem;
				background: linear-gradient(135deg, rgba(233,69,96,0.1), rgba(233,69,96,0.05));
				border: 1px solid rgba(233,69,96,0.2); border-radius: 12px; text-align: center;
			}
			.cta-box h3 { color: #fff; margin-bottom: 0.5rem; }
			.cta-box p { color: #8b949e; margin-bottom: 1rem; }
			.cta-box a {
				background: #e94560;
				color: white;
				padding: 0.7rem 1.8rem;
				border-radius: 8px;
				font-weight: 700;
				text-decoration: none;
				transition: all 0.2s;
				box-shadow: 0 4px 20px rgba(233,69,96,0.4);
				animation: ctaPulse 2s ease-in-out infinite;
				min-height: 44px;
				min-width: 44px;
				display: inline-flex;
				align-items: center;
				justify-content: center;
			}
			.cta-box a:hover { background: #c23152; text-decoration: none; }
			@keyframes ctaPulse {
				0%, 100% { box-shadow: 0 4px 20px rgba(233,69,96,0.4); }
				50% { box-shadow: 0 6px 30px rgba(233,69,96,0.65); }
			}

			@media (max-width: 720px) {
				.title h1 { font-size: 1.6rem; }
				.prose { padding: 1em 1.25em; }
				.cta-box { padding: 1.5rem; }
				.cta-box h3 { font-size: 1.1rem; }
				.cta-box a { max-width: 280px; margin: 0 auto; }
				.faq-section h2 { font-size: 1.25rem; }
			}
		</style>
	</head>

	<body class="dot-bg">
		<Header />
		<main id="main-content">
			<article>
				<div class="prose">
					<!-- Breadcrumbs -->
					<nav class="breadcrumb" aria-label="Breadcrumb">
						<a href="/">Inicio</a> &rsaquo; <a href="/blog/">Blog</a> &rsaquo; <span>{title}</span>
					</nav>
					<div class="title">
						<div class="meta">
							<FormattedDate date={pubDate} /> &middot; {author || 'Álvaro Cerpa'}
							{updatedDate && (
								<span> &middot; Actualizado: <FormattedDate date={updatedDate} /></span>
							)}
						</div>
						<h1>{title}</h1>
						{heroImage && (
							<img src={heroImage} alt={title} width="720" height="378" style="width:100%;height:auto;border-radius:12px;margin-top:1rem;" fetchpriority="high" />
						)}
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => <span class="tag">{tag}</span>)}
							</div>
						)}
					</div>

					<!-- Article content (H2, H3 structure from MDX) -->
					<slot />

					<!-- FAQ section -->
					{faq && faq.length > 0 && (
						<section class="faq-section">
							<h2>Preguntas frecuentes</h2>
							{faq.map((f: {q: string; a: string}) => (
								<div class="faq-item">
									<h3>{f.q}</h3>
									<p>{f.a}</p>
								</div>
							))}
						</section>
					)}

					<!-- Author Bio -->
					<div class="author-bio">
						<div class="author-bio-avatar">AC</div>
						<div class="author-bio-info">
							<div class="name">Álvaro Cerpa</div>
							<p class="bio-text">Emprendedor digital y fundador de TribuClaw. Lleva meses operando sus negocios con agentes IA y comparte lo que realmente funciona, sin filtros y en español.</p>
							<a href="https://www.linkedin.com/in/alvaro-cerpa/" target="_blank" rel="noopener noreferrer" class="linkedin-link">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="#0077b5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
								linkedin.com/in/alvaro-cerpa
							</a>
						</div>
					</div>

					<!-- Bottom CTA -->
					<div class="cta-box">
						<h3>¿Listo para tener tu propio agente IA?</h3>
						<p>Únete a TribuClaw y aprende paso a paso, con guías en español y una comunidad que te ayuda.</p>
						<a href={WHOP_URL} target="_blank">Unirme a TribuClaw</a>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
