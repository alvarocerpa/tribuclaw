:root {
	--accent: #7C3AED;
	--accent-light: #8B5CF6;
	--accent-cyan: #06B6D4;
	--bg: #050505;
	--bg-alt: #0F0F0F;
	--bg-tertiary: #1A1A2E;
	--text: #F5F5F5;
	--text-muted: rgba(245,245,245,0.5);
	--border: rgba(255,255,255,0.06);
	--border-hover: rgba(124,58,237,0.3);
	--gradient: linear-gradient(135deg, #7C3AED, #06B6D4);
}

*, *::before, *::after {
	box-sizing: border-box;
	margin: 0;
	padding: 0;
}

html {
	overflow-x: hidden;
	scroll-behavior: smooth;
	scroll-padding-top: 80px;
}

body {
	font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
	background: var(--bg);
	color: var(--text);
	font-size: 16px;
	line-height: 1.7;
	font-weight: 400;
	-webkit-font-smoothing: antialiased;
	-moz-osx-font-smoothing: grayscale;
	overflow-x: hidden;
}

a {
	color: var(--accent);
	text-decoration: none;
	transition: color 0.2s;
}
a:hover {
	color: var(--accent-light);
	text-decoration: none;
}

img, svg {
	max-width: 100%;
	height: auto;
	border-radius: 8px;
}

* {
	word-wrap: break-word;
	overflow-wrap: break-word;
}

/* ─── Typography ─── */
h1, h2, h3, h4, h5, h6 {
	color: #fff;
	line-height: 1.2;
	font-weight: 900;
	letter-spacing: -0.03em;
}

p {
	margin-bottom: 1em;
}

strong, b {
	font-weight: 700;
	color: #fff;
}

code {
	padding: 2px 6px;
	background: rgba(255,255,255,0.06);
	border-radius: 4px;
	font-size: 0.9em;
}

pre {
	padding: 1.5em;
	border-radius: 12px;
	background: var(--bg-alt);
	border: 1px solid var(--border);
	overflow-x: auto;
	margin: 1.5rem 0;
}
pre > code { all: unset; }

blockquote {
	border-left: 3px solid var(--accent);
	padding: 0 0 0 1.25rem;
	margin: 1.5rem 0;
	color: var(--text-muted);
}

hr {
	border: none;
	border-top: 1px solid var(--border);
	margin: 2rem 0;
}

ul, ol {
	padding-left: 1.5rem;
}
li {
	margin-bottom: 0.4rem;
}

table {
	width: 100%;
	border-collapse: collapse;
	margin: 1.5rem 0;
	display: block;
	overflow-x: auto;
}
th, td {
	padding: 0.75rem 1rem;
	border: 1px solid var(--border);
	text-align: left;
}
th {
	background: var(--bg-alt);
	color: #fff;
	font-weight: 700;
}

/* ─── Utility ─── */
.sr-only {
	position: absolute !important;
	height: 1px; width: 1px;
	overflow: hidden;
	clip: rect(1px, 1px, 1px, 1px);
	clip-path: inset(50%);
	white-space: nowrap;
}

/* ─── DOT GRID BACKGROUND (REMOVED - minimalismo) ─── */
/* .dot-bg eliminado - fondo plano */

/* ─── BADGE ─── */
.badge-pill {
	display: inline-block;
	padding: 0.35rem 0.9rem;
	border-radius: 999px;
	font-size: 0.75rem;
	font-weight: 700;
	letter-spacing: 0.05em;
	text-transform: uppercase;
	margin-bottom: 1rem;
	background: rgba(233,69,96,0.08);
	color: var(--accent);
	border: 1px solid rgba(233,69,96,0.2);
}

/* ─── SECTION GLOW (REMOVIDO - minimalismo) ─── */
/* .section-glow eliminado - sin glows decorativos */

/* ─── CONTAINER ─── */
.container {
	max-width: 1200px;
	margin: 0 auto;
	padding: 0 1.5rem;
	width: 100%;
}

.container-hero {
	max-width: 1400px;
	margin: 0 auto;
	padding: 0 1.5rem;
	width: 100%;
}

/* ─── GLASS CARD (SIMPLIFICADO) ─── */
.glass-card {
	background: rgba(255,255,255,0.03);
	border: 1px solid var(--border);
	border-radius: 12px;
	position: relative;
	overflow: hidden;
	box-shadow: 0 4px 20px rgba(0,0,0,0.15);
	transition: transform 0.3s ease, border-color 0.3s;
}
.glass-card:hover {
	transform: translateY(-2px);
	border-color: rgba(255,255,255,0.12);
}

/* ─── GRADIENT TEXT ─── */
.gradient-text {
	background: var(--gradient);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}

/* ─── CTA BUTTON ─── */
.cta-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	background: var(--gradient);
	color: #fff;
	font-family: 'Inter', sans-serif;
	font-weight: 700;
	font-size: 0.85rem;
	letter-spacing: 0.01em;
	padding: 0.85rem 2rem;
	border-radius: 12px;
	border: none;
	text-decoration: none;
	cursor: pointer;
	transition: transform 0.2s, box-shadow 0.3s;
	white-space: nowrap;
	box-shadow: 0 0 20px rgba(124, 58, 237, 0.25);
}
.cta-btn:hover {
	transform: translateY(-1px) scale(1.02);
	box-shadow: 0 0 30px rgba(124, 58, 237, 0.4);
	text-decoration: none;
	color: #fff;
}
.cta-btn-lg {
	font-size: 0.95rem;
	padding: 1rem 2.5rem;
	border-radius: 12px;
}

/* ─── SECTION HEADER ─── */
.section-header {
	text-align: center;
	margin-bottom: 3.5rem;
	position: relative;
	z-index: 1;
}
.section-badge {
	display: inline-block;
	padding: 0.35rem 0.9rem;
	border-radius: 999px;
	font-size: 0.75rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	background: rgba(233,69,96,0.08);
	color: var(--accent);
	border: 1px solid rgba(233,69,96,0.2);
	margin-bottom: 1.25rem;
}
.section-title {
	font-size: clamp(1.8rem, 4vw, 2.8rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	line-height: 1.1;
	margin-bottom: 1rem;
}
.section-sub {
	color: var(--text-muted);
	font-size: 1.05rem;
	max-width: 600px;
	margin: 0 auto;
	line-height: 1.7;
}

/* ─── DIVIDER (violet→cyan gradient) ─── */
.section-divider {
	height: 1px;
	background: linear-gradient(90deg, transparent, var(--accent) 30%, var(--accent-cyan) 70%, transparent);
	max-width: 800px;
	margin: 0 auto;
	opacity: 0.4;
}

/* ─── BLOG OVERRIDES ─── */
/* These only apply when body has no dot-bg (blog pages are clean) */
body:not(.dot-bg) {
	background: var(--bg);
	background-image: none;
}

body:not(.dot-bg) .section-glow {
	display: none;
}

/* ─── PRICING CARD GLOW ─── */
.pricing-card-glow {
	border: 1px solid rgba(124,58,237,0.25);
	box-shadow:
		0 0 30px rgba(124,58,237,0.08),
		0 0 60px rgba(124,58,237,0.04);
	animation: pricingGlow 3s ease-in-out infinite alternate;
}
@keyframes pricingGlow {
	0% {
		box-shadow:
			0 0 30px rgba(124,58,237,0.08),
			0 0 60px rgba(124,58,237,0.04);
		border-color: rgba(124,58,237,0.25);
	}
	100% {
		box-shadow:
			0 0 40px rgba(124,58,237,0.15),
			0 0 80px rgba(124,58,237,0.08),
			0 0 120px rgba(6,182,212,0.04);
		border-color: rgba(124,58,237,0.4);
	}
}
.pricing-card-glow:hover {
	box-shadow:
		0 0 50px rgba(124,58,237,0.2),
		0 0 100px rgba(124,58,237,0.1),
		0 0 150px rgba(6,182,212,0.06);
	border-color: rgba(124,58,237,0.5);
}

/* ─── FEATURE CARD HOVER ─── */
.feature-card-hover {
	transition: transform 0.25s ease-out, box-shadow 0.25s ease-out, border-color 0.25s ease-out;
}
.feature-card-hover:hover {
	transform: translateY(-4px) scale(1.01);
	box-shadow: 0 12px 40px rgba(124,58,237,0.12);
	border-color: rgba(124,58,237,0.3);
}

/* ─── RESPONSIVE ─── */
@media (max-width: 640px) {
	body { font-size: 15px; }
	.container { padding: 0 1.25rem; }
	.section-header { margin-bottom: 2.5rem; }
}

@media (min-width: 640px) and (max-width: 1023px) {
	.container { padding: 0 2rem; }
}
