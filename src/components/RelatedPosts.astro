---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type Props = {
  currentTags: string[];
  currentId: string;
  limit?: number;
};

const { currentTags, currentId, limit = 3 }: Props = Astro.props;

const allPosts = (await getCollection('blog'))
  .filter(post => post.id !== currentId);

const getRelatedPosts = (posts, tags, lim) => {
  const scored = posts.map(post => {
    let score = 0;
    const postTags = post.data.tags || [];
    const matchingTags = postTags.filter(tag => tags.includes(tag));
    score += matchingTags.length * 10;
    if (post.data.author === 'Álvaro Cerpa') {
      score += 5;
    }
    return { post, score };
  });
  return scored
    .sort((a, b) => b.score - a.score)
    .slice(0, lim)
    .map(item => item.post);
};

const relatedPosts = getRelatedPosts(allPosts, currentTags, limit);
---

<section class="related-posts">
  <h3>Artículos relacionados</h3>

  {relatedPosts.length === 0 ? (
    <p class="no-posts">No hay artículos relacionados.</p>
  ) : (
    <ul class="related-list">
      {relatedPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>
            <span class="post-title">{post.data.title}</span>
            <span class="post-date">
              {new Date(post.data.pubDate).toLocaleDateString('es-ES', {
                day: 'numeric',
                month: 'short',
                year: 'numeric'
              })}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .related-posts {
    margin: 2.5rem 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .related-posts h3 {
    font-size: 1rem;
    color: #fff;
    margin: 0 0 1rem;
    font-weight: 700;
  }

  .no-posts {
    color: rgba(250,250,250,0.4);
    font-size: 0.9rem;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .related-list li {
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }

  .related-list li:last-child {
    border-bottom: none;
  }

  .related-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 0;
    text-decoration: none;
  }

  .related-list a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    color: #fafafa;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .post-date {
    color: rgba(250,250,250,0.3);
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .related-list a {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
