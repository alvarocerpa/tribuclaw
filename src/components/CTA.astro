---
import { WHOP_URL } from '../consts';
interface Props {
	text?: string;
	subtitle?: string;
}
const { text = '¿Quieres tu propio agente IA?', subtitle = 'Únete a TribuClaw y aprende paso a paso.' } = Astro.props;
---
<p class="inline-cta"><strong>{text}</strong> {subtitle} <a href={WHOP_URL} target="_blank">Entrar a TribuClaw →</a></p>
<style>
	.inline-cta {
		margin: 2rem 0;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--text-muted);
	}
	.inline-cta a {
		color: #7C3AED;
		font-weight: 700;
		white-space: nowrap;
	}

	@media (max-width: 720px) {
		.inline-cta { margin: 1.5rem 0; }
		.inline-cta a { white-space: normal; }
	}
</style>
