---
import { WHOP_URL } from '../consts';
const today = new Date();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-row">
      <a href="/" class="footer-logo">Tribu<span class="accent">Claw</span></a>
      <nav class="footer-links">
        <a href="/">Inicio</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">Nosotros</a>
        <a href={WHOP_URL} target="_blank" rel="noopener" class="accent-link">Unirme →</a>
      </nav>
    </div>
    <p class="footer-copy">&copy; {today.getFullYear()} TribuClaw.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: #0d1117;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 1.5rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: #fff;
    text-decoration: none;
  }
  .footer-logo:hover { text-decoration: none; }
  .accent { color: #e94560; }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: rgba(250,250,250,0.5);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s;
    font-family: 'Inter', sans-serif;
  }
  .footer-links a:hover { color: #e94560; text-decoration: none; }
  .accent-link { color: #e94560 !important; font-weight: 600; }
  .footer-copy {
    color: rgba(250,250,250,0.25);
    font-size: 0.75rem;
    margin: 1.5rem 0 0;
    font-family: 'Inter', sans-serif;
  }

  @media (max-width: 639px) {
    .footer-row { flex-direction: column; gap: 1.25rem; text-align: center; }
    .footer-links { gap: 1rem; }
  }
</style>
