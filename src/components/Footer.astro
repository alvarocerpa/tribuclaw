---
import { WHOP_URL } from '../consts';
const today = new Date();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Tribu<span class="accent">Claw</span></a>
        <p class="footer-desc">La comunidad en español que te enseña a crear, configurar y dominar tu agente IA personal.</p>
      </div>
      <div class="footer-col">
        <h4>Navegación</h4>
        <a href="/">Inicio</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">Nosotros</a>
        <a href="/#pricing">Precio</a>
      </div>
      <div class="footer-col">
        <h4>Legal</h4>
        <a href="/privacidad/">Privacidad</a>
        <a href="/terminos/">Términos</a>
      </div>
      <div class="footer-col">
        <h4>Newsletter</h4>
        <p class="newsletter-desc">Tips semanales sobre agentes IA.</p>
        <!-- TODO: Álvaro debe configurar el endpoint real (ej. formspree.io/f/TU_ID) -->
        <form class="newsletter-form" action="#" method="POST">
          <input type="email" name="email" placeholder="tu@email.com" required aria-label="Email" />
          <button type="submit" aria-label="Suscribir">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {today.getFullYear()} TribuClaw. Todos los derechos reservados.</p>
      <div class="footer-social">
        <a href="https://x.com/tribuclaw" target="_blank" rel="noopener" aria-label="Twitter/X">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.youtube.com/@tribuclaw" target="_blank" rel="noopener" aria-label="YouTube">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href={WHOP_URL} target="_blank" rel="noopener" aria-label="Whop" class="accent-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0a0d12;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 4rem 1.5rem 2rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  .footer-brand { max-width: 300px; }
  .footer-logo {
    font-family: 'Space Grotesk', 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: #fff;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  .footer-logo:hover { text-decoration: none; }
  .accent { color: #e94560; }
  .footer-desc {
    color: rgba(250,250,250,0.4);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }
  .footer-col h4 {
    font-family: 'Space Grotesk', 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: rgba(250,250,250,0.6);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }
  .footer-col a {
    display: block;
    color: rgba(250,250,250,0.4);
    font-size: 0.85rem;
    text-decoration: none;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: #e94560; text-decoration: none; }
  .newsletter-desc {
    color: rgba(250,250,250,0.4);
    font-size: 0.8rem;
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }
  .newsletter-form input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    color: #fff;
    font-size: 0.8rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-form input::placeholder { color: rgba(250,250,250,0.3); }
  .newsletter-form input:focus { border-color: rgba(233,69,96,0.4); }
  .newsletter-form button {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e94560;
    border: none;
    border-radius: 8px;
    padding: 0.6rem 0.75rem;
    color: #fff;
    cursor: pointer;
    transition: background 0.2s;
  }
  .newsletter-form button:hover { background: #d13a53; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-copy {
    color: rgba(250,250,250,0.25);
    font-size: 0.75rem;
    margin: 0;
  }
  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .footer-social a {
    color: rgba(250,250,250,0.3);
    transition: color 0.2s;
    display: flex;
  }
  .footer-social a:hover { color: #e94560; }
  .accent-link { color: #e94560 !important; }

  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 2fr; }
  }
  @media (max-width: 639px) {
    .footer-bottom { flex-direction: column; text-align: center; }
  }
</style>
