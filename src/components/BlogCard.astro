---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  slug: string;
  heroImage?: string;
  readingTime?: number;
}

const { title, description, pubDate, tags = [], slug, heroImage, readingTime } = Astro.props;
---

<article class="blog-card glass-card">
  <a href={`/blog/${slug}/`}>
    <div class="card-image">
      <img
        src={heroImage || '/images/og-default.jpg'}
        alt={title}
        loading="lazy"
        decoding="async"
        width="400"
        height="225"
      />
    </div>
    <div class="card-body">
      {tags.length > 0 && (
        <div class="card-tags">
          {tags.slice(0, 3).map((tag) => <span class="card-tag">{tag}</span>)}
        </div>
      )}
      <h3 class="card-title">{title}</h3>
      <p class="card-excerpt">{description}</p>
      <div class="card-meta">
        <time class="card-date"><FormattedDate date={pubDate} /></time>
        {readingTime && (
          <span class="card-reading-time">{readingTime} min lectura</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card {
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s, box-shadow 0.3s;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    border-color: rgba(233,69,96,0.25);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 20px rgba(233,69,96,0.08);
  }
  .blog-card a {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .blog-card a:hover { text-decoration: none; color: inherit; }

  .card-image {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-alt);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .blog-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-body {
    padding: 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .card-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    background: rgba(233,69,96,0.08);
    border: 1px solid rgba(233,69,96,0.15);
    color: #e94560;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
    color: #fff;
  }
  .blog-card:hover .card-title {
    color: var(--accent);
  }

  .card-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .card-date {
    font-size: 0.75rem;
    color: rgba(250,250,250,0.3);
  }
  .card-reading-time {
    font-size: 0.7rem;
    color: rgba(250,250,250,0.25);
  }

  @media (max-width: 640px) {
    .card-body { padding: 1rem 1rem 1.25rem; }
    .card-title { font-size: 0.95rem; }
    .card-excerpt { -webkit-line-clamp: 2; }
  }
</style>
